# .env.example — copy to .env and fill in for local dev.
# Real production values live in the Cloudflare Pages dashboard.
# DO NOT commit a real .env file.

# ────────────────────────────────────────────────────────────────────────────
# Build-time config (read by scripts/prebuild-polls.mjs + injected into HTML)
# ────────────────────────────────────────────────────────────────────────────

# JSON-string of the polls array.
# Locally you can leave this empty and edit data/polls.json directly.
# In CI (Cloudflare Pages) this is required when data/polls.json is gitignored.
# Shape per poll: see src/data/polls.ts (Poll type) — at minimum:
#   {"slug":"copenhagen-2026","title":"Copenhagen — family trip",
#    "dateRangeStart":"2026-06-01","dateRangeEnd":"2026-09-30",
#    "pollCloseAt":"2026-06-14T23:59:59+02:00",
#    "organizerToken":"...22-char nanoid...",
#    "participants":[{"token":"...16-char nanoid...","name":"Alice"}],
#    "createdAt":"2026-05-28T00:00:00Z"}
WHENWEGO_POLLS_JSON=

# Render a loud yellow striped "DEMO POLL — nothing here is real" banner at
# the top of every page. Set to "true" for showcase / demo deployments.
# Leave unset for production.
WHENWEGO_DEMO_MODE=

# Hide both the built-with-when-we-go badge AND the sibling cross-link to
# pay-me-back in BaseLayout's footer. Optional escape hatch for adopters
# who don't want either. Leave unset to show both (default).
WHENWEGO_HIDE_FOOTERS=

# ────────────────────────────────────────────────────────────────────────────
# Browser-exposed config (Astro inlines anything prefixed PUBLIC_*)
# ────────────────────────────────────────────────────────────────────────────

# Absolute URL of the public site. Used for resolving OG image meta tags etc.
#   Local dev:  http://localhost:4321
#   Production: https://when.your-domain.com
PUBLIC_SITE_URL=http://localhost:4321

# Client-side API base URL (Phase 2 onwards).
#   Local dev:  http://localhost:8787 (wrangler dev)
#   Production: https://when.your-domain.com   (set in .env.production, committed)
# If unset in prod the client falls back to same-origin.
PUBLIC_API_BASE=http://localhost:8787

# ────────────────────────────────────────────────────────────────────────────
# Worker / Durable Object secrets (Phase 2 onwards — set via wrangler secret put)
# ────────────────────────────────────────────────────────────────────────────

# Optional Telegram bot for organizer pings when poll closes + on first vote.
# Set via: `npx wrangler secret put WHENWEGO_TELEGRAM_BOT_TOKEN` (and CHAT_ID).
# When unset, notifications are silently skipped — API still works fine.
WHENWEGO_TELEGRAM_BOT_TOKEN=
WHENWEGO_TELEGRAM_CHAT_ID=

# Comma-separated list of extra Origins allowed to hit the Worker's /api/*
# endpoints. `http://localhost:4321` and `http://localhost:8787` are always
# allowed (so local dev + smoke tests work out of the box). Add your prod
# domain only if the static site is served from a different origin than the
# Worker route. Example: "https://when.your-domain.com,https://staging.example.com"
ALLOWED_ORIGINS=
