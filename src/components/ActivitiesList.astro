---
// src/components/ActivitiesList.astro
// Phase 7 — post-close curated activity list widget. Hidden on SSR; the parent
// [token].astro page IIFE reveals + populates it after /api/activities resolves.
//
// Wire-up:
//   - Two sections: "Happening this week" + "Always great"
//   - Type icons per item (🎵 🎨 🏛️ 🍽️ 🌳 🏰 🏘️ 🎉 🔮)
//   - Confidence badges on medium/low items (ℹ verify dates / ⚠ check schedule)
//   - DEMO banner when provider.isReal === false
//   - Refresh button visible to organisers only (gated by `mode` prop)
---

<section
  id="activities-list"
  class="activities-list"
  hidden
  aria-labelledby="activities-title"
>
  <div class="activities-header">
    <h2 id="activities-title" class="activities-title">
      Was ihr machen könnt
    </h2>
    <button
      type="button"
      class="activities-refresh"
      data-activities-refresh
      hidden
    >
      Aktualisieren
    </button>
  </div>

  <div class="activities-demo-banner" data-activities-demo-banner hidden>
    <strong>📍 Vorläufige Vorschläge</strong> — echte, KI-kuratierte Tipps
    erscheinen, sobald der Anthropic-Key gesetzt ist.
  </div>

  <p class="activities-meta" data-activities-meta hidden></p>

  {/* Feature 2: loading skeleton — photo cards, hidden on render. */}
  <div class="skeleton-list" data-activities-skeleton hidden aria-hidden="true">
    <div class="skeleton-card skeleton-card--tall"><div class="skeleton-photo"></div><div class="skeleton-line skeleton-line--title"></div><div class="skeleton-line skeleton-line--sub"></div></div>
    <div class="skeleton-card skeleton-card--tall"><div class="skeleton-photo"></div><div class="skeleton-line skeleton-line--title"></div><div class="skeleton-line skeleton-line--sub"></div></div>
  </div>

  <div class="activities-state" data-activities-state hidden>
    <p data-activities-state-text></p>
  </div>

  <div class="activities-section" data-activities-thisweek-section hidden>
    <h3 class="activities-section-title">Diese Woche</h3>
    <ul class="activities-items" data-activities-thisweek></ul>
  </div>

  <div class="activities-section" data-activities-alwaysgreat-section hidden>
    <h3 class="activities-section-title">Immer einen Besuch wert</h3>
    <ul class="activities-items" data-activities-alwaysgreat></ul>
  </div>

  <p class="activities-disclaimer">
    Kuratiert von Claude — konkrete Termine & Preise bitte auf der
    Veranstalter-Seite prüfen.
  </p>
</section>

<style>
  .activities-list {
    margin: 16px 0;
    padding: 18px;
    background: #fff;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 2px 10px rgba(15,23,42,0.07), 0 1px 3px rgba(15,23,42,0.05);
  }
  .activities-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .activities-title {
    margin: 0;
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 17px;
    font-weight: 700;
    color: var(--color-on-background, #0f172a);
    letter-spacing: -0.01em;
  }
  .activities-refresh {
    appearance: none;
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-surface-container-low, #eef4fb);
    color: var(--color-primary, #0066cc);
    padding: 5px 12px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s;
  }
  .activities-refresh:hover { background: var(--color-primary-fixed, #cce0ff); }
  .activities-refresh:disabled { opacity: 0.45; cursor: not-allowed; }
  .activities-meta {
    margin: 0 0 12px 0;
    font-size: 13px;
    color: var(--color-on-surface-variant, #475569);
  }
  .activities-demo-banner {
    margin: 0 0 12px 0;
    padding: 10px 12px;
    font-size: 13px;
    line-height: 1.4;
    background: #fffbeb;
    border: 1px solid #fcd34d;
    border-radius: var(--radius-sm, 6px);
    color: #78350f;
  }
  .activities-state {
    padding: 16px;
    background: var(--color-surface-container-low, #eef4fb);
    border-radius: var(--radius-sm, 6px);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-on-surface-variant, #475569);
  }
  .activities-section { margin-top: 16px; }
  .activities-section-title {
    margin: 0 0 8px 0;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-on-surface-variant, #475569);
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-outline-variant, #cbd5e1);
  }
  .activities-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .activity-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 10px;
    padding: 11px 12px;
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: #fff;
    align-items: start;
    transition: border-color 0.12s;
  }
  .activity-card:hover { border-color: var(--color-primary, #0066cc); }
  .activity-card.is-low { opacity: 0.75; }
  .activity-card-icon { font-size: 20px; line-height: 1.2; }
  .activity-card-body { min-width: 0; }
  .activity-card-name {
    margin: 0 0 3px 0;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-on-background, #0f172a);
  }
  .activity-card-why {
    margin: 0;
    font-size: 12px;
    line-height: 1.45;
    color: var(--color-on-surface-variant, #475569);
  }
  .activity-card-meta {
    margin: 4px 0 0 0;
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
  }
  .activity-card-right {
    text-align: right;
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
    white-space: nowrap;
  }
  .activity-card-price {
    font-weight: 700;
    font-size: 13px;
    color: var(--color-on-background, #0f172a);
  }
  .activity-confidence-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-top: 4px;
    padding: 2px 7px;
    font-size: 10px;
    font-weight: 600;
    border-radius: 99px;
  }
  .activity-confidence-badge.is-medium {
    background: #fef3c7;
    color: #92400e;
  }
  .activity-confidence-badge.is-low {
    background: #fee2e2;
    color: #991b1b;
  }
  .activities-disclaimer {
    margin: 12px 0 0 0;
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
  }
</style>
