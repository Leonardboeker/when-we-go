---
// src/components/HotelShortlist.astro
// Phase 6 — post-close hotel shortlist widget. Renders hidden on SSR; the
// parent page IIFE populates it after /api/hotels resolves.
//
// Wire-up:
//   Participant page ([token].astro):
//     - On poll close + reason='ok': render shared shortlist
//     - "Vote for this one" button → POST /api/hotel-vote { slug, token, hotelId }
//     - "✓ Chosen by organiser" badge when chosenHotelId matches
//     - Yellow DEMO banner when provider.isReal === false
//
//   Admin page (admin/[token].astro):
//     - Same shortlist + "Mark as chosen" buttons → POST /api/admin/hotel-choose
//     - Vote tally pill on each card
//     - "Refresh hotels" button → POST /api/hotels/refresh (org-only, 1/4h)
//
// `mode` prop ('participant' | 'admin') gates which controls render — the
// markup is shared so both views always look like the same product.
interface Props {
  mode: 'participant' | 'admin';
}
const { mode } = Astro.props as Props;
---

<section
  id="hotel-shortlist"
  class="hotel-shortlist"
  data-hotel-mode={mode}
  hidden
  aria-labelledby="hotel-shortlist-title"
>
  <div class="hotel-shortlist-header">
    <h2 id="hotel-shortlist-title" class="hotel-shortlist-title">
      Hotels für die Gruppe
    </h2>
    {
      mode === 'admin' && (
        <button
          type="button"
          class="hotel-shortlist-refresh"
          data-hotels-refresh
        >
          Aktualisieren
        </button>
      )
    }
  </div>

  {/* Curated real hotels → provider.isReal = true → this banner stays hidden. */}
  <div class="hotel-shortlist-demo-banner" data-hotels-demo-banner hidden></div>

  <p class="hotel-shortlist-meta" data-hotels-meta hidden></p>

  {/* Feature 2: loading skeleton — photo + lines, hidden on render. */}
  <div class="skeleton-list" data-hotels-skeleton hidden aria-hidden="true">
    <div class="skeleton-card skeleton-card--tall"><div class="skeleton-photo"></div><div class="skeleton-line skeleton-line--title"></div><div class="skeleton-line skeleton-line--sub"></div></div>
    <div class="skeleton-card skeleton-card--tall"><div class="skeleton-photo"></div><div class="skeleton-line skeleton-line--title"></div><div class="skeleton-line skeleton-line--sub"></div></div>
  </div>

  <div class="hotel-shortlist-state" data-hotels-state hidden>
    <p data-hotels-state-text></p>
  </div>

  <ul class="hotel-shortlist-list" data-hotels-list hidden></ul>

  <p class="hotel-shortlist-disclaimer">
    Handverlesene echte Hotels — alle sehen dieselbe Liste. Aktuelle Preise und
    Verfügbarkeit siehst du live auf Booking.com.
  </p>
</section>

<style>
  .hotel-shortlist {
    margin: 16px 0;
    padding: 18px;
    background: #fff;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 2px 10px rgba(15,23,42,0.07), 0 1px 3px rgba(15,23,42,0.05);
  }
  .hotel-shortlist-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hotel-shortlist-title {
    margin: 0;
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 17px;
    font-weight: 700;
    color: var(--color-on-background, #0f172a);
    letter-spacing: -0.01em;
  }
  .hotel-shortlist-refresh {
    appearance: none;
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-surface-container-low, #eef4fb);
    color: var(--color-primary, #0066cc);
    padding: 5px 12px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s;
  }
  .hotel-shortlist-refresh:hover { background: var(--color-primary-fixed, #cce0ff); }
  .hotel-shortlist-refresh:disabled { opacity: 0.45; cursor: not-allowed; }
  .hotel-shortlist-meta {
    margin: 0 0 12px 0;
    font-size: 13px;
    color: var(--color-on-surface-variant, #475569);
  }
  .hotel-shortlist-demo-banner {
    margin: 0 0 12px 0;
    padding: 10px 12px;
    font-size: 13px;
    line-height: 1.4;
    background: #fffbeb;
    border: 1px solid #fcd34d;
    border-radius: var(--radius-sm, 6px);
    color: #78350f;
  }
  .hotel-shortlist-state {
    padding: 16px;
    background: var(--color-surface-container-low, #eef4fb);
    border-radius: var(--radius-sm, 6px);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-on-surface-variant, #475569);
  }
  .hotel-shortlist-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .hotel-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    padding: 13px 14px;
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: #fff;
    align-items: start;
    transition: border-color 0.12s, box-shadow 0.12s;
  }
  .hotel-card:hover { border-color: var(--color-primary, #0066cc); box-shadow: 0 2px 8px rgba(0,102,204,0.1); }
  .hotel-card.is-chosen {
    border-color: #16a34a;
    border-width: 2px;
    background: #f0fdf4;
  }
  .hotel-card-name {
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 4px 0;
    color: var(--color-on-background, #0f172a);
  }
  .hotel-card-meta {
    font-size: 12px;
    color: var(--color-on-surface-variant, #475569);
    margin: 0;
  }
  .hotel-card-amenities {
    margin-top: 4px;
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
  }
  .hotel-card-prices { text-align: right; }
  .hotel-card-pp {
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 22px;
    font-weight: 800;
    margin: 0;
    color: var(--color-on-background, #0f172a);
    letter-spacing: -0.02em;
  }
  .hotel-card.is-chosen .hotel-card-pp { color: #16a34a; }
  .hotel-card-pp-live {
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 16px;
    font-weight: 800;
    margin: 0;
    color: var(--color-primary, #0066cc);
    letter-spacing: -0.01em;
  }
  .hotel-card-pp-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-on-surface-variant, #475569);
  }
  .hotel-card-total {
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
    margin-top: 4px;
  }
  .hotel-card-actions {
    grid-column: 1 / -1;
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .hotel-card-button {
    appearance: none;
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: #fff;
    color: var(--color-on-background, #0f172a);
    padding: 5px 12px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s;
  }
  .hotel-card-button:hover { border-color: var(--color-primary, #0066cc); color: var(--color-primary, #0066cc); }
  .hotel-card-button:disabled { opacity: 0.55; cursor: not-allowed; }
  .hotel-card-button-primary {
    background: var(--color-primary, #0066cc);
    border-color: var(--color-primary, #0066cc);
    color: #fff;
  }
  .hotel-card-button-primary:hover { background: #0052a3; border-color: #0052a3; color: #fff; }
  /* Feature 4: book CTA button */
  .hotel-card-button-book {
    background: #0066cc;
    border-color: #0066cc;
    color: #fff;
    text-decoration: none;
    margin-left: auto;
  }
  .hotel-card-button-book:hover { background: #0052a3; border-color: #0052a3; color: #fff; }
  .hotel-card-vote-tally {
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
  }
  .hotel-card-chosen-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    background: #dcfce7;
    color: #166534;
    border-radius: 99px;
    font-size: 11px;
    font-weight: 600;
  }
  .hotel-shortlist-disclaimer {
    margin: 12px 0 0 0;
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
  }
</style>
