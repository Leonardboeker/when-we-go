---
// src/components/PollHeader.astro
// Modern card header — matches Stitch "Trip Planner Modern" design.
// White card + shadow, destination pill, large Bricolage headline,
// orange rounded countdown badge.
import { daysUntil } from '../lib/calendar';

interface Props {
  participantName: string;
  title: string;
  destination?: string;
  pollCloseAt: string;
}

const { participantName, title, destination, pollCloseAt } = Astro.props;

const days = daysUntil(pollCloseAt);
const closed = days === 0;
const closeDateShort = new Date(pollCloseAt).toLocaleString('de-DE', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
---

<header class="poll-header">
  {/* Destination pill */}
  {destination && (
    <div class="poll-header-pill">
      <span class="poll-header-pill-dot"></span>
      {destination}
    </div>
  )}

  {/* Greeting + headline */}
  <p class="poll-header-greeting">Hey <strong>{participantName}</strong></p>
  <h1 class="poll-header-title">
    {destination
      ? <>Wann kannst du?</>
      : <>Wann kannst du bei <span class="poll-header-dest">{title}</span>?</>}
  </h1>

  {/* Poll close meta */}
  <p class="poll-header-meta">
    Abstimmung endet {closeDateShort}
  </p>

  {/* Countdown badge — daysUntil(pollCloseAt) is computed at BUILD TIME, so
       without this client-side updater the number freezes on the day the
       static page was built. data-poll-close drives a tiny IIFE below that
       overrides the SSR number on load + on tab-focus / day-flip. */}
  <div
    class={['poll-countdown', closed && 'poll-countdown--closed'].filter(Boolean).join(' ')}
    data-poll-countdown
    data-poll-close={pollCloseAt}
  >
    {closed ? (
      <span class="poll-countdown-label" data-poll-countdown-label>Abstimmung beendet</span>
    ) : (
      <>
        <span class="poll-countdown-num" data-poll-countdown-num>{days}</span>
        <span class="poll-countdown-label" data-poll-countdown-label>Tag{days === 1 ? '' : 'e'} zum Abstimmen</span>
      </>
    )}
  </div>

  {/* Feature 8: participant progress — populated by IIFE */}
  <div id="participant-progress" class="participant-progress" hidden></div>
</header>

<style>
  .poll-header {
    background: var(--color-surface-container-lowest, #fff);
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 2px 12px rgba(15, 23, 42, 0.08), 0 1px 3px rgba(15, 23, 42, 0.06);
    padding: 20px 20px 20px;
    margin: 0 0 16px;
  }

  /* Destination pill */
  .poll-header-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: var(--color-primary-fixed, #cce0ff);
    color: var(--color-on-primary-container, #001e42);
    border-radius: 99px;
    font-family: var(--font-sans, 'DM Sans', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    margin: 0 0 12px;
  }
  .poll-header-pill-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-primary, #0066cc);
    flex-shrink: 0;
  }

  /* Greeting */
  .poll-header-greeting {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-on-surface-variant, #475569);
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .poll-header-greeting strong {
    color: var(--color-on-background, #0f172a);
    font-weight: 700;
  }

  /* Headline */
  .poll-header-title {
    font-family: var(--font-headline, 'Bricolage Grotesque', 'Syne', sans-serif);
    font-size: clamp(24px, 6vw, 34px);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 10px;
    color: var(--color-on-background, #0f172a);
    letter-spacing: -0.02em;
  }
  .poll-header-dest {
    color: var(--color-primary, #0066cc);
  }

  /* Close date meta */
  .poll-header-meta {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 13px;
    color: var(--color-on-surface-variant, #475569);
    margin: 0 0 14px;
  }

  /* Countdown badge */
  .poll-countdown {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 8px 16px;
    background: var(--color-primary, #0066cc);
    color: #fff;
    border-radius: var(--radius-sm, 6px);
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
  }
  .poll-countdown-num {
    font-size: 20px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .poll-countdown-label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .poll-countdown--closed {
    background: var(--color-surface-container-high, #c9daf0);
    color: var(--color-on-surface-variant, #475569);
  }

  /* Feature 8: participant progress */
  .participant-progress {
    margin-top: 8px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 13px;
    color: #475569;
  }
</style>

<script is:inline>
  /* Live countdown — recomputes days-until-close on load, on tab focus, and
     once per hour. Without this the SSR number froze at the build-day value. */
  (function () {
    var root = document.querySelector('[data-poll-countdown]');
    if (!root) return;
    var iso = root.getAttribute('data-poll-close');
    if (!iso) return;
    var closeMs = Date.parse(iso);
    if (!isFinite(closeMs)) return;

    function recompute() {
      var nowMs = Date.now();
      var msLeft = closeMs - nowMs;
      var days = Math.max(0, Math.ceil(msLeft / 86400000));
      var closed = msLeft <= 0;

      var numEl = root.querySelector('[data-poll-countdown-num]');
      var labelEl = root.querySelector('[data-poll-countdown-label]');

      if (closed) {
        root.classList.add('poll-countdown--closed');
        if (numEl) numEl.remove();
        if (labelEl) labelEl.textContent = 'Abstimmung beendet';
        return;
      }
      root.classList.remove('poll-countdown--closed');
      if (numEl) numEl.textContent = String(days);
      if (labelEl) labelEl.textContent = (days === 1 ? 'Tag' : 'Tage') + ' zum Abstimmen';
    }

    recompute();
    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'visible') recompute();
    });
    setInterval(recompute, 60 * 60 * 1000); // hourly fallback for left-open tabs
  })();
</script>
