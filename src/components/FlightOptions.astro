---
// src/components/FlightOptions.astro
// Phase 5 — post-close flight options widget. Renders empty (hidden) on SSR;
// the parent [token].astro page IIFE populates it after the poll closes.
//
// Wire-up (in [token].astro):
//   - On poll close + reason='ok': fill cards from /api/flights response
//   - On reason !== 'ok': show the matching message variant
//   - Refresh button calls POST /api/flights/refresh — disabled for 1h after
//     a successful refresh
//
// Layout:
//   - Header row with title + "Refresh" button
//   - 3 cheapest cards
//   - "See all options" collapsible (rest of the list)
//   - State messages (one of: configure / profile / no_routes / api_down)
---

<section
  id="flight-options"
  class="flight-options"
  hidden
  aria-labelledby="flight-options-title"
>
  <div class="flight-options-header">
    <h2 id="flight-options-title" class="flight-options-title">Flüge für euch</h2>
    <button
      type="button"
      class="flight-options-refresh"
      data-flights-refresh
      hidden
    >
      Aktualisieren
    </button>
  </div>

  {/* Deeplinks mode: no in-app prices, so the DEMO banner stays hidden. */}
  <div class="flight-options-demo-banner" data-flights-demo-banner hidden></div>

  <p class="flight-options-meta" data-flights-meta hidden></p>

  {/* Feature 2: loading skeleton — shown while fetching, hidden on render. */}
  <div class="skeleton-list" data-flights-skeleton hidden aria-hidden="true">
    <div class="skeleton-card"><div><div class="skeleton-line skeleton-line--title"></div><div class="skeleton-line skeleton-line--sub"></div></div><div class="skeleton-line skeleton-line--price"></div></div>
    <div class="skeleton-card"><div><div class="skeleton-line skeleton-line--title"></div><div class="skeleton-line skeleton-line--sub"></div></div><div class="skeleton-line skeleton-line--price"></div></div>
    <div class="skeleton-card"><div><div class="skeleton-line skeleton-line--title"></div><div class="skeleton-line skeleton-line--sub"></div></div><div class="skeleton-line skeleton-line--price"></div></div>
  </div>

  <!-- State messages — exactly one shown depending on reason. -->
  <div class="flight-options-state" data-flights-state hidden>
    <p data-flights-state-text></p>
    <a
      class="flight-options-google-link"
      data-flights-google-link
      href="#"
      target="_blank"
      rel="noopener"
      hidden
      >Try Google Flights instead →</a
    >
  </div>

  <ul class="flight-options-list" data-flights-list hidden></ul>

  <details class="flight-options-more" data-flights-more hidden>
    <summary>Alle Optionen</summary>
    <ul class="flight-options-rest" data-flights-rest></ul>
  </details>

  <p class="flight-options-disclaimer">
    Echte Live-Preise siehst du direkt bei Google Flights bzw. Skyscanner.
  </p>
</section>

<style>
  .flight-options {
    margin: 16px 0;
    padding: 18px;
    background: #fff;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 2px 10px rgba(15,23,42,0.07), 0 1px 3px rgba(15,23,42,0.05);
  }
  .flight-options-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .flight-options-title {
    margin: 0;
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 17px;
    font-weight: 700;
    color: var(--color-on-background, #0f172a);
    letter-spacing: -0.01em;
  }
  .flight-options-refresh {
    appearance: none;
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-surface-container-low, #eef4fb);
    color: var(--color-primary, #0066cc);
    padding: 5px 12px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s;
  }
  .flight-options-refresh:hover { background: var(--color-primary-fixed, #cce0ff); }
  .flight-options-refresh:disabled { opacity: 0.45; cursor: not-allowed; }
  .flight-options-meta {
    margin: 0 0 12px 0;
    font-size: 13px;
    color: var(--color-on-surface-variant, #475569);
  }
  .flight-options-demo-banner {
    margin: 0 0 12px 0;
    padding: 10px 12px;
    font-size: 13px;
    line-height: 1.4;
    background: #fffbeb;
    border: 1px solid #fcd34d;
    border-radius: var(--radius-sm, 6px);
    color: #78350f;
  }
  .flight-options-state {
    padding: 16px;
    background: var(--color-surface-container-low, #eef4fb);
    border-radius: var(--radius-sm, 6px);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-on-surface-variant, #475569);
  }
  .flight-options-google-link {
    display: inline-block;
    margin-top: 8px;
    font-weight: 600;
    color: var(--color-primary, #0066cc);
    font-size: 13px;
  }
  .flight-options-list,
  .flight-options-rest {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .flight-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    padding: 12px 14px;
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: #fff;
    align-items: center;
    transition: border-color 0.12s, box-shadow 0.12s;
  }
  .flight-card:hover { border-color: var(--color-primary, #0066cc); box-shadow: 0 2px 8px rgba(0,102,204,0.1); }
  .flight-card.is-cheapest {
    border-color: #16a34a;
    background: #f0fdf4;
  }
  .flight-card-main strong { font-size: 14px; font-weight: 700; }
  .flight-card-meta {
    font-size: 12px;
    color: var(--color-on-surface-variant, #475569);
    margin-top: 3px;
  }
  .flight-card-price {
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 20px;
    font-weight: 800;
    color: var(--color-on-background, #0f172a);
    letter-spacing: -0.02em;
  }
  .flight-card.is-cheapest .flight-card-price { color: #16a34a; }
  .flight-card-book {
    display: inline-block;
    margin-top: 4px;
    font-size: 11px;
    color: var(--color-primary, #0066cc);
    font-weight: 600;
    text-decoration: none;
  }
  .flight-options-more { margin-top: 10px; }
  .flight-options-more summary {
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary, #0066cc);
  }
  .flight-options-disclaimer {
    margin: 12px 0 0 0;
    font-size: 11px;
    color: var(--color-on-surface-variant, #475569);
  }
  /* Real-deeplink card (replaces fake price cards) */
  .flight-deeplink-card {
    border: 1.5px solid var(--color-outline-variant, #cbd5e1);
    border-radius: var(--radius-sm, 6px);
    background: #fff;
    padding: 16px;
  }
  .flight-deeplink-route {
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--color-on-background, #0f172a);
  }
  .flight-deeplink-sub {
    margin-top: 4px;
    font-size: 13px;
    color: var(--color-on-surface-variant, #475569);
  }
  .flight-deeplink-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }
  .flight-deeplink-btn {
    flex: 1 1 auto;
    text-align: center;
    padding: 10px 14px;
    border: 1.5px solid var(--color-primary, #0066cc);
    border-radius: var(--radius-sm, 6px);
    background: #fff;
    color: var(--color-primary, #0066cc);
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.12s, color 0.12s;
  }
  .flight-deeplink-btn:hover { background: var(--color-primary-fixed, #cce0ff); }
  .flight-deeplink-btn-primary {
    background: var(--color-primary, #0066cc);
    color: #fff;
  }
  .flight-deeplink-btn-primary:hover { background: #0052a3; color: #fff; }
  .flight-deeplink-note {
    padding: 14px 16px;
    background: var(--color-surface-container-low, #eef4fb);
    border-radius: var(--radius-sm, 6px);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-on-surface-variant, #475569);
  }
  .flight-deeplink-note a {
    color: var(--color-primary, #0066cc);
    font-weight: 700;
    text-decoration: none;
  }
</style>
