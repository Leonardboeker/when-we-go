---
// src/components/CalendarGrid.astro
// Phase 1: visual-only calendar. Weeks as rows, days as cells, Mon-first.
// All cells are disabled <button>s so Phase 2 JS can re-enable them without
// changing the DOM shape. Sticky month-divider rows segment the grid by month.
// Weekend cells get a diagonal stripe pattern. Today gets a primary border.
import {
  enumerateDays,
  groupByWeek,
  isWeekend,
  isToday,
  monthHeader,
  type Week,
} from '../lib/calendar';

interface Props {
  dateRangeStart: string;
  dateRangeEnd: string;
}

const { dateRangeStart, dateRangeEnd } = Astro.props;

const allDays = enumerateDays(dateRangeStart, dateRangeEnd);
const weeks: Week[] = groupByWeek(allDays);

// Walk the weeks and inject a month-divider whenever the first non-null cell
// of a week starts a new calendar month.
type Row =
  | { kind: 'month'; label: string }
  | { kind: 'week'; week: Week };

const rows: Row[] = [];
let lastMonthKey = '';
for (const week of weeks) {
  // Find the first real day in the week (skip nulls).
  const firstReal = week.days.find((d): d is string => d !== null);
  if (firstReal) {
    const monthKey = firstReal.slice(0, 7); // YYYY-MM
    if (monthKey !== lastMonthKey) {
      rows.push({ kind: 'month', label: monthHeader(firstReal) });
      lastMonthKey = monthKey;
    }
  }
  rows.push({ kind: 'week', week });
}

const WEEKDAY_LABELS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
---

<section
  class="calendar-grid"
  aria-label="Date availability grid"
  data-poll-start={dateRangeStart}
  data-poll-end={dateRangeEnd}
>
  <div class="calendar-weekdays" aria-hidden="true">
    {WEEKDAY_LABELS.map((label) => (
      <div class={['calendar-weekday', (label === 'Sat' || label === 'Sun') && 'is-weekend'].filter(Boolean).join(' ')}>
        {label}
      </div>
    ))}
  </div>

  <div class="calendar-rows" role="grid">
    {rows.map((row) =>
      row.kind === 'month' ? (
        <div class="calendar-month-divider" role="row">
          <span>{row.label}</span>
        </div>
      ) : (
        <div class="calendar-week" role="row">
          {row.week.days.map((day) =>
            day === null ? (
              <div class="calendar-cell calendar-cell-pad" role="gridcell" aria-hidden="true"></div>
            ) : (
              <button
                type="button"
                class={[
                  'calendar-cell',
                  'calendar-cell-day',
                  'cell-unset',
                  isWeekend(day) && 'is-weekend',
                  isToday(day) && 'is-today',
                ].filter(Boolean).join(' ')}
                role="gridcell"
                aria-label={`${day} — tap to cycle vote`}
                data-date={day}
                data-state="unset"
              >
                <span class="calendar-cell-day-num">
                  {Number(day.slice(8))}
                </span>
                <span class="calendar-cell-badge" aria-hidden="true"></span>
              </button>
            )
          )}
        </div>
      )
    )}
  </div>

  <div class="calendar-status" aria-live="polite">
    <span class="calendar-legend">
      <span class="calendar-legend-item"><span class="calendar-legend-swatch swatch-yes"></span> Yes</span>
      <span class="calendar-legend-item"><span class="calendar-legend-swatch swatch-maybe"></span> Maybe</span>
      <span class="calendar-legend-item"><span class="calendar-legend-swatch swatch-no"></span> No</span>
    </span>
    <span class="calendar-status-msg" data-calendar-status></span>
  </div>
</section>

<style>
  .calendar-grid {
    margin: 0 0 24px;
    font-family: var(--font-body, 'Space Mono', monospace);
    color: var(--color-on-background);
  }
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    padding: 0 0 8px;
    border-bottom: 2px solid var(--color-on-background);
    margin-bottom: 8px;
  }
  .calendar-weekday {
    font-family: var(--font-label, 'JetBrains Mono', monospace);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
    color: var(--color-on-surface-variant);
  }
  .calendar-weekday.is-weekend {
    color: var(--color-primary);
  }
  .calendar-rows {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .calendar-month-divider {
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--color-surface-container-high);
    border-top: 2px solid var(--color-on-background);
    border-bottom: 2px solid var(--color-on-background);
    padding: 6px 10px;
    margin: 8px 0 4px;
    font-family: var(--font-label, 'JetBrains Mono', monospace);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .calendar-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .calendar-cell {
    aspect-ratio: 1 / 1;
    min-height: 40px;
    border: 2px solid var(--color-outline);
    background: var(--color-surface-container-lowest);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-label, 'JetBrains Mono', monospace);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-on-background);
    cursor: not-allowed;
    padding: 0;
    transition: transform 0.1s ease, background 0.1s ease;
  }
  .calendar-cell-pad {
    visibility: hidden;
    border: none;
    background: transparent;
    min-height: 0;
  }
  .calendar-cell-day-num {
    line-height: 1;
  }
  .calendar-cell.is-weekend {
    background-image: repeating-linear-gradient(
      -45deg,
      var(--color-surface-container-lowest) 0 4px,
      var(--color-surface-container) 4px 8px
    );
  }
  .calendar-cell.is-today {
    border: 2px solid var(--color-primary);
    box-shadow: inset 0 0 0 2px var(--color-primary);
    color: var(--color-primary);
  }
  .calendar-cell[disabled] {
    cursor: not-allowed;
    opacity: 0.85;
  }
  .calendar-cell-day {
    cursor: pointer;
    position: relative;
  }
  .calendar-cell-day:hover:not([disabled]):not(.cell-readonly) {
    transform: translateY(-1px);
  }
  .calendar-cell-day:active:not([disabled]):not(.cell-readonly) {
    transform: translateY(0);
  }
  .calendar-cell-badge {
    position: absolute;
    top: 2px;
    right: 4px;
    font-size: 10px;
    font-weight: 800;
    line-height: 1;
    pointer-events: none;
  }
  /* Vote state visuals — JS toggles cell-yes / cell-maybe / cell-no / cell-unset */
  .cell-yes {
    background: var(--color-primary);
    color: var(--color-on-primary, #fff);
    border-color: var(--color-primary);
  }
  .cell-yes.is-weekend {
    background-image: none;
  }
  .cell-maybe {
    background-image: repeating-linear-gradient(
      -45deg,
      var(--color-surface-container) 0 4px,
      var(--color-surface-container-high) 4px 8px
    );
    color: var(--color-on-background);
    border-color: var(--color-on-background);
  }
  .cell-no {
    background: var(--color-surface-container-lowest);
    color: var(--color-on-surface-variant);
    border-color: var(--color-outline);
    opacity: 0.55;
    text-decoration: line-through;
  }
  .cell-unset {
    background: var(--color-surface-container-lowest);
  }
  /* Post-close overlap badges */
  .cell-perfect .calendar-cell-badge::after { content: '✓'; color: var(--color-primary); }
  .cell-witheffort .calendar-cell-badge::after { content: '~'; color: var(--color-on-surface); }
  .cell-oneshort .calendar-cell-badge::after { content: '·'; color: var(--color-on-surface-variant); }
  .cell-readonly {
    cursor: default;
    pointer-events: none;
  }

  .calendar-status {
    margin: 12px 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px 16px;
    font-family: var(--font-label, 'JetBrains Mono', monospace);
    font-size: 12px;
    color: var(--color-on-surface-variant);
  }
  .calendar-legend {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px 14px;
  }
  .calendar-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .calendar-legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-on-background);
  }
  .swatch-yes { background: var(--color-primary); }
  .swatch-maybe { background-image: repeating-linear-gradient(-45deg, var(--color-surface-container) 0 3px, var(--color-surface-container-high) 3px 6px); }
  .swatch-no { background: var(--color-surface-container-lowest); }
  .calendar-status-msg {
    font-weight: 700;
    color: var(--color-primary);
  }

  /* Desktop polish: wider cells, slightly bigger type. */
  @media (min-width: 640px) {
    .calendar-cell {
      min-height: 56px;
      font-size: 15px;
    }
    .calendar-weekday {
      font-size: 12px;
    }
  }
</style>
