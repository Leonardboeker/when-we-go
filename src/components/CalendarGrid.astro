---
// src/components/CalendarGrid.astro
// Phase 1: visual-only calendar. Weeks as rows, days as cells, Mon-first.
// All cells are disabled <button>s so Phase 2 JS can re-enable them without
// changing the DOM shape. Sticky month-divider rows segment the grid by month.
// Weekend cells get a diagonal stripe pattern. Today gets a primary border.
import {
  enumerateDays,
  groupByWeek,
  isWeekend,
  isToday,
  monthHeader,
  type Week,
} from '../lib/calendar';

interface Props {
  dateRangeStart: string;
  dateRangeEnd: string;
}

const { dateRangeStart, dateRangeEnd } = Astro.props;

const allDays = enumerateDays(dateRangeStart, dateRangeEnd);
const weeks: Week[] = groupByWeek(allDays);

// Walk the weeks and inject a month-divider whenever the first non-null cell
// of a week starts a new calendar month.
type Row =
  | { kind: 'month'; label: string }
  | { kind: 'week'; week: Week };

const rows: Row[] = [];
let lastMonthKey = '';
for (const week of weeks) {
  // Find the first real day in the week (skip nulls).
  const firstReal = week.days.find((d): d is string => d !== null);
  if (firstReal) {
    const monthKey = firstReal.slice(0, 7); // YYYY-MM
    if (monthKey !== lastMonthKey) {
      rows.push({ kind: 'month', label: monthHeader(firstReal) });
      lastMonthKey = monthKey;
    }
  }
  rows.push({ kind: 'week', week });
}

const WEEKDAY_LABELS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
---

<section
  class="calendar-grid"
  aria-label="Date availability grid"
  data-poll-start={dateRangeStart}
  data-poll-end={dateRangeEnd}
>
  <div class="calendar-how-it-works" aria-label="How voting works">
    <span class="how-label">TAP TO VOTE</span>
    <span class="how-sep">—</span>
    <span class="calendar-legend">
      <span class="calendar-legend-item"><span class="calendar-legend-swatch swatch-yes"></span> Yes</span>
      <span class="calendar-legend-item"><span class="calendar-legend-swatch swatch-maybe"></span> Maybe</span>
      <span class="calendar-legend-item"><span class="calendar-legend-swatch swatch-no"></span> No</span>
    </span>
    <span class="how-hint">tap again to unset</span>
  </div>

  <div class="calendar-weekdays" aria-hidden="true">
    {WEEKDAY_LABELS.map((label) => (
      <div class={['calendar-weekday', (label === 'Sat' || label === 'Sun') && 'is-weekend'].filter(Boolean).join(' ')}>
        {label}
      </div>
    ))}
  </div>

  <div class="calendar-rows" role="grid">
    {rows.map((row) =>
      row.kind === 'month' ? (
        <div class="calendar-month-divider" role="row">
          <span>{row.label}</span>
        </div>
      ) : (
        <div class="calendar-week" role="row">
          {row.week.days.map((day) =>
            day === null ? (
              <div class="calendar-cell calendar-cell-pad" role="gridcell" aria-hidden="true"></div>
            ) : (
              <button
                type="button"
                class={[
                  'calendar-cell',
                  'calendar-cell-day',
                  'cell-unset',
                  isWeekend(day) && 'is-weekend',
                  isToday(day) && 'is-today',
                ].filter(Boolean).join(' ')}
                role="gridcell"
                aria-label={`${day} — tap to cycle vote`}
                data-date={day}
                data-state="unset"
              >
                <span class="calendar-cell-day-num">
                  {Number(day.slice(8))}
                </span>
                <span class="calendar-cell-badge" aria-hidden="true"></span>
              </button>
            )
          )}
        </div>
      )
    )}
  </div>

  <div class="calendar-status" aria-live="polite">
    <span class="calendar-status-msg" data-calendar-status></span>
  </div>
</section>

<style>
  .calendar-grid {
    margin: 0 0 24px;
    font-family: var(--font-body, 'Space Mono', monospace);
    color: var(--color-on-background);
  }
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    padding: 0 0 6px;
    border-bottom: 1px solid var(--color-outline-variant, #cbd5e1);
    margin-bottom: 8px;
  }
  .calendar-weekday {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    color: var(--color-on-surface-variant, #475569);
  }
  .calendar-weekday.is-weekend {
    color: var(--color-secondary, #c24b0a);
  }
  .calendar-rows {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .calendar-month-divider {
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--color-background, #f0f4f8);
    border-bottom: 1px solid var(--color-outline-variant, #cbd5e1);
    padding: 8px 0 6px;
    margin: 12px 0 6px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-on-surface-variant, #475569);
  }
  .calendar-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .calendar-cell {
    aspect-ratio: 1 / 1;
    min-height: 40px;
    border: 1.5px solid var(--color-outline-variant);
    border-radius: 8px;
    background: var(--color-surface-container-lowest);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-on-background);
    cursor: not-allowed;
    padding: 0;
    transition: transform 0.12s ease, background 0.12s ease, border-color 0.12s ease;
  }
  .calendar-cell-pad {
    visibility: hidden;
    border: none;
    background: transparent;
    min-height: 0;
  }
  .calendar-cell-day-num {
    line-height: 1;
  }
  /* Weekend = warm sand. No stripes — stripes are reserved for "maybe" state. */
  .calendar-cell.is-weekend {
    background: var(--color-surface-container);
    border-color: var(--color-outline-variant);
  }
  .calendar-cell.is-today {
    border: 2px solid var(--color-secondary, #c24b0a);
    color: var(--color-secondary, #c24b0a);
    font-weight: 800;
  }
  .calendar-cell[disabled] {
    cursor: not-allowed;
    opacity: 0.85;
  }
  .calendar-cell-day {
    cursor: pointer;
    position: relative;
  }
  .calendar-cell-day:hover:not([disabled]):not(.cell-readonly) {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 102, 204, 0.15);
    border-color: var(--color-primary, #0066cc);
  }
  .calendar-cell-day:active:not([disabled]):not(.cell-readonly) {
    transform: translateY(0);
    box-shadow: none;
  }
  .calendar-cell-badge {
    position: absolute;
    top: 2px;
    right: 4px;
    font-size: 10px;
    font-weight: 800;
    line-height: 1;
    pointer-events: none;
  }
  /* ── Vote state visuals — universally readable: green/amber/red ── */

  /* YES — solid green: "I'm available" */
  .cell-yes {
    background: #16a34a;
    color: #fff;
    border-color: #15803d;
    box-shadow: 0 1px 6px rgba(22, 163, 74, 0.35);
    font-weight: 700;
  }

  /* MAYBE — solid amber: "uncertain" */
  .cell-maybe {
    background: #f59e0b;
    color: #1c1917;
    border-color: #d97706;
    box-shadow: 0 1px 6px rgba(245, 158, 11, 0.35);
    font-weight: 700;
  }

  /* NO — desaturated red tint with strikethrough: "can't make it" */
  .cell-no {
    background: #fee2e2;
    color: #9f1239;
    border-color: #fca5a5;
    text-decoration: line-through;
    text-decoration-color: #f87171;
    text-decoration-thickness: 2px;
    opacity: 0.85;
  }

  /* UNSET — clean white */
  .cell-unset {
    background: #ffffff;
  }

  /* Weekend override — voted states take over completely */
  .cell-yes.is-weekend,
  .cell-maybe.is-weekend,
  .cell-no.is-weekend { background-image: none; }
  /* Post-close overlap badges */
  .cell-perfect .calendar-cell-badge::after { content: '✓'; color: var(--color-primary); }
  .cell-witheffort .calendar-cell-badge::after { content: '~'; color: var(--color-on-surface); }
  .cell-oneshort .calendar-cell-badge::after { content: '·'; color: var(--color-on-surface-variant); }
  .cell-readonly {
    cursor: default;
    pointer-events: none;
  }

  /* Feature 1: live-update animation */
  @keyframes cellPulse {
    0% { transform: scale(1.12); }
    100% { transform: scale(1); }
  }
  .cell-updated { animation: cellPulse 0.3s ease-out; }

  /* Feature 2: red dot for dates with a "no" vote */
  .cell-has-no::after {
    content: '';
    position: absolute;
    top: 3px;
    right: 3px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ef4444;
    pointer-events: none;
  }

  /* Feature 7: best-week highlight */
  .cell-best-week {
    box-shadow: inset 0 0 0 2px #16a34a !important;
  }

  /* ── How-it-works bar ── */
  .calendar-how-it-works {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 10px;
    padding: 8px 12px;
    margin-bottom: 10px;
    background: var(--color-surface-container-low, #eef4fb);
    border-radius: var(--radius-sm, 6px);
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 11px;
    color: var(--color-on-surface-variant);
  }
  .how-label {
    font-weight: 700;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-on-background, #0f172a);
  }
  .how-sep {
    color: var(--color-outline-variant, #cbd5e1);
  }
  .how-hint {
    margin-left: auto;
    font-size: 10px;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .calendar-legend {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px 12px;
  }
  .calendar-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-on-background);
  }
  .calendar-legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    border: 1.5px solid transparent;
    flex-shrink: 0;
  }
  .swatch-yes   { background: #16a34a; border-color: #15803d; }
  .swatch-maybe { background: #f59e0b; border-color: #d97706; }
  .swatch-no    { background: #fee2e2; border-color: #fca5a5; }

  /* Feature 7: best-week hint pill */
  :global(.best-week-hint) {
    display: inline-block;
    margin: 8px 0 4px;
    padding: 5px 12px;
    background: #dcfce7;
    color: #166534;
    border-radius: 99px;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 13px;
    font-weight: 600;
  }

  /* ── Status line (bottom) ── */
  .calendar-status {
    margin: 10px 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 16px;
    font-family: var(--font-label, 'JetBrains Mono', monospace);
    font-size: 12px;
    color: var(--color-on-surface-variant);
    min-height: 20px;
  }
  .calendar-status-msg {
    font-weight: 700;
    color: var(--color-primary);
  }

  @media (min-width: 640px) {
    .calendar-cell {
      min-height: 52px;
      font-size: 15px;
      border-radius: 10px;
    }
    .calendar-weekday { font-size: 12px; }
  }
</style>

<script>
  // Feature 6: Swipe navigation between months
  const calGrid = document.querySelector('.calendar-grid');
  if (calGrid) {
    let touchStartX = 0;
    calGrid.addEventListener('touchstart', (e) => {
      touchStartX = (e as TouchEvent).touches[0].clientX;
    }, { passive: true });
    calGrid.addEventListener('touchend', (e) => {
      const delta = (e as TouchEvent).changedTouches[0].clientX - touchStartX;
      const dividers = document.querySelectorAll('.calendar-month-divider');
      const visible = [...dividers].find((d) => d.getBoundingClientRect().top > 0);
      if (Math.abs(delta) > 50 && visible) {
        const idx = [...dividers].indexOf(visible as Element);
        const target = delta < 0 ? dividers[idx + 1] : dividers[Math.max(0, idx - 1)];
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
</script>
