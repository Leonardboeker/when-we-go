---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nicht gefunden — when-we-go">
  <main class="not-found">
    <div class="not-found-card">
      <p class="not-found-emoji" aria-hidden="true">🧭</p>
      <h1 class="not-found-code">404</h1>
      <p class="not-found-lead">Hier ist nichts.</p>
      <p class="not-found-sub">
        Öffne den persönlichen Link, den du bekommen hast — oder frag die Person,
        die die Reise plant, nochmal danach.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    max-width: 480px;
    margin: 0 auto;
    padding: 48px 16px;
  }
  .not-found-card {
    background: var(--color-surface-container-lowest, #fff);
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 2px 12px rgba(15, 23, 42, 0.08), 0 1px 3px rgba(15, 23, 42, 0.06);
    padding: 40px 28px;
    text-align: center;
  }
  .not-found-emoji {
    font-size: 40px;
    margin: 0 0 8px;
  }
  .not-found-code {
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: clamp(48px, 16vw, 80px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
    color: var(--color-primary, #0066cc);
  }
  .not-found-lead {
    font-family: var(--font-headline, 'Bricolage Grotesque', sans-serif);
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--color-on-background, #0f172a);
  }
  .not-found-sub {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-on-surface-variant, #475569);
    margin: 0;
  }
</style>
