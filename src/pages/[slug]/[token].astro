---
// src/pages/[slug]/[token].astro
// Per-participant page. Phase 2: tap-to-vote calendar grid with debounced
// API persistence, post-close read-only view + overlap badges.
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { polls, type Poll, type Participant } from '../../data/polls';
import PollHeader from '../../components/PollHeader.astro';
import CalendarGrid from '../../components/CalendarGrid.astro';
import ProfileForm from '../../components/ProfileForm.astro';
import EmailButtons from '../../components/EmailButtons.astro';
import FlightOptions from '../../components/FlightOptions.astro';
import HotelShortlist from '../../components/HotelShortlist.astro';
import ActivitiesList from '../../components/ActivitiesList.astro';
import BottomNav from '../../components/BottomNav.astro';
import Onboarding from '../../components/Onboarding.astro';
import { buildICalDownloadUrl } from '../../lib/calendar-links';

export const prerender = true;

export const getStaticPaths = (() => {
  const paths: Array<{
    params: { slug: string; token: string };
    props: { poll: Poll; participant: Participant };
  }> = [];
  for (const poll of polls) {
    for (const participant of poll.participants) {
      paths.push({
        params: { slug: poll.slug, token: participant.token },
        props: { poll, participant },
      });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { poll, participant } = Astro.props as {
  poll: Poll;
  participant: Participant;
};

// Cross-poll isolation: only this poll's data is in scope. Other polls are
// not imported or referenced below. (verify-isolation.mjs enforces this.)
const title = `Hey ${participant.name} — when can you ${poll.destination ? `come to ${poll.destination}` : 'join'}?`;

// API base URL. Override via WHENWEGO_PUBLIC_API_BASE (build env). Defaults to
// same-origin (empty string) so the deployed Worker route handles /api/* paths.
const publicApiBase =
  (import.meta.env.WHENWEGO_PUBLIC_API_BASE as string | undefined) ?? '';

// Phase 8: absolute site URL for building add-to-calendar links. The
// `WHENWEGO_PUBLIC_SITE_URL` build env wins; falls back to PUBLIC_SITE_URL
// (the existing Astro convention), then localhost for dev. Trailing slash
// stripped so we can concatenate paths cleanly.
const publicSiteUrl = (
  (import.meta.env.WHENWEGO_PUBLIC_SITE_URL as string | undefined) ??
  (import.meta.env.PUBLIC_SITE_URL as string | undefined) ??
  'http://localhost:4321'
).replace(/\/$/, '');

// Pre-build the .ics download URL at SSR time — it's the only add-to-calendar
// URL that doesn't depend on the overlap, so it's safe to bake in.
const icalDownloadUrl = buildICalDownloadUrl({
  siteUrl: publicSiteUrl,
  slug: poll.slug,
});
---

<BaseLayout
  title={title}
  ogImage={`/og/${poll.slug}.png`}
  ogDescription={`${poll.title} — pick the days you can come. Poll closes ${poll.pollCloseAt.slice(0, 10)}.`}
>
  <main class="page-wrapper">
    {/* Visually hidden h1 for screen readers — PollHeader provides the visual heading. */}
    <h1 class="sr-only">Hey {participant.name} — pick your dates for {poll.title}</h1>

    <PollHeader
      participantName={participant.name}
      title={poll.title}
      destination={poll.destination}
      pollCloseAt={poll.pollCloseAt}
    />

    {/* Feature 9: Share buttons */}
    <div class="share-buttons">
      <span class="share-label">Teilen:</span>
      <a
        class="share-btn share-btn-whatsapp"
        href={`https://wa.me/?text=${encodeURIComponent(`Hey! Wann hast du Zeit für ${poll.destination ?? poll.title}? Abstimm hier: ${publicSiteUrl}/${poll.slug}/${participant.token}`)}`}
        target="_blank"
        rel="noopener noreferrer"
      >WhatsApp</a>
      <a
        class="share-btn share-btn-telegram"
        href={`https://t.me/share/url?url=${encodeURIComponent(`${publicSiteUrl}/${poll.slug}/${participant.token}`)}&text=${encodeURIComponent(`Hey! Wann hast du Zeit für ${poll.destination ?? poll.title}?`)}`}
        target="_blank"
        rel="noopener noreferrer"
      >Telegram</a>
    </div>

    {/* ── Section: Dates (default tab) ─────────────────────────────── */}
    <div class="page-section" data-section="dates">
      {/* Post-close summary banner */}
      <div id="poll-summary-banner" class="poll-summary-banner" hidden>
        <span data-summary-text></span>
      </div>
      {/* Phase 8: add-to-calendar buttons */}
      <EmailButtons />
      {/* Phase 4: profile gate */}
      <div id="profile-gate" hidden>
        <ProfileForm />
      </div>
      <div id="calendar-gate" hidden>
        <CalendarGrid
          dateRangeStart={poll.dateRangeStart}
          dateRangeEnd={poll.dateRangeEnd}
        />
      </div>
    </div>

    {/* ── Section: Trip (post-close results) ────────────────────────── */}
    <div class="page-section" data-section="trip" hidden>
      {/* Feature 5: closed-state banner — shown when the poll has ended. */}
      <div id="trip-closed-banner" class="trip-closed-banner" hidden>
        <span class="trip-closed-icon" aria-hidden="true">✅</span>
        <span id="trip-closed-text">Die Abstimmung ist beendet — hier sind die Ergebnisse.</span>
      </div>
      <p class="trip-preclose-hint" id="trip-pre-close-msg" hidden>
        ✈️ Trip details appear here once the poll closes.
      </p>
      <FlightOptions />
      <HotelShortlist mode="participant" />
      <ActivitiesList />
    </div>

    {/* ── Section: Profile ─────────────────────────────────────────── */}
    <div class="page-section" data-section="profile" hidden>
      <div class="profile-tab-header">
        <h2 class="profile-tab-title">Your profile</h2>
        <p class="profile-tab-hint">Used for personalised flight suggestions and email reminders.</p>
      </div>
      <ProfileForm />
    </div>

    <div id="vote-toast" class="vote-toast" role="status" aria-live="polite" hidden></div>
  </main>

  <BottomNav />

  {/* Feature 4: first-visit onboarding sheet (shows once per device) */}
  <Onboarding />

  <script
    is:inline
    define:vars={{
      slug: poll.slug,
      token: participant.token,
      apiBase: publicApiBase,
      dateRangeStartIn: poll.dateRangeStart,
      dateRangeEndIn: poll.dateRangeEnd,
      pollTitle: poll.title,
      pollDestination: poll.destination ?? poll.title,
      icalDownloadUrl,
    }}
  >
  (function () {
    'use strict';
    const STATES = ['unset', 'yes', 'maybe', 'no'];
    const CLASS_PREFIX = 'cell-';
    const OVERLAP_CLASSES = ['cell-perfect', 'cell-witheffort', 'cell-oneshort'];
    const DEBOUNCE_MS = 500;

    /** @type {Record<string, 'unset'|'yes'|'maybe'|'no'>} */
    const voteState = Object.create(null);
    /** Last known server vote state for change detection (live updates) */
    const serverVoteSnapshot = Object.create(null);
    let closed = false;
    let saveTimer = null;
    let pollInterval = null;
    /** @type {AbortController | null} */
    let inflightAbort = null;

    const grid = document.querySelector('.calendar-grid');
    const statusEl = document.querySelector('[data-calendar-status]');
    const summaryBanner = document.getElementById('poll-summary-banner');
    const summaryTextEl = summaryBanner
      ? summaryBanner.querySelector('[data-summary-text]')
      : null;
    const toastEl = document.getElementById('vote-toast');
    const profileGate = document.getElementById('profile-gate');
    const calendarGate = document.getElementById('calendar-gate');
    const profileFormEl = document.getElementById('profile-form-element');
    const profileStatusEl = document.querySelector('[data-profile-status]');
    const profileSubmitBtn = document.querySelector('[data-profile-submit]');

    if (!grid) return;

    function isProfileComplete(p) {
      return Boolean(p && p.email && p.homeAirport);
    }

    function showCalendar() {
      if (profileGate) profileGate.hidden = true;
      if (calendarGate) calendarGate.hidden = false;
    }
    function showProfileForm() {
      if (profileGate) profileGate.hidden = false;
      if (calendarGate) calendarGate.hidden = true;
    }

    function setProfileStatus(msg, kind) {
      if (!profileStatusEl) return;
      profileStatusEl.textContent = msg || '';
      if (kind) profileStatusEl.dataset.kind = kind;
      else delete profileStatusEl.dataset.kind;
    }

    function buildProfilePayload() {
      if (!profileFormEl) return null;
      const fd = new FormData(profileFormEl);
      const email = (fd.get('email') || '').toString().trim();
      const homeAirport = (fd.get('homeAirport') || '').toString().trim().toUpperCase();
      const homeCity = (fd.get('homeCity') || '').toString().trim();
      const budgetRaw = (fd.get('budgetMaxEur') || '').toString();
      const interests = fd.getAll('interests').map((v) => v.toString());

      const payload = {};
      if (email) payload.email = email;
      if (homeAirport) payload.homeAirport = homeAirport;
      if (homeCity) payload.homeCity = homeCity;
      if (budgetRaw) {
        const n = parseInt(budgetRaw, 10);
        if (!isNaN(n) && n > 0) payload.budgetMaxEur = n;
      }
      if (interests.length > 0) payload.interests = interests;
      return payload;
    }

    function validateProfileClientSide(p) {
      const errors = {};
      if (!p.email) errors.email = 'Please enter your email.';
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(p.email))
        errors.email = 'That email looks invalid.';
      if (!p.homeAirport) errors.homeAirport = 'Pick your home airport.';
      else if (!/^[A-Z]{3}$/.test(p.homeAirport))
        errors.homeAirport = 'Airport must be a 3-letter IATA code.';
      return errors;
    }

    function setFieldError(name, msg) {
      const el = document.querySelector(
        '[data-error-for="' + name + '"]'
      );
      if (!el) return;
      if (msg) {
        el.textContent = msg;
        el.hidden = false;
      } else {
        el.textContent = '';
        el.hidden = true;
      }
    }

    async function submitProfile(e) {
      if (e) e.preventDefault();
      const payload = buildProfilePayload();
      if (!payload) return;
      setFieldError('email', '');
      setFieldError('homeAirport', '');
      const errors = validateProfileClientSide(payload);
      if (Object.keys(errors).length > 0) {
        for (const k of Object.keys(errors)) setFieldError(k, errors[k]);
        setProfileStatus('Please fix the errors above.', 'err');
        return;
      }
      if (profileSubmitBtn) profileSubmitBtn.disabled = true;
      setProfileStatus('Saving…', '');
      try {
        const res = await fetch(apiBase + '/api/profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, token, profile: payload }),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'HTTP ' + res.status);
        }
        const j = await res.json();
        setProfileStatus('Saved.', '');
        if (j.profileComplete) {
          showCalendar();
          // Refresh server state so the grid initialises with current votes.
          refreshState();
        }
      } catch (err) {
        setProfileStatus(
          'Save failed: ' + (err && err.message ? err.message : 'unknown'),
          'err'
        );
      } finally {
        if (profileSubmitBtn) profileSubmitBtn.disabled = false;
      }
    }

    if (profileFormEl) {
      profileFormEl.addEventListener('submit', submitProfile);
    }

    /** @param {string} msg @param {'saving'|'saved'|'error'|''} [kind] */
    function setStatus(msg, kind) {
      if (!statusEl) return;
      statusEl.textContent = msg;
      if (kind) statusEl.dataset.kind = kind;
      else delete statusEl.dataset.kind;
    }

    /** @param {string} msg @param {'ok'|'err'} kind */
    function showToast(msg, kind) {
      if (!toastEl) return;
      toastEl.textContent = msg;
      toastEl.dataset.kind = kind;
      toastEl.hidden = false;
      setTimeout(() => {
        toastEl.hidden = true;
      }, 2400);
    }

    /** @param {HTMLButtonElement} cell @param {string} state @param {boolean} [animate] */
    function applyCellClass(cell, state, animate) {
      for (const s of STATES) cell.classList.remove(CLASS_PREFIX + s);
      cell.classList.add(CLASS_PREFIX + state);
      cell.dataset.state = state;
      // Feature 9: screen-reader-friendly label with current vote in German.
      const STATE_DE = { unset: 'noch offen', yes: 'Ja', maybe: 'Vielleicht', no: 'Nein' };
      cell.setAttribute(
        'aria-label',
        cell.dataset.date + ', Stimme: ' + (STATE_DE[state] || state)
      );
      cell.setAttribute('aria-pressed', state !== 'unset' ? 'true' : 'false');
      if (animate) {
        cell.classList.remove('cell-updated');
        // Force reflow to restart animation
        void cell.offsetWidth;
        cell.classList.add('cell-updated');
      }
    }

    /** @param {HTMLButtonElement} cell @param {string|null} tier */
    function applyOverlapBadge(cell, tier) {
      for (const c of OVERLAP_CLASSES) cell.classList.remove(c);
      if (tier === 'perfect') cell.classList.add('cell-perfect');
      else if (tier === 'withEffort') cell.classList.add('cell-witheffort');
      else if (tier === 'oneShort') cell.classList.add('cell-oneshort');
    }

    function markReadOnly() {
      const cells = grid.querySelectorAll('.calendar-cell-day');
      cells.forEach((c) => {
        c.classList.add('cell-readonly');
        c.setAttribute('aria-disabled', 'true');
      });
    }

    /** @param {string} d */
    function nextState(d) {
      const cur = voteState[d] || 'unset';
      const idx = STATES.indexOf(cur);
      return STATES[(idx + 1) % STATES.length];
    }

    function scheduleSave() {
      if (saveTimer) clearTimeout(saveTimer);
      setStatus('Speichert…', 'saving');
      saveTimer = setTimeout(persistVotes, DEBOUNCE_MS);
    }

    async function persistVotes() {
      saveTimer = null;
      // Build payload from current state (only non-unset entries; bulk replace).
      const votes = Object.keys(voteState)
        .filter((d) => voteState[d] !== 'unset')
        .map((d) => ({ date: d, state: voteState[d] }));

      if (inflightAbort) inflightAbort.abort();
      inflightAbort = new AbortController();

      try {
        const res = await fetch(apiBase + '/api/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, token, votes }),
          signal: inflightAbort.signal,
        });
        if (res.status === 410) {
          closed = true;
          setStatus('poll closed');
          markReadOnly();
          showToast('Poll closed', 'err');
          await refreshState();
          return;
        }
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'HTTP ' + res.status);
        }
        setStatus('Gespeichert ✓', 'saved');
        setTimeout(() => setStatus('', ''), 1800);
      } catch (err) {
        if (err && err.name === 'AbortError') return;
        setStatus('Nicht gespeichert — nochmal tippen', 'error');
        showToast(
          'Save failed: ' + (err && err.message ? err.message : 'unknown'),
          'err'
        );
      }
    }

    /** @param {string} date */
    function onCellTap(date) {
      if (closed) return;
      const cell = grid.querySelector(
        '.calendar-cell-day[data-date="' + date + '"]'
      );
      if (!cell) return;
      const ns = nextState(date);
      voteState[date] = ns;
      applyCellClass(cell, ns);
      scheduleSave();
    }

    grid.addEventListener('click', (e) => {
      const target = e.target;
      const cell = target && target.closest
        ? target.closest('.calendar-cell-day')
        : null;
      if (!cell) return;
      if (cell.classList.contains('cell-readonly')) return;
      const d = cell.dataset.date;
      if (!d) return;
      onCellTap(d);
    });

    // ── Feature 9: keyboard navigation (roving tabindex arrow-key grid) ──
    // Cells are <button>s, so Enter/Space already toggle via the click handler.
    // This adds Arrow/Home/End focus movement: ±1 = prev/next day, ±7 = same
    // weekday adjacent week (the flat chronological list is exactly weekday-
    // aligned at ±7). One cell holds tabindex=0 at a time so Tab lands once.
    const cellList = Array.prototype.slice.call(
      grid.querySelectorAll('.calendar-cell-day')
    );
    cellList.forEach((c, i) => {
      c.setAttribute('tabindex', i === 0 ? '0' : '-1');
      c.setAttribute('role', 'gridcell');
    });
    function focusCell(idx) {
      if (idx < 0 || idx >= cellList.length) return;
      cellList.forEach((c) => c.setAttribute('tabindex', '-1'));
      const target = cellList[idx];
      target.setAttribute('tabindex', '0');
      target.focus();
    }
    grid.addEventListener('keydown', (e) => {
      const cell = e.target && e.target.closest
        ? e.target.closest('.calendar-cell-day')
        : null;
      if (!cell) return;
      const i = cellList.indexOf(cell);
      if (i === -1) return;
      let next = -1;
      switch (e.key) {
        case 'ArrowRight': next = i + 1; break;
        case 'ArrowLeft': next = i - 1; break;
        case 'ArrowDown': next = i + 7; break;
        case 'ArrowUp': next = i - 7; break;
        case 'Home': next = 0; break;
        case 'End': next = cellList.length - 1; break;
        default: return;
      }
      e.preventDefault();
      // Clamp ±7 moves that overshoot to the nearest end so focus never lost.
      if (next < 0) next = (e.key === 'ArrowUp') ? i : 0;
      if (next >= cellList.length) next = (e.key === 'ArrowDown') ? i : cellList.length - 1;
      focusCell(next);
    });

    /**
     * Initialise cell visuals from server response. Also applies overlap badges
     * when the poll is closed.
     * @param {{votes:Array<{date:string,state:string}>,closed:boolean,overlap:any,viewer?:{profile:any}}} data
     */
    function applyServerState(data) {
      closed = !!data.closed;

      // Phase 4 gating: profile complete → calendar visible; otherwise show form.
      // The form pre-fills from any partial profile so returning users see their
      // last input.
      const profile = data && data.viewer && data.viewer.profile;
      if (isProfileComplete(profile)) {
        showCalendar();
      } else {
        // Pre-populate inputs with whatever profile state exists.
        if (profile) {
          const emailEl = document.getElementById('profile-email');
          const airportEl = document.getElementById('profile-airport');
          const cityEl = document.getElementById('profile-airport-city');
          if (emailEl && profile.email) emailEl.value = profile.email;
          if (airportEl && profile.homeAirport) airportEl.value = profile.homeAirport;
          if (cityEl && profile.homeCity) cityEl.value = profile.homeCity;
        }
        showProfileForm();
        // No further state work needed — user must complete profile first.
        return;
      }

      for (const v of data.votes || []) {
        const prev = serverVoteSnapshot[v.date];
        const changed = prev !== undefined && prev !== v.state && voteState[v.date] === prev;
        voteState[v.date] = v.state;
        serverVoteSnapshot[v.date] = v.state;
        const cell = grid.querySelector(
          '.calendar-cell-day[data-date="' + v.date + '"]'
        );
        if (cell) applyCellClass(cell, v.state, changed);
      }
      if (closed) {
        markReadOnly();
        const overlap = data.overlap;
        if (overlap && overlap.perDate) {
          const perfect = new Set(overlap.perfect || []);
          const withEffort = new Set(overlap.withEffort || []);
          const oneShort = new Set(overlap.oneShort || []);
          const cells = grid.querySelectorAll('.calendar-cell-day');
          cells.forEach((cell) => {
            const d = cell.dataset.date;
            if (!d) return;
            if (perfect.has(d)) applyOverlapBadge(cell, 'perfect');
            else if (withEffort.has(d)) applyOverlapBadge(cell, 'withEffort');
            else if (oneShort.has(d)) applyOverlapBadge(cell, 'oneShort');
          });
          renderSummaryBanner(overlap);
          renderAddToCalendarButtons(overlap);
        }
        // Feature 2: add red dot for any date with at least one "no" vote
        if (data.overlap && data.overlap.perDate) {
          const perDate = data.overlap.perDate;
          const allCells = grid.querySelectorAll('.calendar-cell-day');
          allCells.forEach((cell) => {
            const d = cell.dataset.date;
            if (!d || !perDate[d]) return;
            const hasNo = Object.values(perDate[d]).some((s) => s === 'no');
            if (hasNo) cell.classList.add('cell-has-no');
          });
        }
        setStatus('Abstimmung beendet', '');
        // Feature 5: closed-state banner on the Trip tab + hide pre-close hint.
        const closedBanner = document.getElementById('trip-closed-banner');
        const closedText = document.getElementById('trip-closed-text');
        const preCloseMsg = document.getElementById('trip-pre-close-msg');
        if (preCloseMsg) preCloseMsg.hidden = true;
        if (closedBanner) {
          const ranges = (data.overlap && data.overlap.ranges) || [];
          const best = ranges.find((r) => r.tier === 'perfect') ||
            ranges.find((r) => r.tier === 'withEffort') || null;
          if (closedText && best) {
            closedText.textContent = 'Abstimmung beendet · Beste Daten: ' +
              best.start + ' → ' + best.end + ' (' + best.length + ' Tage)';
          }
          closedBanner.hidden = false;
        }
        // Phase 5-7: load trip content (non-blocking).
        loadFlights(false);
        loadHotels();
        loadActivities();
        // Auto-switch to Trip tab and show notification badge.
        if (typeof window.__switchToTripTab === 'function') {
          window.__switchToTripTab(true);
        }
      } else {
        // Feature 7: Best week highlight (only when poll is open)
        highlightBestWeek();
      }

      // Feature 8: participant progress indicator
      renderParticipantProgress(data);
    }

    /** Feature 7: find the Mon-Sun week with the most "yes" votes and highlight it */
    function highlightBestWeek() {
      // Clear previous highlights
      grid.querySelectorAll('.cell-best-week').forEach((c) => c.classList.remove('cell-best-week'));

      const yesDates = Object.keys(voteState).filter((d) => voteState[d] === 'yes');
      if (yesDates.length < 3) return;

      // Group yes-dates by week (Mon-Sun)
      const weekCounts = new Map();
      const weekDates = new Map();
      for (const d of yesDates) {
        const dt = new Date(d + 'T00:00:00Z');
        const dow = (dt.getUTCDay() + 6) % 7; // 0=Mon, 6=Sun
        const monday = new Date(dt);
        monday.setUTCDate(dt.getUTCDate() - dow);
        const key = monday.toISOString().slice(0, 10);
        weekCounts.set(key, (weekCounts.get(key) || 0) + 1);
        if (!weekDates.has(key)) weekDates.set(key, []);
        weekDates.get(key).push(d);
      }

      let bestKey = null;
      let bestCount = 0;
      for (const [k, count] of weekCounts) {
        if (count > bestCount) { bestCount = count; bestKey = k; }
      }

      if (!bestKey || bestCount < 4) return;

      const bestDatesSet = new Set(weekDates.get(bestKey));
      grid.querySelectorAll('.calendar-cell-day').forEach((cell) => {
        if (bestDatesSet.has(cell.dataset.date)) cell.classList.add('cell-best-week');
      });

      // Show hint text
      const existing = document.getElementById('best-week-hint');
      if (existing) existing.remove();
      const dates = [...bestDatesSet].sort();
      if (dates.length > 0) {
        const hint = document.createElement('p');
        hint.id = 'best-week-hint';
        hint.className = 'best-week-hint';
        hint.textContent = '📅 Dein Top-Termin: ' + dates[0] + ' → ' + dates[dates.length - 1];
        const calStatus = grid.querySelector('.calendar-status');
        if (calStatus) grid.insertBefore(hint, calStatus);
        else grid.appendChild(hint);
      }
    }

    /** Feature 8: show participant vote progress */
    function renderParticipantProgress(data) {
      const progressEl = document.getElementById('participant-progress');
      if (!progressEl) return;
      // Use voterStatus if available (from /api/poll history). Fall back to
      // the poll.participantCount + viewer.voteCount we always have.
      const voterStatus = data.voterStatus || null;
      if (voterStatus && Array.isArray(voterStatus)) {
        const total = voterStatus.length;
        const voted = voterStatus.filter((v) => v.voteCount > 0).length;
        progressEl.textContent = voted + ' von ' + total + ' haben abgestimmt';
        progressEl.hidden = false;
      } else if (data.poll && data.poll.participantCount) {
        // Minimal fallback: we know the viewer's vote count from data.viewer
        const total = data.poll.participantCount;
        const viewerVoted = data.viewer && data.viewer.voteCount > 0 ? 1 : 0;
        progressEl.textContent = viewerVoted + ' von ' + total + ' haben abgestimmt (min.)';
        progressEl.hidden = false;
      }
    }

    // ─── Phase 5: flight options ─────────────────────────────────────────
    const flightSection = document.getElementById('flight-options');
    const flightSkeleton = flightSection
      ? flightSection.querySelector('[data-flights-skeleton]')
      : null;
    const flightRefreshBtn = flightSection
      ? flightSection.querySelector('[data-flights-refresh]')
      : null;
    const flightListEl = flightSection
      ? flightSection.querySelector('[data-flights-list]')
      : null;
    const flightRestEl = flightSection
      ? flightSection.querySelector('[data-flights-rest]')
      : null;
    const flightMoreEl = flightSection
      ? flightSection.querySelector('[data-flights-more]')
      : null;
    const flightStateEl = flightSection
      ? flightSection.querySelector('[data-flights-state]')
      : null;
    const flightStateText = flightSection
      ? flightSection.querySelector('[data-flights-state-text]')
      : null;
    const flightGoogleLink = flightSection
      ? flightSection.querySelector('[data-flights-google-link]')
      : null;
    const flightMetaEl = flightSection
      ? flightSection.querySelector('[data-flights-meta]')
      : null;
    const flightDemoBanner = flightSection
      ? flightSection.querySelector('[data-flights-demo-banner]')
      : null;

    function formatDurationMin(mins) {
      if (!mins || mins <= 0) return '';
      const h = Math.floor(mins / 60);
      const m = mins % 60;
      if (h === 0) return m + 'm';
      if (m === 0) return h + 'h';
      return h + 'h ' + m + 'm';
    }

    function fmtFlightTime(iso) {
      if (!iso) return '';
      // Amadeus 'local' string e.g. '2026-07-12T07:30:00' — slice the time part.
      const t = iso.split('T')[1];
      if (!t) return '';
      return t.slice(0, 5);
    }

    function renderFlightCard(f, isCheapest) {
      const li = document.createElement('li');
      li.className = 'flight-card' + (isCheapest ? ' is-cheapest' : '');
      const main = document.createElement('div');
      main.className = 'flight-card-main';
      const airlineStrong = document.createElement('strong');
      airlineStrong.textContent = f.airline + (f.carrierCode ? ' (' + f.carrierCode + ')' : '');
      main.appendChild(airlineStrong);
      const meta = document.createElement('div');
      meta.className = 'flight-card-meta';
      const stopsTxt = f.stops === 0 ? 'Direct' : f.stops + ' stop' + (f.stops > 1 ? 's' : '');
      const durTxt = formatDurationMin(f.durationMinTotal);
      const timeTxt = f.departureTimeLocal && f.arrivalTimeLocal
        ? fmtFlightTime(f.departureTimeLocal) + ' → ' + fmtFlightTime(f.arrivalTimeLocal) : '';
      meta.textContent = [timeTxt, durTxt, stopsTxt].filter(Boolean).join(' · ');
      main.appendChild(meta);
      li.appendChild(main);

      const right = document.createElement('div');
      right.style.cssText = 'text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:4px';
      const price = document.createElement('div');
      price.className = 'flight-card-price';
      price.textContent = '€' + Math.round(f.priceEur);
      right.appendChild(price);
      // Book link — either Google Flights or pre-built URL
      const bookLink = document.createElement('a');
      bookLink.className = 'flight-card-book';
      bookLink.textContent = 'Buchen →';
      bookLink.target = '_blank';
      bookLink.rel = 'noopener noreferrer';
      const origin = (f.origin && f.origin.iata) ? f.origin.iata : '';
      const dest = (window._flightDestIata) ? window._flightDestIata : '';
      const depDate = (f.departureTimeLocal) ? f.departureTimeLocal.slice(0,10) : '';
      bookLink.href = 'https://www.google.com/travel/flights?q=' + encodeURIComponent('Flights ' + origin + ' to ' + dest + (depDate ? ' ' + depDate : ''));
      right.appendChild(bookLink);
      li.appendChild(right);
      return li;
    }

    function buildGoogleFlightsUrl(originIata, destIata, depart, ret) {
      const q =
        'Flights from ' +
        originIata +
        ' to ' +
        destIata +
        (depart ? ' on ' + depart : '') +
        (ret ? ' returning ' + ret : '');
      return 'https://www.google.com/travel/flights?q=' + encodeURIComponent(q);
    }

    function reasonMessage(reason) {
      switch (reason) {
        case 'not_configured':
          return 'Flight suggestions not configured — ask your organiser to set up a provider.';
        case 'profile_incomplete':
          return 'Complete your profile (home airport) to see flight suggestions.';
        case 'destination_unmapped':
          return "We couldn't map this destination to an airport — try Google Flights.";
        case 'no_routes':
          return 'No flights found for this date pair — try Google Flights for alternatives.';
        case 'api_down':
        case 'provider_error':
          return 'Flight search is temporarily unavailable — please refresh in a few minutes.';
        default:
          return '';
      }
    }

    function renderFlights(data) {
      if (!flightSection) return;
      flightSection.hidden = false;
      // Always show "Refresh prices" once we've loaded once (even on errors).
      if (flightRefreshBtn) flightRefreshBtn.disabled = false;

      const flights = (data && data.flights) || [];
      const reason = data && data.reason;
      const origin = data && data.origin;
      const destination = data && data.destination;
      const dateRange = data && data.dateRange;
      const provider = data && data.provider;

      // Phase 5: DEMO banner when provider is mock (isReal === false).
      if (flightDemoBanner) {
        flightDemoBanner.hidden = !(provider && provider.isReal === false);
      }

      // Meta line (origin → destination, dates).
      if (flightMetaEl && origin && destination && origin.iata && destination.iata) {
        flightMetaEl.textContent =
          origin.iata +
          ' → ' +
          destination.iata +
          (dateRange && dateRange.start
            ? ' · ' + dateRange.start + ' to ' + dateRange.end
            : '');
        flightMetaEl.hidden = false;
      }

      // Clear previous render.
      if (flightListEl) {
        flightListEl.innerHTML = '';
        flightListEl.hidden = true;
      }
      if (flightRestEl) flightRestEl.innerHTML = '';
      if (flightMoreEl) flightMoreEl.hidden = true;
      if (flightStateEl) flightStateEl.hidden = true;
      if (flightGoogleLink) flightGoogleLink.hidden = true;

      if (reason !== 'ok' || flights.length === 0) {
        if (flightStateEl && flightStateText) {
          flightStateText.textContent = reasonMessage(reason || 'no_routes');
          flightStateEl.hidden = false;
          // Show Google Flights fallback for the cases where it's actionable.
          if (
            origin && destination && origin.iata && destination.iata &&
            (reason === 'no_routes' || reason === 'destination_unmapped' || reason === 'api_down')
          ) {
            if (flightGoogleLink) {
              flightGoogleLink.href = buildGoogleFlightsUrl(
                origin.iata,
                destination.iata,
                dateRange && dateRange.start,
                dateRange && dateRange.end
              );
              flightGoogleLink.hidden = false;
            }
          }
        }
        return;
      }

      // Render up to 3 cheapest, rest goes into the collapsible.
      const top = flights.slice(0, 3);
      const rest = flights.slice(3);
      if (flightListEl) {
        for (let i = 0; i < top.length; i++) {
          flightListEl.appendChild(renderFlightCard(top[i], i === 0));
        }
        flightListEl.hidden = false;
      }
      if (rest.length > 0 && flightRestEl && flightMoreEl) {
        for (const f of rest) flightRestEl.appendChild(renderFlightCard(f, false));
        flightMoreEl.hidden = false;
      }
    }

    async function loadFlights(forceRefresh) {
      if (!flightSection) return;
      flightSection.hidden = false;
      // Feature 2: show skeleton while loading (hide stale list/state).
      if (flightSkeleton) flightSkeleton.hidden = false;
      if (flightListEl) flightListEl.hidden = true;
      if (flightStateEl) flightStateEl.hidden = true;
      if (flightRefreshBtn) {
        flightRefreshBtn.disabled = true;
        flightRefreshBtn.textContent = forceRefresh ? 'Refreshing…' : 'Loading…';
      }
      try {
        const url =
          apiBase +
          (forceRefresh ? '/api/flights/refresh' : '/api/flights') +
          '?slug=' +
          encodeURIComponent(slug) +
          '&token=' +
          encodeURIComponent(token);
        const opts = forceRefresh
          ? { method: 'POST', headers: { 'Content-Type': 'application/json' } }
          : { headers: { Accept: 'application/json' } };
        const res = await fetch(url, opts);
        if (res.status === 429) {
          // Rate-limited refresh — surface gently.
          showToast('Refresh available again in ~1 hour', 'err');
          if (flightRefreshBtn) {
            flightRefreshBtn.textContent = 'Refresh prices';
            flightRefreshBtn.disabled = false;
          }
          return;
        }
        if (!res.ok) {
          throw new Error('HTTP ' + res.status);
        }
        const data = await res.json();
        renderFlights(data);
      } catch (err) {
        if (flightStateEl && flightStateText) {
          flightStateText.textContent =
            'Could not load flights right now — try refreshing the page.';
          flightStateEl.hidden = false;
        }
      } finally {
        if (flightSkeleton) flightSkeleton.hidden = true;
        if (flightRefreshBtn) {
          flightRefreshBtn.textContent = 'Refresh prices';
          flightRefreshBtn.disabled = false;
        }
      }
    }

    if (flightRefreshBtn) {
      flightRefreshBtn.addEventListener('click', () => loadFlights(true));
    }

    // ─── Phase 6: hotel shortlist (shared list) ──────────────────────────
    const hotelSection = document.getElementById('hotel-shortlist');
    const hotelSkeleton = hotelSection
      ? hotelSection.querySelector('[data-hotels-skeleton]')
      : null;
    const hotelListEl = hotelSection
      ? hotelSection.querySelector('[data-hotels-list]')
      : null;
    const hotelStateEl = hotelSection
      ? hotelSection.querySelector('[data-hotels-state]')
      : null;
    const hotelStateText = hotelSection
      ? hotelSection.querySelector('[data-hotels-state-text]')
      : null;
    const hotelDemoBanner = hotelSection
      ? hotelSection.querySelector('[data-hotels-demo-banner]')
      : null;
    const hotelMetaEl = hotelSection
      ? hotelSection.querySelector('[data-hotels-meta]')
      : null;
    let myVotedHotelId = null;

    function hotelReasonMessage(reason) {
      switch (reason) {
        case 'destination_unmapped':
          return "We couldn't map this destination to a city — try Booking.com directly.";
        case 'no_inventory':
          return 'No hotels available for these dates — try adjacent days on Booking.com.';
        case 'provider_error':
          return 'Hotel search is temporarily unavailable — please refresh in a few minutes.';
        default:
          return '';
      }
    }

    function renderHotelCard(h, opts) {
      const li = document.createElement('li');
      li.className = 'hotel-card' + (opts.chosen ? ' is-chosen' : '');
      li.dataset.hotelId = h.hotelId;

      // Photo header
      if (h.imageUrl) {
        const img = document.createElement('img');
        img.src = h.imageUrl;
        img.alt = h.name;
        img.loading = 'lazy';
        img.style.cssText = 'width:100%;height:160px;object-fit:cover;border-radius:6px 6px 0 0;display:block;margin:-13px -14px 12px;width:calc(100% + 28px);';
        li.appendChild(img);
      }

      const body = document.createElement('div');
      body.style.cssText = 'display:grid;grid-template-columns:1fr auto;gap:12px;align-items:start';

      const main = document.createElement('div');
      const nameEl = document.createElement('p');
      nameEl.className = 'hotel-card-name';
      nameEl.textContent = h.name;
      main.appendChild(nameEl);

      const metaEl = document.createElement('p');
      metaEl.className = 'hotel-card-meta';
      metaEl.textContent = '★'.repeat(Math.max(1, Math.min(5, h.stars))) + ' · ' +
        (h.distanceToCenterKm != null ? h.distanceToCenterKm.toFixed(1) + ' km to centre' : '');
      main.appendChild(metaEl);

      if (h.amenities && h.amenities.length > 0) {
        const am = document.createElement('p');
        am.className = 'hotel-card-amenities';
        am.textContent = h.amenities.slice(0, 4).join(' · ');
        main.appendChild(am);
      }
      body.appendChild(main);

      const prices = document.createElement('div');
      prices.className = 'hotel-card-prices';
      const pp = document.createElement('p');
      pp.className = 'hotel-card-pp';
      pp.textContent = '€' + h.perPersonEur;
      prices.appendChild(pp);
      const ppLabel = document.createElement('span');
      ppLabel.className = 'hotel-card-pp-label';
      ppLabel.textContent = 'per person';
      prices.appendChild(ppLabel);
      const total = document.createElement('p');
      total.className = 'hotel-card-total';
      total.textContent = '€' + h.totalPriceEur + ' total · €' + h.nightlyPriceEur + '/night';
      prices.appendChild(total);
      body.appendChild(prices);
      li.appendChild(body);

      const actions = document.createElement('div');
      actions.className = 'hotel-card-actions';

      if (opts.chosen) {
        const badge = document.createElement('span');
        badge.className = 'hotel-card-chosen-badge';
        badge.textContent = '✓ Chosen by organiser';
        actions.appendChild(badge);
      } else {
        const voteBtn = document.createElement('button');
        voteBtn.type = 'button';
        voteBtn.className = 'hotel-card-button';
        const isMine = myVotedHotelId === h.hotelId;
        voteBtn.textContent = isMine ? '✓ Your vote' : 'Vote for this one';
        if (isMine) voteBtn.classList.add('hotel-card-button-primary');
        voteBtn.addEventListener('click', () => voteForHotel(h.hotelId));
        actions.appendChild(voteBtn);
      }

      const tally = document.createElement('span');
      tally.className = 'hotel-card-vote-tally';
      const count = (opts.voteTallies && opts.voteTallies[h.hotelId]) || 0;
      tally.textContent = count + ' vote' + (count === 1 ? '' : 's');
      actions.appendChild(tally);

      // Booking CTA button (Feature 4)
      if (h.bookingUrl) {
        const bookLink = document.createElement('a');
        bookLink.href = h.bookingUrl;
        bookLink.target = '_blank';
        bookLink.rel = 'noopener noreferrer';
        bookLink.textContent = '🏨 Jetzt buchen';
        bookLink.className = 'hotel-card-button hotel-card-button-book';
        actions.appendChild(bookLink);
      }

      li.appendChild(actions);
      return li;
    }

    function renderHotels(data) {
      if (!hotelSection) return;
      hotelSection.hidden = false;
      const hotels = (data && data.hotels) || [];
      const reason = data && data.reason;
      const provider = data && data.provider;
      const dateRange = data && data.dateRange;
      const destination = data && data.destination;
      const chosenHotelId = data && data.chosenHotelId;
      const voteTallies = (data && data.voteTallies) || {};

      if (hotelDemoBanner) {
        hotelDemoBanner.hidden = !(provider && provider.isReal === false);
      }
      if (hotelMetaEl && destination && destination.city) {
        const datesLabel =
          dateRange && dateRange.checkIn
            ? ' · ' + dateRange.checkIn + ' → ' + dateRange.checkOut
            : '';
        const guestsLabel =
          data && typeof data.guests === 'number'
            ? ' · ' + data.guests + ' guest' + (data.guests === 1 ? '' : 's')
            : '';
        hotelMetaEl.textContent = destination.city + datesLabel + guestsLabel;
        hotelMetaEl.hidden = false;
      }
      if (hotelListEl) {
        hotelListEl.innerHTML = '';
        hotelListEl.hidden = true;
      }
      if (hotelStateEl) hotelStateEl.hidden = true;

      if (reason !== 'ok' || hotels.length === 0) {
        if (hotelStateEl && hotelStateText) {
          hotelStateText.textContent =
            hotelReasonMessage(reason || 'no_inventory') ||
            'Hotel shortlist is empty — try again soon.';
          hotelStateEl.hidden = false;
        }
        return;
      }

      const top = hotels.slice(0, 5);
      if (hotelListEl) {
        for (const h of top) {
          hotelListEl.appendChild(
            renderHotelCard(h, {
              chosen: chosenHotelId === h.hotelId,
              voteTallies,
            })
          );
        }
        hotelListEl.hidden = false;
      }
    }

    async function loadHotels() {
      if (!hotelSection) return;
      hotelSection.hidden = false;
      // Feature 2: show skeleton while loading.
      if (hotelSkeleton) hotelSkeleton.hidden = false;
      if (hotelListEl) hotelListEl.hidden = true;
      if (hotelStateEl) hotelStateEl.hidden = true;
      try {
        const url =
          apiBase +
          '/api/hotels?slug=' +
          encodeURIComponent(slug) +
          '&token=' +
          encodeURIComponent(token);
        const res = await fetch(url, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        renderHotels(data);
      } catch (err) {
        if (hotelStateEl && hotelStateText) {
          hotelStateText.textContent =
            'Could not load hotels right now — try refreshing the page.';
          hotelStateEl.hidden = false;
        }
      } finally {
        if (hotelSkeleton) hotelSkeleton.hidden = true;
      }
    }

    async function voteForHotel(hotelId) {
      try {
        const res = await fetch(apiBase + '/api/hotel-vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, token, hotelId }),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        myVotedHotelId = data.hotelId || hotelId;
        showToast('Vote saved', 'ok');
        // Re-render with updated tallies.
        loadHotels();
      } catch (err) {
        showToast('Vote failed', 'err');
      }
    }

    // ─── Phase 7: activities (Claude-curated) ────────────────────────────
    const activitiesSection = document.getElementById('activities-list');
    const activitiesSkeleton = activitiesSection
      ? activitiesSection.querySelector('[data-activities-skeleton]')
      : null;
    const activitiesDemoBanner = activitiesSection
      ? activitiesSection.querySelector('[data-activities-demo-banner]')
      : null;
    const activitiesMetaEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-meta]')
      : null;
    const activitiesStateEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-state]')
      : null;
    const activitiesStateText = activitiesSection
      ? activitiesSection.querySelector('[data-activities-state-text]')
      : null;
    const thisWeekSection = activitiesSection
      ? activitiesSection.querySelector('[data-activities-thisweek-section]')
      : null;
    const thisWeekListEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-thisweek]')
      : null;
    const alwaysGreatSection = activitiesSection
      ? activitiesSection.querySelector('[data-activities-alwaysgreat-section]')
      : null;
    const alwaysGreatListEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-alwaysgreat]')
      : null;

    const ACTIVITY_ICONS = {
      concert: '🎵',
      festival: '🎉',
      museum: '🏛️',
      food: '🍽️',
      outdoors: '🌳',
      history: '🏰',
      neighborhood: '🏘️',
      event: '🎭',
      other: '🔮',
    };

    function renderActivityCard(item) {
      const li = document.createElement('li');
      li.className = 'activity-card';
      if (item.confidence === 'low') li.classList.add('is-low');

      // Photo
      if (item.imageUrl) {
        const img = document.createElement('img');
        img.src = item.imageUrl;
        img.alt = item.name;
        img.loading = 'lazy';
        img.style.cssText = 'grid-column:1/-1;width:100%;height:130px;object-fit:cover;border-radius:4px;display:block;';
        li.appendChild(img);
      }

      const icon = document.createElement('div');
      icon.className = 'activity-card-icon';
      icon.textContent = ACTIVITY_ICONS[item.type] || ACTIVITY_ICONS.other;
      li.appendChild(icon);

      const body = document.createElement('div');
      body.className = 'activity-card-body';

      const nameRow = document.createElement('div');
      nameRow.style.cssText = 'display:flex;align-items:flex-start;justify-content:space-between;gap:8px';
      const name = document.createElement('p');
      name.className = 'activity-card-name';
      name.style.margin = '0';
      name.textContent = item.name;
      nameRow.appendChild(name);
      // Price badge inline with name
      const priceTag = document.createElement('span');
      priceTag.style.cssText = 'font-size:12px;font-weight:700;white-space:nowrap;color:' + (item.paid ? '#0f172a' : '#16a34a');
      priceTag.textContent = item.paid ? (typeof item.priceEur === 'number' ? '€' + item.priceEur : 'Paid') : 'Free';
      nameRow.appendChild(priceTag);
      body.appendChild(nameRow);

      const why = document.createElement('p');
      why.className = 'activity-card-why';
      why.textContent = item.whyOneSentence;
      body.appendChild(why);

      const meta = document.createElement('p');
      meta.className = 'activity-card-meta';
      meta.textContent = item.dateRange;
      body.appendChild(meta);

      if (item.confidence === 'medium') {
        const badge = document.createElement('span');
        badge.className = 'activity-confidence-badge is-medium';
        badge.textContent = 'ℹ Termine prüfen';
        body.appendChild(badge);
      } else if (item.confidence === 'low') {
        const badge = document.createElement('span');
        badge.className = 'activity-confidence-badge is-low';
        badge.textContent = '⚠ Aktuelles Programm checken';
        body.appendChild(badge);
      }

      // Booking link
      if (item.bookingUrl) {
        const link = document.createElement('a');
        link.href = item.bookingUrl;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.textContent = 'Mehr Info →';
        link.style.cssText = 'display:inline-block;margin-top:6px;font-size:12px;font-weight:600;color:#0066cc;text-decoration:none;';
        body.appendChild(link);
      } else {
        // Google Maps fallback
        const mapsLink = document.createElement('a');
        mapsLink.href = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(item.name);
        mapsLink.target = '_blank';
        mapsLink.rel = 'noopener noreferrer';
        mapsLink.textContent = 'Google Maps →';
        mapsLink.style.cssText = 'display:inline-block;margin-top:6px;font-size:12px;font-weight:600;color:#0066cc;text-decoration:none;';
        body.appendChild(mapsLink);
      }

      li.appendChild(body);
      return li;
    }

    function renderActivities(data) {
      if (!activitiesSection) return;
      activitiesSection.hidden = false;
      const activities = (data && data.activities) || { thisWeek: [], alwaysGreat: [] };
      const reason = data && data.reason;
      const provider = data && data.provider;
      const destination = data && data.destination;

      if (activitiesDemoBanner) {
        activitiesDemoBanner.hidden = !(provider && provider.isReal === false);
      }
      if (activitiesMetaEl && destination) {
        activitiesMetaEl.textContent = destination;
        activitiesMetaEl.hidden = false;
      }
      if (thisWeekListEl) thisWeekListEl.innerHTML = '';
      if (alwaysGreatListEl) alwaysGreatListEl.innerHTML = '';
      if (thisWeekSection) thisWeekSection.hidden = true;
      if (alwaysGreatSection) alwaysGreatSection.hidden = true;
      if (activitiesStateEl) activitiesStateEl.hidden = true;

      const total = (activities.thisWeek || []).length + (activities.alwaysGreat || []).length;
      if (reason !== 'ok' || total === 0) {
        if (activitiesStateEl && activitiesStateText) {
          activitiesStateText.textContent =
            reason === 'destination_too_obscure'
              ? "We couldn't find specific activity suggestions for this destination — try TripAdvisor or your favourite travel guide."
              : 'Activity suggestions are temporarily unavailable — refresh in a few minutes.';
          activitiesStateEl.hidden = false;
        }
        return;
      }

      if ((activities.thisWeek || []).length > 0 && thisWeekListEl && thisWeekSection) {
        for (const item of activities.thisWeek) {
          thisWeekListEl.appendChild(renderActivityCard(item));
        }
        thisWeekSection.hidden = false;
      }
      if ((activities.alwaysGreat || []).length > 0 && alwaysGreatListEl && alwaysGreatSection) {
        for (const item of activities.alwaysGreat) {
          alwaysGreatListEl.appendChild(renderActivityCard(item));
        }
        alwaysGreatSection.hidden = false;
      }
    }

    async function loadActivities() {
      if (!activitiesSection) return;
      activitiesSection.hidden = false;
      // Feature 2: show skeleton while loading.
      if (activitiesSkeleton) activitiesSkeleton.hidden = false;
      if (activitiesStateEl) activitiesStateEl.hidden = true;
      try {
        const url =
          apiBase +
          '/api/activities?slug=' +
          encodeURIComponent(slug) +
          '&token=' +
          encodeURIComponent(token);
        const res = await fetch(url, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        renderActivities(data);
      } catch (err) {
        if (activitiesStateEl && activitiesStateText) {
          activitiesStateText.textContent =
            'Could not load activities right now — try refreshing the page.';
          activitiesStateEl.hidden = false;
          activitiesSection.hidden = false;
        }
      } finally {
        if (activitiesSkeleton) activitiesSkeleton.hidden = true;
      }
    }

    // Phase 8: build add-to-calendar URLs from the featured trip range and
    // reveal the inline button block. Skipped if the calendar block isn't in
    // the DOM (defensive — older SSR cache).
    function addDaysIso(iso, days) {
      const parts = iso.split('-').map(Number);
      const dt = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
      dt.setUTCDate(dt.getUTCDate() + days);
      const y = dt.getUTCFullYear();
      const m = String(dt.getUTCMonth() + 1).padStart(2, '0');
      const d = String(dt.getUTCDate()).padStart(2, '0');
      return y + '-' + m + '-' + d;
    }
    function packCompactDate(iso) {
      return iso.replace(/-/g, '') + 'T000000Z';
    }
    function packIsoDate(iso) {
      return iso + 'T00:00:00Z';
    }
    function buildCalUrls(featured) {
      const startIso = featured ? featured.start : dateRangeStartIn;
      const endIncIso = featured ? featured.end : dateRangeEndIn;
      const endExclIso = addDaysIso(endIncIso, 1);
      const description = 'See your trip page for full details.';
      const location = pollDestination;
      const title = pollTitle;
      const datesCompact = packCompactDate(startIso) + '/' + packCompactDate(endExclIso);
      const google =
        'https://calendar.google.com/calendar/render?' +
        new URLSearchParams({
          action: 'TEMPLATE',
          text: title,
          dates: datesCompact,
          details: description,
          location: location,
        }).toString();
      const outlook =
        'https://outlook.live.com/calendar/0/deeplink/compose?' +
        new URLSearchParams({
          path: '/calendar/action/compose',
          rru: 'addevent',
          subject: title,
          startdt: packIsoDate(startIso),
          enddt: packIsoDate(endExclIso),
          body: description,
          location: location,
          allday: 'true',
        }).toString();
      const yahoo =
        'https://calendar.yahoo.com/?' +
        new URLSearchParams({
          v: '60',
          title: title,
          st: packCompactDate(startIso),
          et: packCompactDate(endExclIso),
          desc: description,
          in_loc: location,
        }).toString();
      return { google, outlook, yahoo, apple: icalDownloadUrl };
    }
    function renderAddToCalendarButtons(overlap) {
      const container = document.querySelector('[data-add-to-calendar-buttons]');
      if (!container) return;
      const ranges = (overlap && overlap.ranges) || [];
      const featured =
        ranges.find((r) => r.tier === 'perfect') ||
        ranges.find((r) => r.tier === 'withEffort') ||
        ranges[0] ||
        null;
      const urls = buildCalUrls(featured);
      const gEl = container.querySelector('[data-cal-google]');
      const aEl = container.querySelector('[data-cal-apple]');
      const oEl = container.querySelector('[data-cal-outlook]');
      const yEl = container.querySelector('[data-cal-yahoo]');
      const wEl = container.querySelector('[data-cal-webcal]');
      if (gEl) gEl.setAttribute('href', urls.google);
      if (aEl) aEl.setAttribute('href', urls.apple);
      if (oEl) oEl.setAttribute('href', urls.outlook);
      if (yEl) yEl.setAttribute('href', urls.yahoo);
      // Feature 5: webcal:// link uses the same .ics URL but with webcal:// scheme
      if (wEl) wEl.setAttribute('href', urls.apple.replace(/^https?:\/\//, 'webcal://'));
      container.hidden = false;
    }

    /** @param {any} overlap */
    function renderSummaryBanner(overlap) {
      if (!summaryBanner || !summaryTextEl) return;
      const ranges = (overlap && overlap.ranges) || [];
      const perfect = ranges.filter((r) => r.tier === 'perfect');
      const withEffort = ranges.filter((r) => r.tier === 'withEffort');
      const oneShort = ranges.filter((r) => r.tier === 'oneShort');
      let msg;
      let kind = 'ok';
      if (perfect.length > 0) {
        const top = perfect[0];
        msg = '🎉 Best dates: ' + top.start + ' → ' + top.end + ' (' + top.length + ' days)';
      } else if (withEffort.length > 0) {
        const top = withEffort[0];
        msg = '✨ With a little effort: ' + top.start + ' → ' + top.end + ' (' + top.length + ' days) — almost everyone can make it';
      } else if (oneShort.length > 0) {
        // Feature 3: graceful fallback — no date worked for everyone, but
        // suggest the window where the fewest people are missing.
        const top = oneShort.slice().sort((a, b) => b.length - a.length)[0];
        msg = '🤏 No date worked for all — but ' + top.start + ' → ' + top.end +
          ' is closest (just one person short). Worth a group chat?';
        kind = 'warn';
      } else {
        msg = '😕 No overlapping dates yet. Try nudging people to add more "maybe" days, or pick a new window together.';
        kind = 'warn';
      }
      summaryTextEl.textContent = msg;
      summaryBanner.dataset.kind = kind;
      summaryBanner.hidden = false;
    }

    async function refreshState() {
      const url =
        apiBase +
        '/api/poll?slug=' +
        encodeURIComponent(slug) +
        '&token=' +
        encodeURIComponent(token);
      try {
        const res = await fetch(url, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        applyServerState(data);
        // Feature 1: start live-poll interval when poll is open, stop when closed
        if (!data.closed && !pollInterval) {
          pollInterval = setInterval(refreshState, 30000);
        } else if (data.closed && pollInterval) {
          clearInterval(pollInterval);
          pollInterval = null;
        }
      } catch (err) {
        setStatus('offline — votes won’t save');
      }
    }

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') refreshState();
    });

    refreshState();
  })();
</script>

