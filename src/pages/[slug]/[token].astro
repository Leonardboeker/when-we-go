---
// src/pages/[slug]/[token].astro
// Per-participant page. Phase 2: tap-to-vote calendar grid with debounced
// API persistence, post-close read-only view + overlap badges.
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { polls, type Poll, type Participant } from '../../data/polls';
import PollHeader from '../../components/PollHeader.astro';
import CalendarGrid from '../../components/CalendarGrid.astro';
import ProfileForm from '../../components/ProfileForm.astro';
import EmailButtons from '../../components/EmailButtons.astro';
import FlightOptions from '../../components/FlightOptions.astro';
import HotelShortlist from '../../components/HotelShortlist.astro';
import ActivitiesList from '../../components/ActivitiesList.astro';
import BottomNav from '../../components/BottomNav.astro';
import Onboarding from '../../components/Onboarding.astro';
import { buildICalDownloadUrl } from '../../lib/calendar-links';

export const prerender = true;

export const getStaticPaths = (() => {
  const paths: Array<{
    params: { slug: string; token: string };
    props: { poll: Poll; participant: Participant };
  }> = [];
  for (const poll of polls) {
    for (const participant of poll.participants) {
      paths.push({
        params: { slug: poll.slug, token: participant.token },
        props: { poll, participant },
      });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { poll, participant } = Astro.props as {
  poll: Poll;
  participant: Participant;
};

// Cross-poll isolation: only this poll's data is in scope. Other polls are
// not imported or referenced below. (verify-isolation.mjs enforces this.)
const title = `Hey ${participant.name} — wann kannst du${poll.destination ? ` nach ${poll.destination}` : ''}?`;

// API base URL. Override via WHENWEGO_PUBLIC_API_BASE (build env). Defaults to
// same-origin (empty string) so the deployed Worker route handles /api/* paths.
const publicApiBase =
  (import.meta.env.WHENWEGO_PUBLIC_API_BASE as string | undefined) ?? '';

// Phase 8: absolute site URL for building add-to-calendar links. The
// `WHENWEGO_PUBLIC_SITE_URL` build env wins; falls back to PUBLIC_SITE_URL
// (the existing Astro convention), then localhost for dev. Trailing slash
// stripped so we can concatenate paths cleanly.
const publicSiteUrl = (
  (import.meta.env.WHENWEGO_PUBLIC_SITE_URL as string | undefined) ??
  (import.meta.env.PUBLIC_SITE_URL as string | undefined) ??
  'http://localhost:4321'
).replace(/\/$/, '');

// Pre-build the .ics download URL at SSR time — it's the only add-to-calendar
// URL that doesn't depend on the overlap, so it's safe to bake in.
const icalDownloadUrl = buildICalDownloadUrl({
  siteUrl: publicSiteUrl,
  slug: poll.slug,
});
---

<BaseLayout
  title={title}
  ogImage={`/og/${poll.slug}.png`}
  ogDescription={`${poll.title} — tippe die Tage an, an denen du kannst. Abstimmung endet ${poll.pollCloseAt.slice(0, 10)}.`}
>
  <main class="page-wrapper">
    {/* Visually hidden h1 for screen readers — PollHeader provides the visual heading. */}
    <h1 class="sr-only">Hey {participant.name} — wähl deine Tage für {poll.title}</h1>

    <PollHeader
      participantName={participant.name}
      title={poll.title}
      destination={poll.destination}
      pollCloseAt={poll.pollCloseAt}
    />

    {/* Feature 9: Share buttons */}
    <div class="share-buttons">
      <span class="share-label">Teilen:</span>
      <a
        class="share-btn share-btn-whatsapp"
        href={`https://wa.me/?text=${encodeURIComponent(`Hey! Wann hast du Zeit für ${poll.destination ?? poll.title}? Abstimm hier: ${publicSiteUrl}/${poll.slug}/${participant.token}`)}`}
        target="_blank"
        rel="noopener noreferrer"
      >WhatsApp</a>
      <a
        class="share-btn share-btn-telegram"
        href={`https://t.me/share/url?url=${encodeURIComponent(`${publicSiteUrl}/${poll.slug}/${participant.token}`)}&text=${encodeURIComponent(`Hey! Wann hast du Zeit für ${poll.destination ?? poll.title}?`)}`}
        target="_blank"
        rel="noopener noreferrer"
      >Telegram</a>
    </div>

    {/* #9 — Web Push opt-in (hidden until we confirm VAPID is configured). */}
    <div id="push-optin" class="push-optin" hidden>
      <button type="button" id="push-btn" class="push-btn">🔔 Benachrichtigungen aktivieren</button>
      <span id="push-status" class="push-status"></span>
    </div>

    {/* ── Section: Dates (default tab) ─────────────────────────────── */}
    <div class="page-section" data-section="dates">
      {/* Post-close summary banner */}
      <div id="poll-summary-banner" class="poll-summary-banner" hidden>
        <span data-summary-text></span>
      </div>
      {/* Phase 8: add-to-calendar buttons */}
      <EmailButtons />
      {/* Calendar-first: voting is never gated. Profile (email + home airport)
          is optional and lives in the Profil tab — it only personalises the
          flight suggestions, it never blocks voting. */}
      <div id="calendar-gate">
        <CalendarGrid
          dateRangeStart={poll.dateRangeStart}
          dateRangeEnd={poll.dateRangeEnd}
        />
      </div>

      {/* #6 — date comments: short notes attached to a specific day. */}
      <section id="comments-section" class="comments-section" hidden aria-labelledby="comments-title">
        <h2 id="comments-title" class="comments-title">Notizen zu Terminen</h2>
        <p class="comments-blurb">Kurze Notiz zu einem Tag — z.&nbsp;B. „kann nur abends".</p>
        <form id="comment-form" class="comment-form">
          <input
            type="date"
            id="comment-date"
            class="comment-date"
            min={poll.dateRangeStart}
            max={poll.dateRangeEnd}
            required
            aria-label="Tag"
          />
          <input
            type="text"
            id="comment-text"
            class="comment-text"
            maxlength="200"
            placeholder="Deine Notiz…"
            required
            aria-label="Notiz"
          />
          <button type="submit" class="comment-submit">Hinzufügen</button>
        </form>
        <p class="comment-error" id="comment-error" hidden></p>
        <ul class="comment-list" id="comment-list"></ul>
        <p class="comment-empty" id="comment-empty" hidden>Noch keine Notizen.</p>
      </section>
    </div>

    {/* ── Section: Trip (post-close results) ────────────────────────── */}
    <div class="page-section" data-section="trip" hidden>
      {/* Feature 5: closed-state banner — shown when the poll has ended. */}
      <div id="trip-closed-banner" class="trip-closed-banner" hidden>
        <span class="trip-closed-icon" aria-hidden="true">✅</span>
        <span id="trip-closed-text">Die Abstimmung ist beendet — hier sind die Ergebnisse.</span>
      </div>
      {/* Open-poll preview note — shown while voting is still running so the
          flight/hotel/activity/event cards below read as a non-final preview.
          Replaces the old "erscheint sobald die Abstimmung endet" placeholder;
          the IIFE toggles it (open → visible, closed → hidden). */}
      <p class="trip-preview-note" id="trip-preview-note" hidden>
        Vorschau — finalisiert sich, sobald der Termin steht.
      </p>
      <p class="trip-preclose-hint" id="trip-pre-close-msg" hidden>
        ✈️ Sobald die Abstimmung endet, erscheinen hier Flüge, Hotels & Tipps.
      </p>
      {/* Feature 2 (weather): typical weather for the destination + dates.
          Populated client-side from Open-Meteo (free, no key). */}
      <div id="weather-widget" class="weather-widget" hidden>
        <span class="weather-emoji" id="weather-emoji" aria-hidden="true">⛅</span>
        <div class="weather-body">
          <p class="weather-title" id="weather-title"></p>
          <p class="weather-sub" id="weather-sub"></p>
        </div>
      </div>
      {/* Interactive map (Leaflet + OpenStreetMap, keyless). Hidden until the
          IIFE has hotel/activity coords to plot; lazy-loads Leaflet on first
          trip-tab activation. Sits above the flight/hotel/activity cards. */}
      <section id="trip-map-section" class="trip-map-section" hidden aria-labelledby="trip-map-title">
        <div class="trip-map-header">
          <h2 id="trip-map-title" class="trip-map-title">Auf der Karte</h2>
          <div class="trip-map-legend" aria-hidden="true">
            <span class="trip-map-legend-item"><span class="trip-map-dot trip-map-dot--hotel"></span>Hotels</span>
            <span class="trip-map-legend-item"><span class="trip-map-dot trip-map-dot--activity"></span>Aktivitäten</span>
          </div>
        </div>
        <div id="trip-map" class="trip-map"></div>
        <p class="trip-map-attribution">Karte © OpenStreetMap-Mitwirkende · Leaflet</p>
      </section>
      <FlightOptions />
      <HotelShortlist mode="participant" />
      <ActivitiesList />
    </div>

    {/* ── Section: Profile ─────────────────────────────────────────── */}
    <div class="page-section" data-section="profile" hidden>
      <div class="profile-tab-header">
        <h2 class="profile-tab-title">Dein Profil</h2>
        <p class="profile-tab-hint">Für persönliche Flug-Vorschläge und Erinnerungs-Mails.</p>
      </div>
      <ProfileForm />
    </div>

    <div id="vote-toast" class="vote-toast" role="status" aria-live="polite" hidden></div>
  </main>

  <BottomNav />

  {/* Feature 4: first-visit onboarding sheet (shows once per device) */}
  <Onboarding />

  <script
    is:inline
    define:vars={{
      slug: poll.slug,
      token: participant.token,
      apiBase: publicApiBase,
      dateRangeStartIn: poll.dateRangeStart,
      dateRangeEndIn: poll.dateRangeEnd,
      pollTitle: poll.title,
      pollDestination: poll.destination ?? poll.title,
      icalDownloadUrl,
    }}
  >
  (function () {
    'use strict';
    const STATES = ['unset', 'yes', 'maybe', 'no'];
    const CLASS_PREFIX = 'cell-';
    const OVERLAP_CLASSES = ['cell-perfect', 'cell-witheffort', 'cell-oneshort'];
    const DEBOUNCE_MS = 500;

    /** @type {Record<string, 'unset'|'yes'|'maybe'|'no'>} */
    const voteState = Object.create(null);
    /** Last known server vote state for change detection (live updates) */
    const serverVoteSnapshot = Object.create(null);
    let closed = false;
    let saveTimer = null;
    let pollInterval = null;
    // Trip-tab content (flights/hotels/activities/map) is loaded lazily and at
    // most once per "phase" so the 30s poll tick never re-hits the provider
    // APIs. Set true after the first successful load; reset to false on close so
    // the post-close refresh re-loads against the now-decided overlap window.
    let tripContentLoaded = false;
    let lastOverlapForLoad = null;
    /** @type {AbortController | null} */
    let inflightAbort = null;
    /** Phase 11: per-day group votes by name {date: [{name, state}]}, + viewer's name */
    let groupVotesData = Object.create(null);
    let viewerName = '';

    const grid = document.querySelector('.calendar-grid');
    const statusEl = document.querySelector('[data-calendar-status]');
    const summaryBanner = document.getElementById('poll-summary-banner');
    const summaryTextEl = summaryBanner
      ? summaryBanner.querySelector('[data-summary-text]')
      : null;
    const toastEl = document.getElementById('vote-toast');
    const profileGate = document.getElementById('profile-gate');
    const calendarGate = document.getElementById('calendar-gate');
    const profileFormEl = document.getElementById('profile-form-element');
    const profileStatusEl = document.querySelector('[data-profile-status]');
    const profileSubmitBtn = document.querySelector('[data-profile-submit]');

    if (!grid) return;

    function isProfileComplete(p) {
      return Boolean(p && p.email && p.homeAirport);
    }

    function showCalendar() {
      if (profileGate) profileGate.hidden = true;
      if (calendarGate) calendarGate.hidden = false;
    }
    function showProfileForm() {
      if (profileGate) profileGate.hidden = false;
      if (calendarGate) calendarGate.hidden = true;
    }

    function setProfileStatus(msg, kind) {
      if (!profileStatusEl) return;
      profileStatusEl.textContent = msg || '';
      if (kind) profileStatusEl.dataset.kind = kind;
      else delete profileStatusEl.dataset.kind;
    }

    function buildProfilePayload() {
      if (!profileFormEl) return null;
      const fd = new FormData(profileFormEl);
      const email = (fd.get('email') || '').toString().trim();
      const homeAirport = (fd.get('homeAirport') || '').toString().trim().toUpperCase();
      const homeCity = (fd.get('homeCity') || '').toString().trim();
      const budgetRaw = (fd.get('budgetMaxEur') || '').toString();
      const interests = fd.getAll('interests').map((v) => v.toString());

      const payload = {};
      if (email) payload.email = email;
      if (homeAirport) payload.homeAirport = homeAirport;
      if (homeCity) payload.homeCity = homeCity;
      if (budgetRaw) {
        const n = parseInt(budgetRaw, 10);
        if (!isNaN(n) && n > 0) payload.budgetMaxEur = n;
      }
      if (interests.length > 0) payload.interests = interests;
      return payload;
    }

    function validateProfileClientSide(p) {
      const errors = {};
      if (!p.email) errors.email = 'Bitte gib deine E-Mail ein.';
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(p.email))
        errors.email = 'Diese E-Mail sieht ungültig aus.';
      if (!p.homeAirport) errors.homeAirport = 'Wähl deinen Heimatflughafen.';
      else if (!/^[A-Z]{3}$/.test(p.homeAirport))
        errors.homeAirport = 'Flughafen muss ein 3-Buchstaben-IATA-Code sein.';
      return errors;
    }

    function setFieldError(name, msg) {
      const el = document.querySelector(
        '[data-error-for="' + name + '"]'
      );
      if (!el) return;
      if (msg) {
        el.textContent = msg;
        el.hidden = false;
      } else {
        el.textContent = '';
        el.hidden = true;
      }
    }

    async function submitProfile(e) {
      if (e) e.preventDefault();
      const payload = buildProfilePayload();
      if (!payload) return;
      setFieldError('email', '');
      setFieldError('homeAirport', '');
      const errors = validateProfileClientSide(payload);
      if (Object.keys(errors).length > 0) {
        for (const k of Object.keys(errors)) setFieldError(k, errors[k]);
        setProfileStatus('Bitte korrigier die Fehler oben.', 'err');
        return;
      }
      if (profileSubmitBtn) profileSubmitBtn.disabled = true;
      setProfileStatus('Speichert…', '');
      try {
        const res = await fetch(apiBase + '/api/profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, token, profile: payload }),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'HTTP ' + res.status);
        }
        const j = await res.json();
        setProfileStatus('Gespeichert.', '');
        if (j.profileComplete) {
          showCalendar();
          // Refresh server state so the grid initialises with current votes.
          refreshState();
        }
      } catch (err) {
        setProfileStatus(
          'Speichern fehlgeschlagen: ' + (err && err.message ? err.message : 'unbekannt'),
          'err'
        );
      } finally {
        if (profileSubmitBtn) profileSubmitBtn.disabled = false;
      }
    }

    if (profileFormEl) {
      profileFormEl.addEventListener('submit', submitProfile);
    }

    // ── #6: date comments ──────────────────────────────────────────────
    const commentsSection = document.getElementById('comments-section');
    const commentForm = document.getElementById('comment-form');
    const commentDateEl = document.getElementById('comment-date');
    const commentTextEl = document.getElementById('comment-text');
    const commentListEl = document.getElementById('comment-list');
    const commentEmptyEl = document.getElementById('comment-empty');
    const commentErrorEl = document.getElementById('comment-error');

    function fmtCommentDate(iso) {
      try {
        return new Date(iso + 'T00:00:00Z').toLocaleDateString('de-DE', {
          weekday: 'short', day: '2-digit', month: 'short',
        });
      } catch (e) { return iso; }
    }
    function renderComments(comments) {
      if (!commentsSection || !commentListEl) return;
      commentsSection.hidden = false;
      const list = Array.isArray(comments) ? comments : [];
      // Group by date, sorted ascending; within a date keep server order.
      const byDate = {};
      for (const c of list) { (byDate[c.date] = byDate[c.date] || []).push(c); }
      const dates = Object.keys(byDate).sort();
      commentListEl.innerHTML = '';
      if (commentEmptyEl) commentEmptyEl.hidden = dates.length > 0;
      for (const d of dates) {
        const li = document.createElement('li');
        li.className = 'comment-day';
        const h = document.createElement('p');
        h.className = 'comment-day-date';
        h.textContent = fmtCommentDate(d);
        li.appendChild(h);
        for (const c of byDate[d]) {
          const row = document.createElement('div');
          row.className = 'comment-item' + (c.isMine ? ' is-mine' : '');
          const who = document.createElement('span');
          who.className = 'comment-who';
          who.textContent = c.isMine ? 'Du' : c.name;
          const txt = document.createElement('span');
          txt.className = 'comment-body';
          txt.textContent = c.text;
          row.appendChild(who);
          row.appendChild(txt);
          li.appendChild(row);
        }
        commentListEl.appendChild(li);
      }
    }
    async function submitComment(e) {
      if (e) e.preventDefault();
      if (!commentDateEl || !commentTextEl) return;
      const date = commentDateEl.value;
      const text = commentTextEl.value.trim();
      if (commentErrorEl) commentErrorEl.hidden = true;
      if (!date || !text) return;
      try {
        const res = await fetch(apiBase + '/api/comment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, token, date, text }),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'HTTP ' + res.status);
        }
        commentTextEl.value = '';
        showToast('Notiz gespeichert', 'ok');
        await refreshState();
      } catch (err) {
        if (commentErrorEl) {
          commentErrorEl.textContent = 'Konnte nicht speichern: ' + (err && err.message ? err.message : 'unbekannt');
          commentErrorEl.hidden = false;
        }
      }
    }
    if (commentForm) commentForm.addEventListener('submit', submitComment);

    // ── #9: Web Push opt-in ───────────────────────────────────────────
    // The whole block is a no-op unless the server reports VAPID is
    // configured AND the browser supports push + service workers.
    const pushOptin = document.getElementById('push-optin');
    const pushBtn = document.getElementById('push-btn');
    const pushStatus = document.getElementById('push-status');

    function urlBase64ToUint8Array(base64String) {
      const padding = '='.repeat((4 - (base64String.length % 4)) % 4);
      const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
      const raw = atob(base64);
      const arr = new Uint8Array(raw.length);
      for (let i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
      return arr;
    }

    async function initPush() {
      if (!pushOptin || !pushBtn) return;
      if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
      // Ask the server for the VAPID public key — 503 means push is off.
      let publicKey = null;
      try {
        const res = await fetch(apiBase + '/api/push/key', { headers: { Accept: 'application/json' } });
        if (!res.ok) return; // 503 not_configured → stay hidden
        const j = await res.json();
        if (!j.ok || !j.publicKey) return;
        publicKey = j.publicKey;
      } catch (e) { return; }

      pushOptin.hidden = false;
      // Already granted + subscribed? Reflect that.
      if (Notification.permission === 'granted') {
        try {
          const reg = await navigator.serviceWorker.getRegistration();
          const existing = reg && (await reg.pushManager.getSubscription());
          if (existing) {
            pushBtn.disabled = true;
            pushBtn.textContent = '🔔 Aktiviert ✓';
            return;
          }
        } catch (e) { /* fall through to enable button */ }
      }

      pushBtn.addEventListener('click', async () => {
        pushBtn.disabled = true;
        if (pushStatus) pushStatus.textContent = 'Aktiviere…';
        try {
          const reg = await navigator.serviceWorker.register('/sw.js');
          await navigator.serviceWorker.ready;
          const perm = await Notification.requestPermission();
          if (perm !== 'granted') {
            if (pushStatus) pushStatus.textContent = 'Im Browser blockiert.';
            pushBtn.disabled = false;
            return;
          }
          const sub = await reg.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: urlBase64ToUint8Array(publicKey),
          });
          const res = await fetch(apiBase + '/api/push/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug, token, subscription: sub.toJSON() }),
          });
          if (!res.ok) throw new Error('HTTP ' + res.status);
          pushBtn.textContent = '🔔 Aktiviert ✓';
          if (pushStatus) pushStatus.textContent = '';
        } catch (err) {
          if (pushStatus) pushStatus.textContent = 'Fehlgeschlagen.';
          pushBtn.disabled = false;
        }
      });
    }
    initPush();

    /** @param {string} msg @param {'saving'|'saved'|'error'|''} [kind] */
    function setStatus(msg, kind) {
      if (!statusEl) return;
      statusEl.textContent = msg;
      if (kind) statusEl.dataset.kind = kind;
      else delete statusEl.dataset.kind;
    }

    /** @param {string} msg @param {'ok'|'err'} kind */
    function showToast(msg, kind) {
      if (!toastEl) return;
      toastEl.textContent = msg;
      toastEl.dataset.kind = kind;
      toastEl.hidden = false;
      setTimeout(() => {
        toastEl.hidden = true;
      }, 2400);
    }

    /** @param {HTMLButtonElement} cell @param {string} state @param {boolean} [animate] */
    function applyCellClass(cell, state, animate) {
      for (const s of STATES) cell.classList.remove(CLASS_PREFIX + s);
      cell.classList.add(CLASS_PREFIX + state);
      cell.dataset.state = state;
      // Feature 9: screen-reader-friendly label with current vote in German.
      const STATE_DE = { unset: 'noch offen', yes: 'Ja', maybe: 'Vielleicht', no: 'Nein' };
      cell.setAttribute(
        'aria-label',
        cell.dataset.date + ', Stimme: ' + (STATE_DE[state] || state)
      );
      cell.setAttribute('aria-pressed', state !== 'unset' ? 'true' : 'false');
      if (animate) {
        cell.classList.remove('cell-updated');
        // Force reflow to restart animation
        void cell.offsetWidth;
        cell.classList.add('cell-updated');
      }
    }

    /** @param {HTMLButtonElement} cell @param {string|null} tier */
    function applyOverlapBadge(cell, tier) {
      for (const c of OVERLAP_CLASSES) cell.classList.remove(c);
      if (tier === 'perfect') cell.classList.add('cell-perfect');
      else if (tier === 'withEffort') cell.classList.add('cell-witheffort');
      else if (tier === 'oneShort') cell.classList.add('cell-oneshort');
    }

    function markReadOnly() {
      const cells = grid.querySelectorAll('.calendar-cell-day');
      cells.forEach((c) => {
        c.classList.add('cell-readonly');
        c.setAttribute('aria-disabled', 'true');
      });
    }

    /** @param {string} d */
    function nextState(d) {
      const cur = voteState[d] || 'unset';
      const idx = STATES.indexOf(cur);
      return STATES[(idx + 1) % STATES.length];
    }

    // ── Phase 11: live group availability ──────────────────────────────────
    const STATE_SYMBOL = { yes: '✓', maybe: '?', no: '✗' };
    const MONTHS_DE = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni',
      'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
    /** @param {string} iso */
    function formatDateDE(iso) {
      const p = iso.split('-');
      return parseInt(p[2], 10) + '. ' + (MONTHS_DE[parseInt(p[1], 10) - 1] || '');
    }

    /** Render per-day dots for OTHER participants (own vote = cell background). */
    function renderGroupVotes() {
      grid.querySelectorAll('.cell-voter-dots').forEach((el) => el.remove());
      for (const date of Object.keys(groupVotesData)) {
        const others = (groupVotesData[date] || []).filter((v) => v.name !== viewerName);
        if (others.length === 0) continue;
        const cell = grid.querySelector('.calendar-cell-day[data-date="' + date + '"]');
        if (!cell) continue;
        const wrap = document.createElement('span');
        wrap.className = 'cell-voter-dots';
        wrap.setAttribute('aria-hidden', 'true');
        wrap.title = others.map((v) => v.name + ' ' + (STATE_SYMBOL[v.state] || '')).join(', ');
        for (const v of others) {
          const dot = document.createElement('span');
          dot.className = 'voter-dot is-' + v.state;
          wrap.appendChild(dot);
        }
        cell.appendChild(wrap);
      }
    }

    /** Build "Papa ✓, Schwester ?, Du ✓" for one day (for the tap toast). */
    function groupSummaryFor(date) {
      const merged = (groupVotesData[date] || []).filter((v) => v.name !== viewerName);
      const own = voteState[date];
      if (own && own !== 'unset') merged.push({ name: 'Du', state: own });
      if (merged.length === 0) return '';
      const order = { yes: 0, maybe: 1, no: 2 };
      merged.sort((a, b) => (order[a.state] - order[b.state]));
      return merged.map((v) => v.name + ' ' + (STATE_SYMBOL[v.state] || '')).join(', ');
    }

    function scheduleSave() {
      if (saveTimer) clearTimeout(saveTimer);
      setStatus('Speichert…', 'saving');
      saveTimer = setTimeout(persistVotes, DEBOUNCE_MS);
    }

    async function persistVotes() {
      saveTimer = null;
      // Build payload from current state (only non-unset entries; bulk replace).
      const votes = Object.keys(voteState)
        .filter((d) => voteState[d] !== 'unset')
        .map((d) => ({ date: d, state: voteState[d] }));

      if (inflightAbort) inflightAbort.abort();
      inflightAbort = new AbortController();

      try {
        const res = await fetch(apiBase + '/api/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, token, votes }),
          signal: inflightAbort.signal,
        });
        if (res.status === 410) {
          closed = true;
          setStatus('poll closed');
          markReadOnly();
          showToast('Poll closed', 'err');
          await refreshState();
          return;
        }
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'HTTP ' + res.status);
        }
        setStatus('Gespeichert ✓', 'saved');
        setTimeout(() => setStatus('', ''), 1800);
      } catch (err) {
        if (err && err.name === 'AbortError') return;
        setStatus('Nicht gespeichert — nochmal tippen', 'error');
        showToast(
          'Speichern fehlgeschlagen: ' + (err && err.message ? err.message : 'unbekannt'),
          'err'
        );
      }
    }

    /** @param {string} date */
    function onCellTap(date) {
      if (closed) return;
      const cell = grid.querySelector(
        '.calendar-cell-day[data-date="' + date + '"]'
      );
      if (!cell) return;
      const ns = nextState(date);
      voteState[date] = ns;
      applyCellClass(cell, ns);
      scheduleSave();
      // Phase 11: show who else can make it on this day
      const summary = groupSummaryFor(date);
      if (summary) showToast(formatDateDE(date) + ' — ' + summary, 'info');
    }

    grid.addEventListener('click', (e) => {
      const target = e.target;
      const cell = target && target.closest
        ? target.closest('.calendar-cell-day')
        : null;
      if (!cell) return;
      if (cell.classList.contains('cell-readonly')) return;
      const d = cell.dataset.date;
      if (!d) return;
      onCellTap(d);
    });

    // ── Feature 9: keyboard navigation (roving tabindex arrow-key grid) ──
    // Cells are <button>s, so Enter/Space already toggle via the click handler.
    // This adds Arrow/Home/End focus movement: ±1 = prev/next day, ±7 = same
    // weekday adjacent week (the flat chronological list is exactly weekday-
    // aligned at ±7). One cell holds tabindex=0 at a time so Tab lands once.
    const cellList = Array.prototype.slice.call(
      grid.querySelectorAll('.calendar-cell-day')
    );
    cellList.forEach((c, i) => {
      c.setAttribute('tabindex', i === 0 ? '0' : '-1');
      c.setAttribute('role', 'gridcell');
    });
    function focusCell(idx) {
      if (idx < 0 || idx >= cellList.length) return;
      cellList.forEach((c) => c.setAttribute('tabindex', '-1'));
      const target = cellList[idx];
      target.setAttribute('tabindex', '0');
      target.focus();
    }
    grid.addEventListener('keydown', (e) => {
      const cell = e.target && e.target.closest
        ? e.target.closest('.calendar-cell-day')
        : null;
      if (!cell) return;
      const i = cellList.indexOf(cell);
      if (i === -1) return;
      let next = -1;
      switch (e.key) {
        case 'ArrowRight': next = i + 1; break;
        case 'ArrowLeft': next = i - 1; break;
        case 'ArrowDown': next = i + 7; break;
        case 'ArrowUp': next = i - 7; break;
        case 'Home': next = 0; break;
        case 'End': next = cellList.length - 1; break;
        default: return;
      }
      e.preventDefault();
      // Clamp ±7 moves that overshoot to the nearest end so focus never lost.
      if (next < 0) next = (e.key === 'ArrowUp') ? i : 0;
      if (next >= cellList.length) next = (e.key === 'ArrowDown') ? i : cellList.length - 1;
      focusCell(next);
    });

    /**
     * Initialise cell visuals from server response. Also applies overlap badges
     * when the poll is closed.
     * @param {{votes:Array<{date:string,state:string}>,closed:boolean,overlap:any,viewer?:{profile:any}}} data
     */
    function applyServerState(data) {
      const wasClosed = closed;
      closed = !!data.closed;
      // True only on the open -> closed transition (first refresh that reports
      // closed). Used to force a one-time trip-content reload against the now-
      // decided overlap, without re-fetching on every later post-close refresh.
      const justClosed = closed && !wasClosed;
      // Phase 11: stash group votes + viewer name for live per-day dots.
      viewerName = (data.viewer && data.viewer.name) || '';
      groupVotesData = data.groupVotes || Object.create(null);

      // Calendar-first: the calendar is ALWAYS visible so anyone can vote
      // immediately — voting is never gated on the profile. The profile
      // (email + home airport) is optional and lives in the Profil tab; it
      // only personalises the flight suggestions on the Reise tab.
      const profile = data && data.viewer && data.viewer.profile;
      showCalendar();
      // Pre-populate the Profil-tab inputs with whatever profile state exists,
      // so returning users see their last input.
      if (profile) {
        const emailEl = document.getElementById('profile-email');
        const airportEl = document.getElementById('profile-airport');
        const cityEl = document.getElementById('profile-airport-city');
        if (emailEl && profile.email) emailEl.value = profile.email;
        if (airportEl && profile.homeAirport) airportEl.value = profile.homeAirport;
        if (cityEl && profile.homeCity) cityEl.value = profile.homeCity;
      }

      for (const v of data.votes || []) {
        const prev = serverVoteSnapshot[v.date];
        const changed = prev !== undefined && prev !== v.state && voteState[v.date] === prev;
        voteState[v.date] = v.state;
        serverVoteSnapshot[v.date] = v.state;
        const cell = grid.querySelector(
          '.calendar-cell-day[data-date="' + v.date + '"]'
        );
        if (cell) applyCellClass(cell, v.state, changed);
      }
      // Stash the latest overlap (post-close it's the decided window; open it's
      // usually null) so a lazy first-open trip load can pass it to loadWeather.
      lastOverlapForLoad = data.overlap || null;

      if (closed) {
        markReadOnly();
        const overlap = data.overlap;
        if (overlap && overlap.perDate) {
          const perfect = new Set(overlap.perfect || []);
          const withEffort = new Set(overlap.withEffort || []);
          const oneShort = new Set(overlap.oneShort || []);
          const cells = grid.querySelectorAll('.calendar-cell-day');
          cells.forEach((cell) => {
            const d = cell.dataset.date;
            if (!d) return;
            if (perfect.has(d)) applyOverlapBadge(cell, 'perfect');
            else if (withEffort.has(d)) applyOverlapBadge(cell, 'withEffort');
            else if (oneShort.has(d)) applyOverlapBadge(cell, 'oneShort');
          });
          renderSummaryBanner(overlap);
          renderAddToCalendarButtons(overlap);
        }
        // Feature 2: add red dot for any date with at least one "no" vote
        if (data.overlap && data.overlap.perDate) {
          const perDate = data.overlap.perDate;
          const allCells = grid.querySelectorAll('.calendar-cell-day');
          allCells.forEach((cell) => {
            const d = cell.dataset.date;
            if (!d || !perDate[d]) return;
            const hasNo = Object.values(perDate[d]).some((s) => s === 'no');
            if (hasNo) cell.classList.add('cell-has-no');
          });
        }
        setStatus('Abstimmung beendet', '');
        // Feature 5: closed-state banner on the Trip tab + hide pre-close hint
        // and the open-poll "Vorschau" note (this is the final result now).
        const closedBanner = document.getElementById('trip-closed-banner');
        const closedText = document.getElementById('trip-closed-text');
        const preCloseMsg = document.getElementById('trip-pre-close-msg');
        const previewNote = document.getElementById('trip-preview-note');
        if (preCloseMsg) preCloseMsg.hidden = true;
        if (previewNote) previewNote.hidden = true;
        if (closedBanner) {
          const ranges = (data.overlap && data.overlap.ranges) || [];
          const best = ranges.find((r) => r.tier === 'perfect') ||
            ranges.find((r) => r.tier === 'withEffort') || null;
          if (closedText && best) {
            closedText.textContent = 'Abstimmung beendet · Beste Daten: ' +
              best.start + ' → ' + best.end + ' (' + best.length + ' Tage)';
          }
          closedBanner.hidden = false;
        }
        // Phase 5-7: (re)load trip content against the now-decided overlap
        // window. On the open -> closed transition, force a reload even if a
        // preview already loaded while open, so flights/hotels/activities/events
        // reflect the final dates. Otherwise (later post-close refreshes) the
        // normal guard keeps it a no-op.
        loadTripContent(justClosed);
        // Auto-switch to Trip tab and show notification badge.
        if (typeof window.__switchToTripTab === 'function') {
          window.__switchToTripTab(true);
        }
      } else {
        // Feature 7: Best week highlight (only when poll is open)
        highlightBestWeek();
        // Open-poll PREVIEW: load the trip content (flights/hotels/activities/
        // events + map) lazily the first time, so the Reise tab shows a live
        // preview during voting instead of a "comes later" placeholder. Guarded
        // so the 30s poll tick never re-hits the provider APIs.
        const previewNote = document.getElementById('trip-preview-note');
        const preCloseMsg = document.getElementById('trip-pre-close-msg');
        if (previewNote) previewNote.hidden = false;
        if (preCloseMsg) preCloseMsg.hidden = true; // replaced by the live preview
        loadTripContent(false);
      }

      // Feature 8: participant progress indicator
      renderParticipantProgress(data);
      // #6: date comments (refreshes with the 30s poll)
      renderComments(data.comments);
      // Phase 11: live per-day group dots (refreshes with the 30s poll)
      renderGroupVotes();
    }

    /**
     * Load the Reise-tab content once (flights, hotels, activities/events, the
     * weather widget + the Leaflet map). Idempotent: a "loaded" flag stops the
     * 30s poll tick (and repeat tab opens) from re-hitting the provider APIs.
     * @param {boolean} force  re-load even if already loaded (used on close, to
     *                         refresh against the now-decided overlap window).
     */
    function loadTripContent(force) {
      if (tripContentLoaded && !force) return;
      tripContentLoaded = true;
      // The handlers resolve the date window server-side: post-close they use
      // the decided overlap, open they fall back to the poll dateRange. So we
      // don't pass a window here — just trigger the loads (all non-blocking).
      loadFlights(false);
      loadHotels();
      loadActivities();
      // Feature 2: weather for the trip window (Open-Meteo, non-blocking).
      // Pass the latest overlap (post-close) or null (open -> poll start window).
      loadWeather(lastOverlapForLoad);
    }

    /** Feature 7: find the Mon-Sun week with the most "yes" votes and highlight it */
    function highlightBestWeek() {
      // Clear previous highlights
      grid.querySelectorAll('.cell-best-week').forEach((c) => c.classList.remove('cell-best-week'));

      const yesDates = Object.keys(voteState).filter((d) => voteState[d] === 'yes');
      if (yesDates.length < 3) return;

      // Group yes-dates by week (Mon-Sun)
      const weekCounts = new Map();
      const weekDates = new Map();
      for (const d of yesDates) {
        const dt = new Date(d + 'T00:00:00Z');
        const dow = (dt.getUTCDay() + 6) % 7; // 0=Mon, 6=Sun
        const monday = new Date(dt);
        monday.setUTCDate(dt.getUTCDate() - dow);
        const key = monday.toISOString().slice(0, 10);
        weekCounts.set(key, (weekCounts.get(key) || 0) + 1);
        if (!weekDates.has(key)) weekDates.set(key, []);
        weekDates.get(key).push(d);
      }

      let bestKey = null;
      let bestCount = 0;
      for (const [k, count] of weekCounts) {
        if (count > bestCount) { bestCount = count; bestKey = k; }
      }

      if (!bestKey || bestCount < 4) return;

      const bestDatesSet = new Set(weekDates.get(bestKey));
      grid.querySelectorAll('.calendar-cell-day').forEach((cell) => {
        if (bestDatesSet.has(cell.dataset.date)) cell.classList.add('cell-best-week');
      });

      // Show hint text
      const existing = document.getElementById('best-week-hint');
      if (existing) existing.remove();
      const dates = [...bestDatesSet].sort();
      if (dates.length > 0) {
        const hint = document.createElement('p');
        hint.id = 'best-week-hint';
        hint.className = 'best-week-hint';
        hint.textContent = '📅 Dein Top-Termin: ' + dates[0] + ' → ' + dates[dates.length - 1];
        const calStatus = grid.querySelector('.calendar-status');
        if (calStatus) grid.insertBefore(hint, calStatus);
        else grid.appendChild(hint);
      }
    }

    /** Feature 8: show participant vote progress */
    function renderParticipantProgress(data) {
      const progressEl = document.getElementById('participant-progress');
      if (!progressEl) return;
      // Use voterStatus if available (from /api/poll history). Fall back to
      // the poll.participantCount + viewer.voteCount we always have.
      const voterStatus = data.voterStatus || null;
      if (voterStatus && Array.isArray(voterStatus)) {
        const total = voterStatus.length;
        const voted = voterStatus.filter((v) => v.voteCount > 0).length;
        progressEl.textContent = voted + ' von ' + total + ' haben abgestimmt';
        progressEl.hidden = false;
      } else if (data.poll && data.poll.participantCount) {
        // Minimal fallback: we know the viewer's vote count from data.viewer
        const total = data.poll.participantCount;
        const viewerVoted = data.viewer && data.viewer.voteCount > 0 ? 1 : 0;
        progressEl.textContent = viewerVoted + ' von ' + total + ' haben abgestimmt (min.)';
        progressEl.hidden = false;
      }
    }

    // ─── Phase 5: flight options ─────────────────────────────────────────
    const flightSection = document.getElementById('flight-options');
    const flightSkeleton = flightSection
      ? flightSection.querySelector('[data-flights-skeleton]')
      : null;
    const flightRefreshBtn = flightSection
      ? flightSection.querySelector('[data-flights-refresh]')
      : null;
    const flightListEl = flightSection
      ? flightSection.querySelector('[data-flights-list]')
      : null;
    const flightRestEl = flightSection
      ? flightSection.querySelector('[data-flights-rest]')
      : null;
    const flightMoreEl = flightSection
      ? flightSection.querySelector('[data-flights-more]')
      : null;
    const flightStateEl = flightSection
      ? flightSection.querySelector('[data-flights-state]')
      : null;
    const flightStateText = flightSection
      ? flightSection.querySelector('[data-flights-state-text]')
      : null;
    const flightGoogleLink = flightSection
      ? flightSection.querySelector('[data-flights-google-link]')
      : null;
    const flightMetaEl = flightSection
      ? flightSection.querySelector('[data-flights-meta]')
      : null;
    const flightDemoBanner = flightSection
      ? flightSection.querySelector('[data-flights-demo-banner]')
      : null;

    function formatDurationMin(mins) {
      if (!mins || mins <= 0) return '';
      const h = Math.floor(mins / 60);
      const m = mins % 60;
      if (h === 0) return m + 'm';
      if (m === 0) return h + 'h';
      return h + 'h ' + m + 'm';
    }

    function fmtFlightTime(iso) {
      if (!iso) return '';
      // Amadeus 'local' string e.g. '2026-07-12T07:30:00' — slice the time part.
      const t = iso.split('T')[1];
      if (!t) return '';
      return t.slice(0, 5);
    }

    function renderFlightCard(f, isCheapest) {
      const li = document.createElement('li');
      li.className = 'flight-card' + (isCheapest ? ' is-cheapest' : '');
      const main = document.createElement('div');
      main.className = 'flight-card-main';
      const airlineStrong = document.createElement('strong');
      airlineStrong.textContent = f.airline + (f.carrierCode ? ' (' + f.carrierCode + ')' : '');
      main.appendChild(airlineStrong);
      const meta = document.createElement('div');
      meta.className = 'flight-card-meta';
      const stopsTxt = f.stops === 0 ? 'Direct' : f.stops + ' stop' + (f.stops > 1 ? 's' : '');
      const durTxt = formatDurationMin(f.durationMinTotal);
      const timeTxt = f.departureTimeLocal && f.arrivalTimeLocal
        ? fmtFlightTime(f.departureTimeLocal) + ' → ' + fmtFlightTime(f.arrivalTimeLocal) : '';
      meta.textContent = [timeTxt, durTxt, stopsTxt].filter(Boolean).join(' · ');
      main.appendChild(meta);
      li.appendChild(main);

      const right = document.createElement('div');
      right.style.cssText = 'text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:4px';
      const price = document.createElement('div');
      price.className = 'flight-card-price';
      price.textContent = '€' + Math.round(f.priceEur);
      right.appendChild(price);
      // Book link — prefer the provider deep-link (Kiwi bookingUrl), else a
      // prefilled Google Flights search for the same route + date.
      const bookLink = document.createElement('a');
      bookLink.className = 'flight-card-book';
      bookLink.target = '_blank';
      bookLink.rel = 'noopener noreferrer';
      if (f.bookingUrl) {
        bookLink.textContent = 'Buchen →';
        bookLink.href = f.bookingUrl;
      } else {
        bookLink.textContent = 'Suchen →';
        const origin = (window._flightOriginIata) ? window._flightOriginIata : '';
        const dest = (window._flightDestIata) ? window._flightDestIata : '';
        const depDate = (f.departureTimeLocal) ? f.departureTimeLocal.slice(0,10) : '';
        bookLink.href = 'https://www.google.com/travel/flights?q=' + encodeURIComponent('Flights ' + origin + ' to ' + dest + (depDate ? ' ' + depDate : ''));
      }
      right.appendChild(bookLink);
      li.appendChild(right);
      return li;
    }

    function buildGoogleFlightsUrl(originIata, destIata, depart, ret) {
      // Real Google Flights search — opens live results (no fake prices in-app).
      const q = originIata
        ? 'Flights from ' + originIata + ' to ' + destIata +
          (depart ? ' on ' + depart : '') + (ret ? ' returning ' + ret : '')
        : 'Flights to ' + destIata + (depart ? ' on ' + depart : '');
      return 'https://www.google.com/travel/flights?q=' + encodeURIComponent(q);
    }

    function buildSkyscannerUrl(originIata, destIata, depart, ret) {
      // Real Skyscanner deep link: /transport/fluge/<o>/<d>/<yymmdd>/<yymmdd>/
      const o = (originIata || '').toLowerCase();
      const d = (destIata || '').toLowerCase();
      if (!o || !d) return '';
      const yymmdd = (iso) => (iso ? iso.slice(2).replace(/-/g, '') : '');
      let url = 'https://www.skyscanner.de/transport/fluge/' + o + '/' + d + '/';
      if (depart) url += yymmdd(depart) + '/';
      if (depart && ret) url += yymmdd(ret) + '/';
      return url;
    }

    function reasonMessage(reason) {
      switch (reason) {
        case 'not_configured':
          return 'Flight suggestions not configured — ask your organiser to set up a provider.';
        case 'profile_incomplete':
          return 'Complete your profile (home airport) to see flight suggestions.';
        case 'destination_unmapped':
          return "We couldn't map this destination to an airport — try Google Flights.";
        case 'no_routes':
          return 'No flights found for this date pair — try Google Flights for alternatives.';
        case 'api_down':
        case 'provider_error':
          return 'Flight search is temporarily unavailable — please refresh in a few minutes.';
        default:
          return '';
      }
    }

    function renderFlights(data) {
      // Real-deeplinks mode: no fabricated prices/airlines. We use the Worker's
      // resolved route (origin IATA from profile, destination IATA from the
      // poll) + dates, then link to Google Flights + Skyscanner where the user
      // sees genuine live prices. Everything shown here is real.
      if (!flightSection) return;
      flightSection.hidden = false;

      const origin = (data && data.origin) || {};
      const destination = (data && data.destination) || {};
      const dateRange = (data && data.dateRange) || {};
      const oIata = origin.iata || '';
      const dIata = destination.iata || '';
      const start = dateRange.start || '';
      const end = dateRange.end || '';
      const flights = (data && Array.isArray(data.flights)) ? data.flights : [];
      // Expose route for the per-card fallback search link.
      window._flightOriginIata = oIata;
      window._flightDestIata = dIata;

      // Real provider (Kiwi public) returns genuine prices + booking links, so
      // the refresh button stays; only the mock DEMO banner is suppressed.
      const hasRealFlights = flights.length > 0;
      if (flightRefreshBtn) flightRefreshBtn.hidden = !hasRealFlights;
      if (flightDemoBanner) flightDemoBanner.hidden = true;
      if (flightRestEl) flightRestEl.innerHTML = '';
      if (flightMoreEl) flightMoreEl.hidden = true;
      if (flightStateEl) flightStateEl.hidden = true;
      if (flightGoogleLink) flightGoogleLink.hidden = true;

      // Meta line
      if (flightMetaEl) {
        if (oIata && dIata) {
          flightMetaEl.textContent = oIata + ' → ' + dIata +
            (start ? ' · ' + start + ' – ' + end : '');
          flightMetaEl.hidden = false;
        } else {
          flightMetaEl.hidden = true;
        }
      }

      if (!flightListEl) return;
      flightListEl.innerHTML = '';
      flightListEl.hidden = false;

      // Destination couldn't be mapped to an airport → generic city search.
      if (!dIata) {
        const li = document.createElement('li');
        li.className = 'flight-deeplink-note';
        const a = document.createElement('a');
        a.target = '_blank'; a.rel = 'noopener noreferrer';
        a.href = 'https://www.google.com/travel/flights?q=' +
          encodeURIComponent('Flüge nach ' + pollDestination);
        a.textContent = 'Auf Google Flights suchen →';
        li.appendChild(document.createTextNode('Wir konnten das Ziel keinem Flughafen zuordnen. '));
        li.appendChild(a);
        flightListEl.appendChild(li);
        return;
      }

      // No home airport yet → prompt for profile, still offer a dest search.
      if (!oIata) {
        const li = document.createElement('li');
        li.className = 'flight-deeplink-note';
        const a = document.createElement('a');
        a.target = '_blank'; a.rel = 'noopener noreferrer';
        a.href = buildGoogleFlightsUrl('', dIata, start, end);
        a.textContent = 'Trotzdem nach ' + dIata + ' suchen →';
        li.appendChild(document.createTextNode(
          'Trag deinen Heimatflughafen im Profil ein, dann zeigen wir dir direkte Such-Links. '));
        li.appendChild(a);
        flightListEl.appendChild(li);
        return;
      }

      // Real itineraries from the provider → render clickable flight cards
      // (each with a "Buchen →" deep-link). Cheapest first; first one flagged.
      if (hasRealFlights) {
        flights.forEach(function (f, i) {
          flightListEl.appendChild(renderFlightCard(f, i === 0));
        });
        // Plus an escape hatch to compare more options on Google Flights.
        const compare = document.createElement('li');
        compare.className = 'flight-deeplink-note';
        const ca = document.createElement('a');
        ca.target = '_blank'; ca.rel = 'noopener noreferrer';
        ca.href = buildGoogleFlightsUrl(oIata, dIata, start, end);
        ca.textContent = 'Mehr Optionen auf Google Flights →';
        compare.appendChild(ca);
        flightListEl.appendChild(compare);
        return;
      }

      // Fallback (no itineraries found): route + Google Flights + Skyscanner.
      const li = document.createElement('li');
      li.className = 'flight-deeplink-card';

      const route = document.createElement('div');
      route.className = 'flight-deeplink-route';
      route.textContent = '✈️ ' + oIata + ' → ' + dIata;
      li.appendChild(route);

      const sub = document.createElement('div');
      sub.className = 'flight-deeplink-sub';
      sub.textContent = (start ? start + ' – ' + end : 'an euren Reisedaten') +
        ' · Live-Preise beim Anbieter';
      li.appendChild(sub);

      const actions = document.createElement('div');
      actions.className = 'flight-deeplink-actions';
      const g = document.createElement('a');
      g.className = 'flight-deeplink-btn flight-deeplink-btn-primary';
      g.target = '_blank'; g.rel = 'noopener noreferrer';
      g.href = buildGoogleFlightsUrl(oIata, dIata, start, end);
      g.textContent = 'Google Flights →';
      actions.appendChild(g);
      const skyUrl = buildSkyscannerUrl(oIata, dIata, start, end);
      if (skyUrl) {
        const s = document.createElement('a');
        s.className = 'flight-deeplink-btn';
        s.target = '_blank'; s.rel = 'noopener noreferrer';
        s.href = skyUrl;
        s.textContent = 'Skyscanner →';
        actions.appendChild(s);
      }
      li.appendChild(actions);
      flightListEl.appendChild(li);
    }

    async function loadFlights(forceRefresh) {
      if (!flightSection) return;
      flightSection.hidden = false;
      // Feature 2: show skeleton while loading (hide stale list/state).
      if (flightSkeleton) flightSkeleton.hidden = false;
      if (flightListEl) flightListEl.hidden = true;
      if (flightStateEl) flightStateEl.hidden = true;
      if (flightRefreshBtn) {
        flightRefreshBtn.disabled = true;
        flightRefreshBtn.textContent = forceRefresh ? 'Refreshing…' : 'Loading…';
      }
      try {
        const url =
          apiBase +
          (forceRefresh ? '/api/flights/refresh' : '/api/flights') +
          '?slug=' +
          encodeURIComponent(slug) +
          '&token=' +
          encodeURIComponent(token);
        const opts = forceRefresh
          ? { method: 'POST', headers: { 'Content-Type': 'application/json' } }
          : { headers: { Accept: 'application/json' } };
        const res = await fetch(url, opts);
        if (res.status === 429) {
          // Rate-limited refresh — surface gently.
          showToast('Refresh available again in ~1 hour', 'err');
          if (flightRefreshBtn) {
            flightRefreshBtn.textContent = 'Refresh prices';
            flightRefreshBtn.disabled = false;
          }
          return;
        }
        if (!res.ok) {
          throw new Error('HTTP ' + res.status);
        }
        const data = await res.json();
        renderFlights(data);
      } catch (err) {
        if (flightStateEl && flightStateText) {
          flightStateText.textContent =
            'Flüge konnten gerade nicht geladen werden — Seite neu laden.';
          flightStateEl.hidden = false;
        }
      } finally {
        if (flightSkeleton) flightSkeleton.hidden = true;
        if (flightRefreshBtn) {
          flightRefreshBtn.textContent = 'Refresh prices';
          flightRefreshBtn.disabled = false;
        }
      }
    }

    if (flightRefreshBtn) {
      flightRefreshBtn.addEventListener('click', () => loadFlights(true));
    }

    // ─── Phase 6: hotel shortlist (shared list) ──────────────────────────
    const hotelSection = document.getElementById('hotel-shortlist');
    const hotelSkeleton = hotelSection
      ? hotelSection.querySelector('[data-hotels-skeleton]')
      : null;
    const hotelListEl = hotelSection
      ? hotelSection.querySelector('[data-hotels-list]')
      : null;
    const hotelStateEl = hotelSection
      ? hotelSection.querySelector('[data-hotels-state]')
      : null;
    const hotelStateText = hotelSection
      ? hotelSection.querySelector('[data-hotels-state-text]')
      : null;
    const hotelDemoBanner = hotelSection
      ? hotelSection.querySelector('[data-hotels-demo-banner]')
      : null;
    const hotelMetaEl = hotelSection
      ? hotelSection.querySelector('[data-hotels-meta]')
      : null;
    let myVotedHotelId = null;

    function hotelReasonMessage(reason) {
      switch (reason) {
        case 'destination_unmapped':
          return 'Für dieses Ziel haben wir noch keine handverlesene Liste.';
        case 'no_inventory':
          return 'Für dieses Ziel haben wir noch keine handverlesene Liste.';
        case 'provider_error':
          return 'Hotel-Suche gerade nicht verfügbar — gleich nochmal versuchen.';
        default:
          return '';
      }
    }
    function bookingCitySearchUrl() {
      const params = new URLSearchParams({ ss: pollDestination, group_adults: '4', no_rooms: '1' });
      return 'https://www.booking.com/searchresults.html?' + params.toString();
    }

    function renderHotelCard(h, opts) {
      const li = document.createElement('li');
      li.className = 'hotel-card' + (opts.chosen ? ' is-chosen' : '');
      li.dataset.hotelId = h.hotelId;

      // Photo header — spans both grid columns and bleeds to the card edges.
      if (h.imageUrl) {
        const img = document.createElement('img');
        img.src = h.imageUrl;
        img.alt = h.name;
        img.loading = 'lazy';
        img.style.cssText = 'grid-column:1/-1;width:calc(100% + 28px);height:150px;object-fit:cover;border-radius:6px 6px 0 0;display:block;margin:-13px -14px 0;';
        li.appendChild(img);
      }

      const main = document.createElement('div');
      const nameEl = document.createElement('p');
      nameEl.className = 'hotel-card-name';
      nameEl.textContent = h.name;
      main.appendChild(nameEl);

      const metaEl = document.createElement('p');
      metaEl.className = 'hotel-card-meta';
      metaEl.textContent = '★'.repeat(Math.max(1, Math.min(5, h.stars))) + ' · ' +
        (h.distanceToCenterKm != null ? h.distanceToCenterKm.toFixed(1) + ' km zum Zentrum' : '');
      main.appendChild(metaEl);

      // Curated hotels store the neighbourhood/vibe in bookingHint.
      if (h.bookingHint) {
        const areaEl = document.createElement('p');
        areaEl.className = 'hotel-card-meta';
        areaEl.textContent = '📍 ' + h.bookingHint;
        main.appendChild(areaEl);
      }

      if (h.amenities && h.amenities.length > 0) {
        const am = document.createElement('p');
        am.className = 'hotel-card-amenities';
        am.textContent = h.amenities.slice(0, 4).join(' · ');
        main.appendChild(am);
      }
      li.appendChild(main);

      const prices = document.createElement('div');
      prices.className = 'hotel-card-prices';
      if (h.priceUnknown) {
        // Feature 4: no invented prices — real price lives on Booking.
        const live = document.createElement('p');
        live.className = 'hotel-card-pp-live';
        live.textContent = 'Preis live';
        prices.appendChild(live);
        const ppLabel = document.createElement('span');
        ppLabel.className = 'hotel-card-pp-label';
        ppLabel.textContent = 'auf Booking';
        prices.appendChild(ppLabel);
      } else {
        const pp = document.createElement('p');
        pp.className = 'hotel-card-pp';
        pp.textContent = '€' + h.perPersonEur;
        prices.appendChild(pp);
        const ppLabel = document.createElement('span');
        ppLabel.className = 'hotel-card-pp-label';
        ppLabel.textContent = 'pro Person';
        prices.appendChild(ppLabel);
        const total = document.createElement('p');
        total.className = 'hotel-card-total';
        total.textContent = '€' + h.totalPriceEur + ' gesamt · €' + h.nightlyPriceEur + '/Nacht';
        prices.appendChild(total);
      }
      li.appendChild(prices);

      const actions = document.createElement('div');
      actions.className = 'hotel-card-actions';

      if (opts.chosen) {
        const badge = document.createElement('span');
        badge.className = 'hotel-card-chosen-badge';
        badge.textContent = '✓ Vom Organisator gewählt';
        actions.appendChild(badge);
      } else {
        const voteBtn = document.createElement('button');
        voteBtn.type = 'button';
        voteBtn.className = 'hotel-card-button';
        const isMine = myVotedHotelId === h.hotelId;
        voteBtn.textContent = isMine ? '✓ Deine Stimme' : 'Für dieses Hotel stimmen';
        if (isMine) voteBtn.classList.add('hotel-card-button-primary');
        voteBtn.addEventListener('click', () => voteForHotel(h.hotelId));
        actions.appendChild(voteBtn);
      }

      const tally = document.createElement('span');
      tally.className = 'hotel-card-vote-tally';
      const count = (opts.voteTallies && opts.voteTallies[h.hotelId]) || 0;
      tally.textContent = count + ' Stimme' + (count === 1 ? '' : 'n');
      actions.appendChild(tally);

      // Booking CTA button (Feature 4)
      if (h.bookingUrl) {
        const bookLink = document.createElement('a');
        bookLink.href = h.bookingUrl;
        bookLink.target = '_blank';
        bookLink.rel = 'noopener noreferrer';
        bookLink.textContent = '🏨 Jetzt buchen';
        bookLink.className = 'hotel-card-button hotel-card-button-book';
        actions.appendChild(bookLink);
      }

      li.appendChild(actions);
      return li;
    }

    function renderHotels(data) {
      if (!hotelSection) return;
      hotelSection.hidden = false;
      const hotels = (data && data.hotels) || [];
      const reason = data && data.reason;
      const provider = data && data.provider;
      const dateRange = data && data.dateRange;
      const destination = data && data.destination;
      const chosenHotelId = data && data.chosenHotelId;
      const voteTallies = (data && data.voteTallies) || {};

      // Feed the interactive map with the same hotel set the cards use.
      setMapHotels(reason === 'ok' ? hotels : []);

      if (hotelDemoBanner) {
        hotelDemoBanner.hidden = !(provider && provider.isReal === false);
      }
      if (hotelMetaEl && destination && destination.city) {
        const datesLabel =
          dateRange && dateRange.checkIn
            ? ' · ' + dateRange.checkIn + ' → ' + dateRange.checkOut
            : '';
        const guestsLabel =
          data && typeof data.guests === 'number'
            ? ' · ' + data.guests + ' ' + (data.guests === 1 ? 'Gast' : 'Gäste')
            : '';
        hotelMetaEl.textContent = destination.city + datesLabel + guestsLabel;
        hotelMetaEl.hidden = false;
      }
      if (hotelListEl) {
        hotelListEl.innerHTML = '';
        hotelListEl.hidden = true;
      }
      if (hotelStateEl) hotelStateEl.hidden = true;

      if (reason !== 'ok' || hotels.length === 0) {
        if (hotelStateEl && hotelStateText) {
          // German fallback + a real Booking.com city-search deep link.
          hotelStateText.innerHTML = '';
          hotelStateText.appendChild(document.createTextNode(
            (hotelReasonMessage(reason || 'no_inventory') ||
              'Noch keine Hotelliste.') + ' '));
          const a = document.createElement('a');
          a.href = bookingCitySearchUrl();
          a.target = '_blank'; a.rel = 'noopener noreferrer';
          a.textContent = 'Auf Booking.com suchen →';
          a.style.cssText = 'color:#0066cc;font-weight:700;text-decoration:none';
          hotelStateText.appendChild(a);
          hotelStateEl.hidden = false;
        }
        return;
      }

      const top = hotels.slice(0, 5);
      if (hotelListEl) {
        for (const h of top) {
          hotelListEl.appendChild(
            renderHotelCard(h, {
              chosen: chosenHotelId === h.hotelId,
              voteTallies,
            })
          );
        }
        hotelListEl.hidden = false;
      }
    }

    async function loadHotels() {
      if (!hotelSection) return;
      hotelSection.hidden = false;
      // Feature 2: show skeleton while loading.
      if (hotelSkeleton) hotelSkeleton.hidden = false;
      if (hotelListEl) hotelListEl.hidden = true;
      if (hotelStateEl) hotelStateEl.hidden = true;
      try {
        const url =
          apiBase +
          '/api/hotels?slug=' +
          encodeURIComponent(slug) +
          '&token=' +
          encodeURIComponent(token);
        const res = await fetch(url, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        renderHotels(data);
      } catch (err) {
        if (hotelStateEl && hotelStateText) {
          hotelStateText.textContent =
            'Hotels konnten gerade nicht geladen werden — Seite neu laden.';
          hotelStateEl.hidden = false;
        }
      } finally {
        if (hotelSkeleton) hotelSkeleton.hidden = true;
      }
    }

    async function voteForHotel(hotelId) {
      try {
        const res = await fetch(apiBase + '/api/hotel-vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, token, hotelId }),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        myVotedHotelId = data.hotelId || hotelId;
        showToast('Vote saved', 'ok');
        // Re-render with updated tallies.
        loadHotels();
      } catch (err) {
        showToast('Vote failed', 'err');
      }
    }

    // ─── Phase 7: activities (Claude-curated) ────────────────────────────
    const activitiesSection = document.getElementById('activities-list');
    const activitiesSkeleton = activitiesSection
      ? activitiesSection.querySelector('[data-activities-skeleton]')
      : null;
    const activitiesDemoBanner = activitiesSection
      ? activitiesSection.querySelector('[data-activities-demo-banner]')
      : null;
    const activitiesMetaEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-meta]')
      : null;
    const activitiesStateEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-state]')
      : null;
    const activitiesStateText = activitiesSection
      ? activitiesSection.querySelector('[data-activities-state-text]')
      : null;
    const thisWeekSection = activitiesSection
      ? activitiesSection.querySelector('[data-activities-thisweek-section]')
      : null;
    const thisWeekListEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-thisweek]')
      : null;
    const alwaysGreatSection = activitiesSection
      ? activitiesSection.querySelector('[data-activities-alwaysgreat-section]')
      : null;
    const alwaysGreatListEl = activitiesSection
      ? activitiesSection.querySelector('[data-activities-alwaysgreat]')
      : null;

    const ACTIVITY_ICONS = {
      concert: '🎵',
      festival: '🎉',
      museum: '🏛️',
      food: '🍽️',
      outdoors: '🌳',
      history: '🏰',
      neighborhood: '🏘️',
      event: '🎭',
      other: '🔮',
    };

    function renderActivityCard(item) {
      const li = document.createElement('li');
      li.className = 'activity-card';
      if (item.confidence === 'low') li.classList.add('is-low');

      // Primary "ansehen" link: real Wikipedia/official page when present,
      // else a Google Maps lookup. The whole card is wrapped in this link so
      // the photo + name are clickable (matches the hotel-card feel).
      var photoSrc = item.photoUrl || item.imageUrl;
      var primaryHref = item.link || item.bookingUrl ||
        (item.mapsUrl ||
          ('https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(item.name)));

      var card = document.createElement('a');
      card.href = primaryHref;
      card.target = '_blank';
      card.rel = 'noopener noreferrer';
      card.className = 'activity-card-link';

      // Photo
      if (photoSrc) {
        const img = document.createElement('img');
        img.src = photoSrc;
        img.alt = item.name;
        img.loading = 'lazy';
        img.style.cssText = 'grid-column:1/-1;width:calc(100% + 24px);height:140px;object-fit:cover;border-radius:6px 6px 0 0;display:block;margin:-12px -12px 8px;';
        card.appendChild(img);
      }

      const icon = document.createElement('div');
      icon.className = 'activity-card-icon';
      icon.textContent = ACTIVITY_ICONS[item.type] || ACTIVITY_ICONS.other;
      card.appendChild(icon);

      const body = document.createElement('div');
      body.className = 'activity-card-body';

      const nameRow = document.createElement('div');
      nameRow.style.cssText = 'display:flex;align-items:flex-start;justify-content:space-between;gap:8px';
      const name = document.createElement('p');
      name.className = 'activity-card-name';
      name.style.margin = '0';
      name.textContent = item.name;
      nameRow.appendChild(name);
      // Price badge inline with name. Wikimedia POIs carry no pricing signal,
      // and Ticketmaster events have a "Tickets →" CTA instead of an unreliable
      // price range — suppress the badge for both rather than show noise.
      if (item.source !== 'wikimedia' && item.source !== 'ticketmaster') {
        const priceTag = document.createElement('span');
        priceTag.style.cssText = 'font-size:12px;font-weight:700;white-space:nowrap;color:' + (item.paid ? '#0f172a' : '#16a34a');
        priceTag.textContent = item.paid ? (typeof item.priceEur === 'number' ? '€' + item.priceEur : 'Kostenpflichtig') : 'Gratis';
        nameRow.appendChild(priceTag);
      }
      body.appendChild(nameRow);

      const why = document.createElement('p');
      why.className = 'activity-card-why';
      why.textContent = item.whyOneSentence;
      body.appendChild(why);

      // Dated events (Ticketmaster) lead with the DATE, made prominent so the
      // "when" reads at a glance; evergreen sights keep the muted meta line.
      var isEvent = item.type === 'event';
      const meta = document.createElement('p');
      meta.className = 'activity-card-meta';
      if (isEvent && item.dateRange) {
        meta.textContent = '🎫 ' + item.dateRange;
        meta.style.cssText = 'font-weight:700;color:#0066cc;font-size:12px;';
      } else {
        meta.textContent = item.dateRange;
      }
      body.appendChild(meta);

      if (item.confidence === 'medium') {
        const badge = document.createElement('span');
        badge.className = 'activity-confidence-badge is-medium';
        badge.textContent = 'ℹ Termine prüfen';
        body.appendChild(badge);
      } else if (item.confidence === 'low') {
        const badge = document.createElement('span');
        badge.className = 'activity-confidence-badge is-low';
        badge.textContent = '⚠ Aktuelles Programm checken';
        body.appendChild(badge);
      }

      // Action row: primary "Ansehen" + a small "Karte" link to maps.
      const actions = document.createElement('div');
      actions.style.cssText = 'display:flex;gap:12px;align-items:center;margin-top:6px;';

      const seeLabel = document.createElement('span');
      // Events link to a ticket page → "Tickets →"; sights → "Ansehen →".
      seeLabel.textContent = isEvent && item.link
        ? 'Tickets →'
        : (item.link ? 'Ansehen →' : (item.bookingUrl ? 'Mehr Info →' : 'Auf Karte →'));
      seeLabel.style.cssText = 'font-size:12px;font-weight:600;color:#0066cc;';
      actions.appendChild(seeLabel);

      // Separate "Karte" deep-link (nested <a> would be invalid, so stop the
      // card-link navigation and open maps in a new tab from the click).
      var mapsHref = item.mapsUrl ||
        ((typeof item.lat === 'number' && typeof item.lng === 'number')
          ? ('https://www.google.com/maps/search/?api=1&query=' + item.lat + ',' + item.lng)
          : null);
      if (mapsHref && item.link) {
        const mapBtn = document.createElement('span');
        mapBtn.textContent = '📍 Karte';
        mapBtn.setAttribute('role', 'link');
        mapBtn.style.cssText = 'font-size:12px;font-weight:600;color:#475569;cursor:pointer;';
        mapBtn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          window.open(mapsHref, '_blank', 'noopener,noreferrer');
        });
        actions.appendChild(mapBtn);
      }
      body.appendChild(actions);

      // Photo attribution (Openverse CC fallback only) — tiny, honours licence.
      if (item.photoAttribution) {
        const attr = document.createElement('p');
        attr.textContent = 'Foto: ' + item.photoAttribution;
        attr.style.cssText = 'margin:4px 0 0;font-size:9px;color:#94a3b8;';
        body.appendChild(attr);
      }

      card.appendChild(body);
      li.appendChild(card);
      return li;
    }

    function renderActivities(data) {
      if (!activitiesSection) return;
      activitiesSection.hidden = false;
      const activities = (data && data.activities) || { thisWeek: [], alwaysGreat: [] };
      const reason = data && data.reason;
      const provider = data && data.provider;
      const destination = data && data.destination;

      // Feed the interactive map with the same activity set the cards use.
      var allActs = (activities.thisWeek || []).concat(activities.alwaysGreat || []);
      setMapActivities(reason === 'ok' ? allActs : []);

      if (activitiesDemoBanner) {
        activitiesDemoBanner.hidden = !(provider && provider.isReal === false);
      }
      if (activitiesMetaEl && destination) {
        activitiesMetaEl.textContent = destination;
        activitiesMetaEl.hidden = false;
      }
      if (thisWeekListEl) thisWeekListEl.innerHTML = '';
      if (alwaysGreatListEl) alwaysGreatListEl.innerHTML = '';
      if (thisWeekSection) thisWeekSection.hidden = true;
      if (alwaysGreatSection) alwaysGreatSection.hidden = true;
      if (activitiesStateEl) activitiesStateEl.hidden = true;

      const total = (activities.thisWeek || []).length + (activities.alwaysGreat || []).length;
      if (reason !== 'ok' || total === 0) {
        if (activitiesStateEl && activitiesStateText) {
          activitiesStateText.textContent =
            reason === 'destination_too_obscure'
              ? 'Für dieses Ziel haben wir keine konkreten Tipps — schau auf TripAdvisor oder in deinem Reiseführer.'
              : 'Aktivitäten gerade nicht verfügbar — in ein paar Minuten neu laden.';
          activitiesStateEl.hidden = false;
        }
        return;
      }

      if ((activities.thisWeek || []).length > 0 && thisWeekListEl && thisWeekSection) {
        for (const item of activities.thisWeek) {
          thisWeekListEl.appendChild(renderActivityCard(item));
        }
        thisWeekSection.hidden = false;
      }
      if ((activities.alwaysGreat || []).length > 0 && alwaysGreatListEl && alwaysGreatSection) {
        for (const item of activities.alwaysGreat) {
          alwaysGreatListEl.appendChild(renderActivityCard(item));
        }
        alwaysGreatSection.hidden = false;
      }
    }

    async function loadActivities() {
      if (!activitiesSection) return;
      activitiesSection.hidden = false;
      // Feature 2: show skeleton while loading.
      if (activitiesSkeleton) activitiesSkeleton.hidden = false;
      if (activitiesStateEl) activitiesStateEl.hidden = true;
      try {
        const url =
          apiBase +
          '/api/activities?slug=' +
          encodeURIComponent(slug) +
          '&token=' +
          encodeURIComponent(token);
        const res = await fetch(url, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        renderActivities(data);
      } catch (err) {
        if (activitiesStateEl && activitiesStateText) {
          activitiesStateText.textContent =
            'Aktivitäten konnten gerade nicht geladen werden — Seite neu laden.';
          activitiesStateEl.hidden = false;
          activitiesSection.hidden = false;
        }
      } finally {
        if (activitiesSkeleton) activitiesSkeleton.hidden = true;
      }
    }

    // ─── Interactive map (Leaflet + OpenStreetMap, keyless) ───────────────
    // Free, no API key. Leaflet (CSS+JS) is loaded lazily from the unpkg CDN
    // the first time we actually have trip data to plot (i.e. on the Reise tab
    // after the poll closes) so other tabs stay lean. Hotels (blue) and
    // activities (orange) get distinct divIcon pins; clicking a pin opens a
    // popup with a thumbnail + a real link. Items without lat/lng are skipped;
    // if nothing has coords the whole section stays hidden. Everything here is
    // defensive: it never throws if Leaflet is slow/absent or the container is
    // missing, and the map is built at most once.
    var LEAFLET_CSS = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    var LEAFLET_JS = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    var LEAFLET_CSS_SRI = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
    var LEAFLET_JS_SRI = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';

    var mapHotels = [];
    var mapActivities = [];
    var mapHotelsReady = false;
    var mapActivitiesReady = false;
    var leafletPromise = null;
    var tripMap = null;
    var tripMapBuilt = false;

    function hasCoords(o) {
      return o && typeof o.lat === 'number' && typeof o.lng === 'number' &&
        isFinite(o.lat) && isFinite(o.lng);
    }

    function setMapHotels(list) {
      mapHotels = Array.isArray(list) ? list.filter(hasCoords) : [];
      mapHotelsReady = true;
      tryBuildTripMap();
    }
    function setMapActivities(list) {
      mapActivities = Array.isArray(list) ? list.filter(hasCoords) : [];
      mapActivitiesReady = true;
      tryBuildTripMap();
    }

    // Inject Leaflet CSS+JS once; resolve when window.L is available. Never
    // rejects — on load failure it resolves with the (still-undefined) global
    // so callers just no-op via the window.L guard.
    function ensureLeaflet() {
      if (leafletPromise) return leafletPromise;
      leafletPromise = new Promise(function (resolve) {
        if (window.L) { resolve(window.L); return; }
        try {
          if (!document.querySelector('link[data-leaflet]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = LEAFLET_CSS;
            link.integrity = LEAFLET_CSS_SRI;
            link.crossOrigin = '';
            link.setAttribute('data-leaflet', '1');
            document.head.appendChild(link);
          }
          var existing = document.querySelector('script[data-leaflet]');
          if (existing) {
            existing.addEventListener('load', function () { resolve(window.L); });
            existing.addEventListener('error', function () { resolve(window.L); });
            if (window.L) resolve(window.L);
            return;
          }
          var s = document.createElement('script');
          s.src = LEAFLET_JS;
          s.integrity = LEAFLET_JS_SRI;
          s.crossOrigin = '';
          s.async = true;
          s.setAttribute('data-leaflet', '1');
          s.addEventListener('load', function () { resolve(window.L); });
          s.addEventListener('error', function () { resolve(window.L); });
          document.head.appendChild(s);
        } catch (e) {
          resolve(window.L);
        }
      });
      return leafletPromise;
    }

    // Coloured teardrop pin via divIcon (keyless — no marker image needed).
    function makePin(L, color) {
      return L.divIcon({
        className: '',
        html: '<span style="display:block;width:18px;height:18px;border-radius:50% 50% 50% 0;' +
          'background:' + color + ';border:2px solid #fff;box-shadow:0 1px 4px rgba(15,23,42,0.5);' +
          'transform:rotate(-45deg);"></span>',
        iconSize: [18, 18],
        iconAnchor: [9, 18],
        popupAnchor: [0, -18],
      });
    }

    // Escape user/provider strings before they go into popup innerHTML.
    function esc(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function popupHtml(name, imgUrl, linkUrl, linkLabel) {
      var html = '<div style="max-width:200px">';
      if (imgUrl) {
        html += '<img src="' + esc(imgUrl) + '" alt="" loading="lazy" ' +
          'style="width:100%;height:90px;object-fit:cover;border-radius:6px;display:block;margin-bottom:6px"/>';
      }
      html += '<strong style="font-size:13px;display:block;line-height:1.3">' + esc(name) + '</strong>';
      if (linkUrl) {
        html += '<a href="' + esc(linkUrl) + '" target="_blank" rel="noopener noreferrer" ' +
          'style="display:inline-block;margin-top:6px;font-size:12px;font-weight:700;color:#0066cc;text-decoration:none">' +
          esc(linkLabel) + '</a>';
      }
      html += '</div>';
      return html;
    }

    // Optional nice-to-have: scroll to + briefly highlight the matching card.
    function highlightCard(selector) {
      try {
        var el = document.querySelector(selector);
        if (!el) return;
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        el.classList.add('trip-map-flash');
        setTimeout(function () { el.classList.remove('trip-map-flash'); }, 1600);
      } catch (e) { /* non-fatal */ }
    }

    // Build the map once both datasets have reported in and Leaflet is ready.
    function tryBuildTripMap() {
      if (tripMapBuilt) return;
      if (!mapHotelsReady || !mapActivitiesReady) return; // wait for both loads
      if (mapHotels.length === 0 && mapActivities.length === 0) {
        var sec0 = document.getElementById('trip-map-section');
        if (sec0) sec0.hidden = true; // nothing to plot
        return;
      }
      ensureLeaflet().then(function (L) {
        if (!L || tripMapBuilt) return; // CDN failed → silently skip the map
        var section = document.getElementById('trip-map-section');
        var container = document.getElementById('trip-map');
        if (!section || !container) return; // container absent → no-op
        try {
          section.hidden = false;
          tripMap = L.map(container, { scrollWheelZoom: false, attributionControl: true });
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors',
          }).addTo(tripMap);

          var hotelIcon = makePin(L, '#0066cc');
          var actIcon = makePin(L, '#ea580c');
          var bounds = [];

          mapHotels.forEach(function (h) {
            var m = L.marker([h.lat, h.lng], { icon: hotelIcon, title: h.name }).addTo(tripMap);
            m.bindPopup(popupHtml(h.name, h.imageUrl, h.bookingUrl, 'Buchen →'));
            if (h.hotelId) {
              m.on('click', function () {
                highlightCard('.hotel-card[data-hotel-id="' + (window.CSS && CSS.escape ? CSS.escape(h.hotelId) : h.hotelId) + '"]');
              });
            }
            bounds.push([h.lat, h.lng]);
          });

          mapActivities.forEach(function (a) {
            var img = a.photoUrl || a.imageUrl;
            var link = a.link || a.bookingUrl || a.mapsUrl;
            var m = L.marker([a.lat, a.lng], { icon: actIcon, title: a.name }).addTo(tripMap);
            m.bindPopup(popupHtml(a.name, img, link, 'Ansehen →'));
            bounds.push([a.lat, a.lng]);
          });

          if (bounds.length === 1) {
            tripMap.setView(bounds[0], 14);
          } else if (bounds.length > 1) {
            tripMap.fitBounds(bounds, { padding: [30, 30], maxZoom: 15 });
          }
          // Leaflet measures size at init; if the tab was hidden the container
          // had 0 height. Recompute once it is visible.
          setTimeout(function () { if (tripMap) tripMap.invalidateSize(); }, 120);
          tripMapBuilt = true;
        } catch (e) {
          // Never let a map error kill the rest of the trip view.
          if (tripMap && tripMap.remove) { try { tripMap.remove(); } catch (e2) {} }
          tripMap = null;
          if (section) section.hidden = true;
        }
      });
    }

    // ── Feature 2: typical weather for destination + trip dates ──
    // Open-Meteo geocoding + historical archive (same calendar dates, a recent
    // year) as a robust "typisches Wetter" proxy that works regardless of how
    // far out the trip is. Free, no API key, CORS-friendly. All data is real.
    function weatherEmoji(avgMax, rainDays, total) {
      if (rainDays / Math.max(1, total) > 0.5) return '🌧️';
      if (rainDays / Math.max(1, total) > 0.25) return '🌦️';
      if (avgMax >= 24) return '☀️';
      if (avgMax >= 16) return '⛅';
      if (avgMax >= 8) return '🌥️';
      return '❄️';
    }
    async function loadWeather(overlap) {
      const el = document.getElementById('weather-widget');
      if (!el) return;
      try {
        const city = (pollDestination || '').split(',')[0].trim();
        if (!city) return;
        // Featured trip range (fallback: poll start, capped to ~7 days).
        const ranges = (overlap && overlap.ranges) || [];
        const feat = ranges.find((r) => r.tier === 'perfect') ||
          ranges.find((r) => r.tier === 'withEffort') || ranges[0] || null;
        let start = feat ? feat.start : dateRangeStartIn;
        if (!start) return;
        // Sample up to 7 days from start.
        const startDt = new Date(start + 'T00:00:00Z');
        const endDt = new Date(startDt.getTime() + 6 * 86400000);
        const fmt = (d) => d.toISOString().slice(0, 10);
        const monthName = startDt.toLocaleString('de-DE', { month: 'long' });

        // 1) Geocode the city (real coords).
        const geo = await fetch(
          'https://geocoding-api.open-meteo.com/v1/search?name=' +
          encodeURIComponent(city) + '&count=1&language=de'
        ).then((r) => r.json());
        const place = geo && geo.results && geo.results[0];
        if (!place) return;

        // 2) Historical archive for the same dates, recent year (2023).
        const y = '2023';
        const s2 = y + fmt(startDt).slice(4);
        const e2 = y + fmt(endDt).slice(4);
        const wx = await fetch(
          'https://archive-api.open-meteo.com/v1/archive?latitude=' + place.latitude +
          '&longitude=' + place.longitude + '&start_date=' + s2 + '&end_date=' + e2 +
          '&daily=temperature_2m_max,temperature_2m_min,precipitation_sum&timezone=auto'
        ).then((r) => r.json());
        const d = wx && wx.daily;
        if (!d || !d.temperature_2m_max || !d.temperature_2m_max.length) return;
        const maxs = d.temperature_2m_max.filter((x) => x != null);
        const mins = d.temperature_2m_min.filter((x) => x != null);
        const precs = (d.precipitation_sum || []).filter((x) => x != null);
        if (!maxs.length) return;
        const avgMax = Math.round(maxs.reduce((a, b) => a + b, 0) / maxs.length);
        const avgMin = Math.round(mins.reduce((a, b) => a + b, 0) / Math.max(1, mins.length));
        const rainDays = precs.filter((p) => p >= 1).length;

        const emojiEl = document.getElementById('weather-emoji');
        const titleEl = document.getElementById('weather-title');
        const subEl = document.getElementById('weather-sub');
        if (emojiEl) emojiEl.textContent = weatherEmoji(avgMax, rainDays, precs.length);
        if (titleEl) titleEl.textContent = 'Typisches Wetter im ' + monthName + ' · ' + avgMax + '° / ' + avgMin + '°';
        if (subEl) {
          subEl.textContent = city + ' · ' +
            (rainDays === 0 ? 'meist trocken' : rainDays + ' von ' + precs.length + ' Tagen Regen') +
            ' (historischer Schnitt)';
        }
        el.hidden = false;
      } catch (e) {
        // Weather is best-effort — silently skip on any failure.
      }
    }

    // Phase 8: build add-to-calendar URLs from the featured trip range and
    // reveal the inline button block. Skipped if the calendar block isn't in
    // the DOM (defensive — older SSR cache).
    function addDaysIso(iso, days) {
      const parts = iso.split('-').map(Number);
      const dt = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
      dt.setUTCDate(dt.getUTCDate() + days);
      const y = dt.getUTCFullYear();
      const m = String(dt.getUTCMonth() + 1).padStart(2, '0');
      const d = String(dt.getUTCDate()).padStart(2, '0');
      return y + '-' + m + '-' + d;
    }
    function packCompactDate(iso) {
      return iso.replace(/-/g, '') + 'T000000Z';
    }
    function packIsoDate(iso) {
      return iso + 'T00:00:00Z';
    }
    function buildCalUrls(featured) {
      const startIso = featured ? featured.start : dateRangeStartIn;
      const endIncIso = featured ? featured.end : dateRangeEndIn;
      const endExclIso = addDaysIso(endIncIso, 1);
      const description = 'See your trip page for full details.';
      const location = pollDestination;
      const title = pollTitle;
      const datesCompact = packCompactDate(startIso) + '/' + packCompactDate(endExclIso);
      const google =
        'https://calendar.google.com/calendar/render?' +
        new URLSearchParams({
          action: 'TEMPLATE',
          text: title,
          dates: datesCompact,
          details: description,
          location: location,
        }).toString();
      const outlook =
        'https://outlook.live.com/calendar/0/deeplink/compose?' +
        new URLSearchParams({
          path: '/calendar/action/compose',
          rru: 'addevent',
          subject: title,
          startdt: packIsoDate(startIso),
          enddt: packIsoDate(endExclIso),
          body: description,
          location: location,
          allday: 'true',
        }).toString();
      const yahoo =
        'https://calendar.yahoo.com/?' +
        new URLSearchParams({
          v: '60',
          title: title,
          st: packCompactDate(startIso),
          et: packCompactDate(endExclIso),
          desc: description,
          in_loc: location,
        }).toString();
      return { google, outlook, yahoo, apple: icalDownloadUrl };
    }
    function renderAddToCalendarButtons(overlap) {
      const container = document.querySelector('[data-add-to-calendar-buttons]');
      if (!container) return;
      const ranges = (overlap && overlap.ranges) || [];
      const featured =
        ranges.find((r) => r.tier === 'perfect') ||
        ranges.find((r) => r.tier === 'withEffort') ||
        ranges[0] ||
        null;
      const urls = buildCalUrls(featured);
      const gEl = container.querySelector('[data-cal-google]');
      const aEl = container.querySelector('[data-cal-apple]');
      const oEl = container.querySelector('[data-cal-outlook]');
      const yEl = container.querySelector('[data-cal-yahoo]');
      const wEl = container.querySelector('[data-cal-webcal]');
      if (gEl) gEl.setAttribute('href', urls.google);
      if (aEl) aEl.setAttribute('href', urls.apple);
      if (oEl) oEl.setAttribute('href', urls.outlook);
      if (yEl) yEl.setAttribute('href', urls.yahoo);
      // Feature 5: webcal:// link uses the same .ics URL but with webcal:// scheme
      if (wEl) wEl.setAttribute('href', urls.apple.replace(/^https?:\/\//, 'webcal://'));
      container.hidden = false;
    }

    /** @param {any} overlap */
    function renderSummaryBanner(overlap) {
      if (!summaryBanner || !summaryTextEl) return;
      const ranges = (overlap && overlap.ranges) || [];
      const perfect = ranges.filter((r) => r.tier === 'perfect');
      const withEffort = ranges.filter((r) => r.tier === 'withEffort');
      const oneShort = ranges.filter((r) => r.tier === 'oneShort');
      let msg;
      let kind = 'ok';
      if (perfect.length > 0) {
        const top = perfect[0];
        msg = '🎉 Best dates: ' + top.start + ' → ' + top.end + ' (' + top.length + ' days)';
      } else if (withEffort.length > 0) {
        const top = withEffort[0];
        msg = '✨ With a little effort: ' + top.start + ' → ' + top.end + ' (' + top.length + ' days) — almost everyone can make it';
      } else if (oneShort.length > 0) {
        // Feature 3: graceful fallback — no date worked for everyone, but
        // suggest the window where the fewest people are missing.
        const top = oneShort.slice().sort((a, b) => b.length - a.length)[0];
        msg = '🤏 No date worked for all — but ' + top.start + ' → ' + top.end +
          ' is closest (just one person short). Worth a group chat?';
        kind = 'warn';
      } else {
        msg = '😕 No overlapping dates yet. Try nudging people to add more "maybe" days, or pick a new window together.';
        kind = 'warn';
      }
      summaryTextEl.textContent = msg;
      summaryBanner.dataset.kind = kind;
      summaryBanner.hidden = false;
    }

    async function refreshState() {
      const url =
        apiBase +
        '/api/poll?slug=' +
        encodeURIComponent(slug) +
        '&token=' +
        encodeURIComponent(token);
      try {
        const res = await fetch(url, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        applyServerState(data);
        // Feature 1: start live-poll interval when poll is open, stop when closed
        if (!data.closed && !pollInterval) {
          pollInterval = setInterval(refreshState, 30000);
        } else if (data.closed && pollInterval) {
          clearInterval(pollInterval);
          pollInterval = null;
        }
      } catch (err) {
        setStatus('offline — votes won’t save');
      }
    }

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') refreshState();
    });

    // When the Reise tab is (re)opened, the map container may have been hidden
    // (0px) at init — recompute Leaflet's size so tiles fill the box. The nav
    // button exists at parse time, so this binds reliably (unlike the deferred
    // window.__switchToTripTab from BottomNav). Also pre-warms Leaflet so the
    // map is ready the moment trip data lands.
    var tripTabBtn = document.querySelector('.bottom-nav-tab[data-tab="trip"]');
    if (tripTabBtn) {
      tripTabBtn.addEventListener('click', function () {
        ensureLeaflet();
        // Safety net: if the first refreshState hadn't loaded the preview yet
        // (e.g. it raced or errored), load it now on first Reise-tab open. The
        // guard makes this a no-op once content is already loaded.
        loadTripContent(false);
        setTimeout(function () { if (tripMap) tripMap.invalidateSize(); }, 160);
      });
    }

    refreshState();
  })();
</script>

