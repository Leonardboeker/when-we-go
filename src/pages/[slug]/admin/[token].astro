---
// src/pages/[slug]/admin/[token].astro
// Phase 2: organiser dashboard. Static skeleton + live data via /api/admin/poll.
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CostSplitPanel from '../../../components/CostSplitPanel.astro';
import HotelShortlist from '../../../components/HotelShortlist.astro';
import { polls, type Poll } from '../../../data/polls';
import { daysUntil } from '../../../lib/calendar';

export const prerender = true;

export const getStaticPaths = (() => {
  return polls.map((poll) => ({
    params: { slug: poll.slug, token: poll.organizerToken },
    props: { poll },
  }));
}) satisfies GetStaticPaths;

const { poll } = Astro.props as { poll: Poll };

const days = daysUntil(poll.pollCloseAt);
const closed = days === 0;
const closeLabel = new Date(poll.pollCloseAt).toLocaleString('en-GB', {
  weekday: 'short',
  day: '2-digit',
  month: 'short',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZoneName: 'short',
});

const publicApiBase =
  (import.meta.env.WHENWEGO_PUBLIC_API_BASE as string | undefined) ?? '';
---

<BaseLayout
  title={`${poll.title} — admin`}
  ogImage={`/og/${poll.slug}.png`}
  ogDescription={`Organiser view for ${poll.title}. Live overlap + who has voted.`}
>
  <main class="admin-page">
    <header class="admin-header">
      <p class="admin-eyebrow">Organiser dashboard</p>
      <h1>{poll.title}</h1>
      {poll.destination && <p class="admin-destination">{poll.destination}</p>}
    </header>

    <section class="admin-meta admin-card" aria-label="Poll metadata">
      <dl class="admin-meta-grid">
        <div>
          <dt>Slug</dt>
          <dd><code>{poll.slug}</code></dd>
        </div>
        <div>
          <dt>Date range</dt>
          <dd>{poll.dateRangeStart} → {poll.dateRangeEnd}</dd>
        </div>
        <div>
          <dt>Poll closes</dt>
          <dd>{closeLabel}</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>
            <span class="status-badge status-open" data-admin-status>
              {closed ? 'Closed' : `${days} day${days === 1 ? '' : 's'} left`}
            </span>
          </dd>
        </div>
        <div>
          <dt>Participants</dt>
          <dd>{poll.participants.length}</dd>
        </div>
        <div>
          <dt>Created</dt>
          <dd>{poll.createdAt.slice(0, 10)}</dd>
        </div>
      </dl>
    </section>

    <section class="admin-section" aria-label="Viable ranges">
      <div class="admin-section-head">
        <h2>Viable date ranges</h2>
        <span class="admin-section-hint" data-admin-overlap-hint>Loading…</span>
      </div>
      <div class="admin-card" data-admin-ranges>
        <p class="admin-empty"><em>Fetching aggregate from API…</em></p>
      </div>
    </section>

    <section class="admin-section" aria-label="Per-date breakdown">
      <div class="admin-section-head">
        <h2>Per-date breakdown</h2>
      </div>
      <div class="admin-card admin-perdate" data-admin-perdate>
        <p class="admin-empty"><em>Loading…</em></p>
      </div>
    </section>

    <section class="admin-section" aria-label="Participants">
      <div class="admin-section-head">
        <h2>Participants</h2>
        <div class="admin-actions">
          <button type="button" class="admin-button" data-admin-refresh>
            Refresh
          </button>
          <button type="button" class="admin-button admin-button-danger" data-admin-close>
            Force close
          </button>
          {/* #8 — reopen a closed poll for N more days (hidden until closed) */}
          <button type="button" class="admin-button" data-admin-reopen hidden>
            Wieder öffnen (+7 Tage)
          </button>
          {/* #5 (DSGVO) — export all data + irreversible post-trip wipe */}
          <button type="button" class="admin-button" data-admin-export>
            Daten exportieren
          </button>
          <button type="button" class="admin-button admin-button-danger" data-admin-wipe>
            Daten löschen
          </button>
        </div>
      </div>
      <p class="admin-profiles-summary" data-admin-profiles-summary>
        Profiles: <span data-admin-profiles-count>—</span>
      </p>
      <table class="admin-table">
        <thead>
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Status</th>
            <th scope="col">Profile</th>
            <th scope="col">Picks</th>
            <th scope="col">Last vote</th>
          </tr>
        </thead>
        <tbody data-admin-voters>
          {poll.participants.map((p) => (
            <tr data-token={p.token}>
              <td>{p.name}</td>
              <td><span class="status-badge status-open">No votes yet</span></td>
              <td><span class="admin-cell-placeholder" data-cell="profile">—</span></td>
              <td><span class="admin-cell-placeholder">—</span></td>
              <td><span class="admin-cell-placeholder">—</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    {/* Phase 5: per-participant flights summary. Hidden until /api/admin/flights
        resolves. Shows DEMO banner when the wired provider isn't real. */}
    <section class="admin-section" aria-label="Flights summary" data-admin-flights-section hidden>
      <div class="admin-section-head">
        <h2>Flights per participant</h2>
        <span class="admin-section-hint" data-admin-flights-hint>—</span>
      </div>
      <div class="admin-card" data-admin-flights-demo hidden style="margin-bottom:12px;padding:10px 12px;background:repeating-linear-gradient(45deg,#fff7d6,#fff7d6 8px,#ffeaa0 8px,#ffeaa0 16px);border:2px solid #1c1b1f;font-size:13px;">
        <strong>📍 DEMO flight data</strong> — real provider not configured.
      </div>
      <table class="admin-table">
        <thead>
          <tr>
            <th scope="col">Participant</th>
            <th scope="col">From → To</th>
            <th scope="col">Status</th>
            <th scope="col">Cheapest</th>
            <th scope="col">Offers</th>
          </tr>
        </thead>
        <tbody data-admin-flights-tbody></tbody>
      </table>
    </section>

    {/* Phase 6: hotel shortlist + organiser controls. Hidden until
        /api/hotels resolves post-close. */}
    <HotelShortlist mode="admin" />

    <CostSplitPanel
      slug={poll.slug}
      organizerToken={poll.organizerToken}
      apiBase={publicApiBase}
    />

    <p class="admin-foot-note" data-admin-foot>
      Auto-refreshes every 30 seconds.
    </p>
  </main>

  <script
    is:inline
    define:vars={{
      slug: poll.slug,
      organizerToken: poll.organizerToken,
      apiBase: publicApiBase,
    }}
  >
    (function () {
      'use strict';
      const REFRESH_MS = 30_000;
      let pollTimer = null;
      let isClosed = false;

      const statusEl = document.querySelector('[data-admin-status]');
      const overlapHintEl = document.querySelector('[data-admin-overlap-hint]');
      const rangesEl = document.querySelector('[data-admin-ranges]');
      const perDateEl = document.querySelector('[data-admin-perdate]');
      const votersEl = document.querySelector('[data-admin-voters]');
      const refreshBtn = document.querySelector('[data-admin-refresh]');
      const closeBtn = document.querySelector('[data-admin-close]');
      const reopenBtn = document.querySelector('[data-admin-reopen]');
      const exportBtn = document.querySelector('[data-admin-export]');
      const wipeBtn = document.querySelector('[data-admin-wipe]');
      const footEl = document.querySelector('[data-admin-foot]');

      /** @param {number|null} ts */
      function fmtTs(ts) {
        if (!ts) return '—';
        const d = new Date(ts);
        return d.toLocaleString('en-GB', {
          day: '2-digit',
          month: 'short',
          hour: '2-digit',
          minute: '2-digit',
        });
      }

      /** @param {{voterStatus:Array<any>, overlap:any, closed:boolean, closedAt:string|null}} data */
      function render(data) {
        isClosed = !!data.closed;
        if (statusEl) {
          // #8 — reflect live state (reopen flips Closed → Offen).
          statusEl.textContent = isClosed ? 'Closed' : 'Offen';
        }
        // Phase 10: reveal the CostSplitPanel once we know the poll is closed.
        // Dataset flag covers race where the panel script runs after this fire.
        if (isClosed) {
          if (document.body) document.body.dataset.pollClosed = 'true';
          document.dispatchEvent(new CustomEvent('whenwego:poll-closed'));
        }

        // Voters table
        if (votersEl) {
          let profilesComplete = 0;
          for (const v of data.voterStatus) {
            const row = votersEl.querySelector('tr[data-token="' + v.token + '"]');
            if (!row) continue;
            const tds = row.querySelectorAll('td');
            if (tds.length < 5) continue;
            // status badge
            tds[1].innerHTML = v.hasVoted
              ? '<span class="status-badge status-paid">Voted</span>'
              : '<span class="status-badge status-open">No votes yet</span>';
            // profile badge — typeof check so missing field falls through gracefully
            const complete = v.profileComplete === true;
            tds[2].innerHTML = complete
              ? '<span class="status-badge status-paid" title="Email + airport set">&#x2713;</span>'
              : '<span class="status-badge status-open" title="Profile incomplete">&#x2717;</span>';
            if (complete) profilesComplete++;
            tds[3].textContent = String(v.voteCount || 0);
            tds[4].textContent = fmtTs(v.lastVotedAt);
          }
          const countEl = document.querySelector('[data-admin-profiles-count]');
          if (countEl) {
            countEl.textContent = profilesComplete + ' / ' + data.voterStatus.length + ' complete';
          }
        }

        // Viable ranges
        const ranges = (data.overlap && data.overlap.ranges) || [];
        const perfect = ranges.filter((r) => r.tier === 'perfect');
        const withEffort = ranges.filter((r) => r.tier === 'withEffort');
        const oneShort = ranges.filter((r) => r.tier === 'oneShort');
        if (overlapHintEl) {
          overlapHintEl.textContent =
            perfect.length + ' perfect / ' + withEffort.length + ' with-effort / ' + oneShort.length + ' one-short';
        }
        if (rangesEl) {
          if (ranges.length === 0) {
            rangesEl.innerHTML = '<p class="admin-empty">No multi-day overlaps yet.</p>';
          } else {
            const parts = [];
            for (const [label, arr] of [['Perfect', perfect], ['With effort', withEffort], ['One short', oneShort]]) {
              if (arr.length === 0) continue;
              parts.push('<h3 class="admin-range-tier">' + label + '</h3><ul class="admin-range-list">');
              for (const r of arr) {
                parts.push('<li>' + r.start + ' → ' + r.end + ' <em>(' + r.length + ' days)</em></li>');
              }
              parts.push('</ul>');
            }
            rangesEl.innerHTML = parts.join('');
          }
        }

        // Per-date stacked bars
        if (perDateEl && data.overlap && data.overlap.perDate) {
          const perDate = data.overlap.perDate;
          const dates = Object.keys(perDate).sort();
          const parts = ['<div class="admin-perdate-list">'];
          for (const d of dates) {
            const bd = perDate[d];
            const total = bd.yes + bd.maybe + bd.no + bd.unvoted;
            if (total === 0) continue;
            const w = (n) => total === 0 ? 0 : (n / total) * 100;
            parts.push(
              '<div class="admin-perdate-row">' +
                '<span class="admin-perdate-date">' + d + '</span>' +
                '<div class="admin-perdate-bar">' +
                  '<span class="bar-yes" style="width:' + w(bd.yes) + '%" title="yes: ' + bd.yes + '"></span>' +
                  '<span class="bar-maybe" style="width:' + w(bd.maybe) + '%" title="maybe: ' + bd.maybe + '"></span>' +
                  '<span class="bar-no" style="width:' + w(bd.no) + '%" title="no: ' + bd.no + '"></span>' +
                  '<span class="bar-unvoted" style="width:' + w(bd.unvoted) + '%" title="unvoted: ' + bd.unvoted + '"></span>' +
                '</div>' +
                '<span class="admin-perdate-meta">' + bd.yes + '/' + (total - bd.unvoted) + '/' + total + '</span>' +
              '</div>'
            );
          }
          parts.push('</div>');
          perDateEl.innerHTML = parts.join('');
        }

        if (footEl) {
          footEl.textContent = isClosed
            ? 'Poll closed at ' + (data.closedAt || '?') + '.'
            : 'Auto-refreshes every 30 seconds.';
        }
        if (closeBtn) closeBtn.disabled = isClosed;
        // #8 — reopen only makes sense once the poll is closed.
        if (reopenBtn) reopenBtn.hidden = !isClosed;
      }

      async function fetchOnce() {
        try {
          const url = apiBase + '/api/admin/poll?slug=' + encodeURIComponent(slug);
          const res = await fetch(url, {
            headers: { 'X-Organizer-Token': organizerToken, Accept: 'application/json' },
          });
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const data = await res.json();
          render(data);
          // Phase 5: pull flight summaries once we know the poll is closed.
          if (data.closed) fetchAdminFlights();
          // Phase 6: hotel shortlist (admin view).
          if (data.closed) loadAdminHotels();
        } catch (err) {
          if (footEl) footEl.textContent = 'Refresh failed: ' + (err && err.message);
        }
      }

      // Phase 5 — fetch per-participant flight summary + render table.
      async function fetchAdminFlights() {
        const section = document.querySelector('[data-admin-flights-section]');
        const tbody = document.querySelector('[data-admin-flights-tbody]');
        const hint = document.querySelector('[data-admin-flights-hint]');
        const demo = document.querySelector('[data-admin-flights-demo]');
        if (!section || !tbody) return;
        try {
          const res = await fetch(
            apiBase + '/api/admin/flights?slug=' + encodeURIComponent(slug),
            { headers: { 'X-Organizer-Token': organizerToken, Accept: 'application/json' } }
          );
          if (!res.ok) return;
          const data = await res.json();
          section.hidden = false;
          if (demo) demo.hidden = !(data.provider && data.provider.isReal === false);
          if (hint) {
            hint.textContent = data.provider
              ? 'provider: ' + data.provider.name
              : '';
          }
          tbody.innerHTML = '';
          for (const p of data.participants || []) {
            const tr = document.createElement('tr');
            const fromTo =
              p.origin && p.destination
                ? p.origin.iata + ' → ' + p.destination.iata
                : '—';
            const cheapest =
              p.cheapestEur !== null && p.cheapestEur !== undefined
                ? '€' + p.cheapestEur + (p.cheapestCarrier ? ' (' + p.cheapestCarrier + ')' : '')
                : '—';
            tr.innerHTML =
              '<td>' + p.name + '</td>' +
              '<td>' + fromTo + '</td>' +
              '<td>' + p.reason + '</td>' +
              '<td>' + cheapest + '</td>' +
              '<td>' + (p.totalOffers || 0) + '</td>';
            tbody.appendChild(tr);
          }
        } catch (_err) {
          // Graceful failure — admin section stays hidden.
        }
      }

      // ─── Phase 6: hotel shortlist (admin view) ──────────────────────────
      const hotelSection = document.getElementById('hotel-shortlist');
      const hotelRefreshBtn = hotelSection
        ? hotelSection.querySelector('[data-hotels-refresh]')
        : null;
      const hotelListEl = hotelSection
        ? hotelSection.querySelector('[data-hotels-list]')
        : null;
      const hotelStateEl = hotelSection
        ? hotelSection.querySelector('[data-hotels-state]')
        : null;
      const hotelStateText = hotelSection
        ? hotelSection.querySelector('[data-hotels-state-text]')
        : null;
      const hotelDemoBanner = hotelSection
        ? hotelSection.querySelector('[data-hotels-demo-banner]')
        : null;
      const hotelMetaEl = hotelSection
        ? hotelSection.querySelector('[data-hotels-meta]')
        : null;

      function hotelReasonMsg(reason) {
        switch (reason) {
          case 'destination_unmapped':
            return "Destination couldn't be mapped to an IATA code.";
          case 'no_inventory':
            return 'No hotels in shortlist for these dates yet.';
          case 'provider_error':
            return 'Provider error — try refreshing.';
          default:
            return '';
        }
      }

      function renderAdminHotelCard(h, opts) {
        const li = document.createElement('li');
        li.className = 'hotel-card' + (opts.chosen ? ' is-chosen' : '');
        li.dataset.hotelId = h.hotelId;

        const main = document.createElement('div');
        const nameEl = document.createElement('p');
        nameEl.className = 'hotel-card-name';
        nameEl.textContent = h.name;
        main.appendChild(nameEl);
        const metaEl = document.createElement('p');
        metaEl.className = 'hotel-card-meta';
        metaEl.textContent =
          '★'.repeat(Math.max(1, Math.min(5, h.stars))) +
          ' · ' +
          (h.distanceToCenterKm != null
            ? h.distanceToCenterKm.toFixed(1) + ' km to centre'
            : '');
        main.appendChild(metaEl);
        if (h.amenities && h.amenities.length > 0) {
          const am = document.createElement('p');
          am.className = 'hotel-card-amenities';
          am.textContent = h.amenities.slice(0, 4).join(' · ');
          main.appendChild(am);
        }
        li.appendChild(main);

        const prices = document.createElement('div');
        prices.className = 'hotel-card-prices';
        const pp = document.createElement('p');
        pp.className = 'hotel-card-pp';
        pp.textContent = '€' + h.perPersonEur;
        prices.appendChild(pp);
        const ppLabel = document.createElement('span');
        ppLabel.className = 'hotel-card-pp-label';
        ppLabel.textContent = 'per person';
        prices.appendChild(ppLabel);
        const total = document.createElement('p');
        total.className = 'hotel-card-total';
        total.textContent =
          '€' + h.totalPriceEur + ' total · €' + h.nightlyPriceEur + '/night';
        prices.appendChild(total);
        li.appendChild(prices);

        const actions = document.createElement('div');
        actions.className = 'hotel-card-actions';
        const chooseBtn = document.createElement('button');
        chooseBtn.type = 'button';
        chooseBtn.className = 'hotel-card-button';
        if (opts.chosen) {
          chooseBtn.classList.add('hotel-card-button-primary');
          chooseBtn.textContent = '✓ Chosen';
          chooseBtn.disabled = true;
        } else {
          chooseBtn.textContent = 'Mark as chosen';
          chooseBtn.addEventListener('click', () =>
            chooseHotel(h.hotelId)
          );
        }
        actions.appendChild(chooseBtn);

        const tally = document.createElement('span');
        tally.className = 'hotel-card-vote-tally';
        const count = (opts.voteTallies && opts.voteTallies[h.hotelId]) || 0;
        tally.textContent = count + ' vote' + (count === 1 ? '' : 's');
        actions.appendChild(tally);
        li.appendChild(actions);

        return li;
      }

      function renderAdminHotels(data) {
        if (!hotelSection) return;
        hotelSection.hidden = false;
        const hotels = (data && data.hotels) || [];
        const reason = data && data.reason;
        const provider = data && data.provider;
        const dateRange = data && data.dateRange;
        const destination = data && data.destination;
        const chosenHotelId = data && data.chosenHotelId;
        const voteTallies = (data && data.voteTallies) || {};

        if (hotelDemoBanner) {
          hotelDemoBanner.hidden = !(provider && provider.isReal === false);
        }
        if (hotelMetaEl && destination && destination.city) {
          const datesLabel =
            dateRange && dateRange.checkIn
              ? ' · ' + dateRange.checkIn + ' → ' + dateRange.checkOut
              : '';
          const guestsLabel =
            data && typeof data.guests === 'number'
              ? ' · ' + data.guests + ' guest' + (data.guests === 1 ? '' : 's')
              : '';
          hotelMetaEl.textContent = destination.city + datesLabel + guestsLabel;
          hotelMetaEl.hidden = false;
        }
        if (hotelListEl) {
          hotelListEl.innerHTML = '';
          hotelListEl.hidden = true;
        }
        if (hotelStateEl) hotelStateEl.hidden = true;

        if (reason !== 'ok' || hotels.length === 0) {
          if (hotelStateEl && hotelStateText) {
            hotelStateText.textContent =
              hotelReasonMsg(reason || 'no_inventory') ||
              'Hotel shortlist is empty.';
            hotelStateEl.hidden = false;
          }
          return;
        }

        const top = hotels.slice(0, 5);
        if (hotelListEl) {
          for (const h of top) {
            hotelListEl.appendChild(
              renderAdminHotelCard(h, {
                chosen: chosenHotelId === h.hotelId,
                voteTallies,
              })
            );
          }
          hotelListEl.hidden = false;
        }
      }

      async function loadAdminHotels() {
        if (!hotelSection) return;
        try {
          // Admin reuses the participant endpoint — pass the organiser token
          // as the "viewer" token (organiser is also a participant of the poll
          // for read purposes; if not, fall back to the first participant).
          // Picking the first participant lets us avoid encoding the org token
          // into a participant-shaped endpoint.
          const firstParticipantRow = document.querySelector(
            '[data-admin-voters] tr[data-token]'
          );
          const viewerToken = firstParticipantRow
            ? firstParticipantRow.dataset.token
            : null;
          if (!viewerToken) return;
          const url =
            apiBase +
            '/api/hotels?slug=' +
            encodeURIComponent(slug) +
            '&token=' +
            encodeURIComponent(viewerToken);
          const res = await fetch(url, { headers: { Accept: 'application/json' } });
          if (!res.ok) return;
          const data = await res.json();
          renderAdminHotels(data);
        } catch (_err) {
          /* graceful */
        }
      }

      async function chooseHotel(hotelId) {
        try {
          const res = await fetch(apiBase + '/api/admin/hotel-choose', {
            method: 'POST',
            headers: {
              'X-Organizer-Token': organizerToken,
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ slug, hotelId }),
          });
          if (!res.ok) throw new Error('HTTP ' + res.status);
          await loadAdminHotels();
        } catch (err) {
          alert('Could not mark chosen: ' + (err && err.message));
        }
      }

      if (hotelRefreshBtn) {
        hotelRefreshBtn.addEventListener('click', async () => {
          hotelRefreshBtn.disabled = true;
          hotelRefreshBtn.textContent = 'Refreshing…';
          try {
            const res = await fetch(
              apiBase + '/api/hotels/refresh?slug=' + encodeURIComponent(slug),
              {
                method: 'POST',
                headers: { 'X-Organizer-Token': organizerToken },
              }
            );
            if (res.status === 429) {
              alert('Refresh available again in ~4 hours.');
            } else if (!res.ok) {
              alert('Refresh failed (HTTP ' + res.status + ')');
            } else {
              await loadAdminHotels();
            }
          } catch (err) {
            alert('Refresh failed: ' + (err && err.message));
          } finally {
            hotelRefreshBtn.textContent = 'Refresh hotels';
            hotelRefreshBtn.disabled = false;
          }
        });
      }

      function startPolling() {
        stopPolling();
        if (isClosed) return;
        pollTimer = setInterval(fetchOnce, REFRESH_MS);
      }
      function stopPolling() {
        if (pollTimer) clearInterval(pollTimer);
        pollTimer = null;
      }

      if (refreshBtn) {
        refreshBtn.addEventListener('click', fetchOnce);
      }
      if (closeBtn) {
        closeBtn.addEventListener('click', async () => {
          if (!confirm('Close this poll now? This cannot be undone.')) return;
          try {
            const url = apiBase + '/api/admin/close?slug=' + encodeURIComponent(slug);
            const res = await fetch(url, {
              method: 'POST',
              headers: { 'X-Organizer-Token': organizerToken, Accept: 'application/json' },
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            await fetchOnce();
            stopPolling();
          } catch (err) {
            alert('Close failed: ' + (err && err.message));
          }
        });
      }
      // #5 (DSGVO) — export all data as a downloadable JSON (token via header).
      if (exportBtn) {
        exportBtn.addEventListener('click', async () => {
          exportBtn.disabled = true;
          try {
            const url = apiBase + '/api/admin/export?slug=' + encodeURIComponent(slug);
            const res = await fetch(url, {
              headers: { 'X-Organizer-Token': organizerToken, Accept: 'application/json' },
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const blob = await res.blob();
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'when-we-go-' + slug + '-export.json';
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(a.href);
          } catch (err) {
            alert('Export fehlgeschlagen: ' + (err && err.message));
          } finally {
            exportBtn.disabled = false;
          }
        });
      }

      // #5 (DSGVO) — irreversible post-trip data wipe (double confirm).
      if (wipeBtn) {
        wipeBtn.addEventListener('click', async () => {
          if (!confirm('ALLE Daten dieser Umfrage unwiderruflich löschen (Stimmen, Profile, E-Mails)? Vorher am besten exportieren.')) return;
          if (!confirm('Wirklich sicher? Das kann NICHT rückgängig gemacht werden.')) return;
          wipeBtn.disabled = true;
          try {
            const url = apiBase + '/api/admin/wipe?slug=' + encodeURIComponent(slug) + '&confirm=DELETE';
            const res = await fetch(url, {
              method: 'POST',
              headers: { 'X-Organizer-Token': organizerToken, Accept: 'application/json' },
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            alert('Daten gelöscht. Die Seite wird neu geladen.');
            location.reload();
          } catch (err) {
            alert('Löschen fehlgeschlagen: ' + (err && err.message));
            wipeBtn.disabled = false;
          }
        });
      }

      // #8 — reopen a closed poll for 7 more days.
      if (reopenBtn) {
        reopenBtn.addEventListener('click', async () => {
          if (!confirm('Abstimmung für 7 weitere Tage öffnen? Schließen-Ergebnisse (Übersicht) werden zurückgesetzt.')) return;
          reopenBtn.disabled = true;
          try {
            const url = apiBase + '/api/admin/reopen?slug=' + encodeURIComponent(slug) + '&days=7';
            const res = await fetch(url, {
              method: 'POST',
              headers: { 'X-Organizer-Token': organizerToken, Accept: 'application/json' },
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            await fetchOnce();
            startPolling();
          } catch (err) {
            alert('Wieder öffnen fehlgeschlagen: ' + (err && err.message));
          } finally {
            reopenBtn.disabled = false;
          }
        });
      }

      fetchOnce().then(startPolling);
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') fetchOnce();
      });
    })();
  </script>
</BaseLayout>

